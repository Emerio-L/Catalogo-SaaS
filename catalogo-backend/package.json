{
  "name": "catalogo-backend",
  "version": "1.0.0",
  "description": "Backend API para el Catálogo de Productos",
  "main": "server.js",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "start": "node server.js",
    "dev": "node server.js",
    "build": "npx prisma generate",
    "prisma:generate": "npx prisma generate",
    "prisma:migrate": "npx prisma migrate dev",
    "prisma:deploy": "npx prisma migrate deploy",
    "accounts:backfill": "node backfill-account-numbers.js",
    "test:saas-upgrade": "node test-saas-upgrade.js",
    "ensure:superadmin": "node ensure-superadmin.js",
    "reset:superadmin": "node reset-superadmin.js"
  },
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "bcryptjs": "^3.0.3",
    "cloudinary": "^2.10.0",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^4.19.2",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.2.0",
    "multer": "^1.4.5-lts.1",
    "sharp": "^0.33.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "prisma": "^6.19.3"
  }
}
