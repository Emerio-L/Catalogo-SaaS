---
interface Props {
	title: string;
	description?: string;
	keywords?: string;
	noindex?: boolean;
	locale?: string;
}

const {
	title,
	description = 'Crea tu tienda en línea con carrito de compras en Guatemala. Recibe pedidos organizados, administra productos y vende sin comisiones con Sedelynk.',
	keywords = '',
	noindex = false,
	locale = 'es_GT'
} = Astro.props;
const siteUrl = import.meta.env.PUBLIC_SITE_URL || Astro.site?.origin || 'https://sedelynk.com';
const canonicalUrl = new URL(Astro.url.pathname, siteUrl).toString();

// Fetch global SaaS settings server-side to resolve global faviconUrl
const publicBackendUrl = import.meta.env.PUBLIC_BACKEND_URL || 'http://localhost:3005';
let faviconUrl = '';
try {
	const settingsRes = await fetch(`${publicBackendUrl}/api/saas/settings`);
	if (settingsRes.ok) {
		const settingsData = await settingsRes.json();
		if (settingsData && settingsData.faviconUrl) {
			faviconUrl = settingsData.faviconUrl;
		}
	}
} catch (e) {
	// Fallback silently if backend is offline during SSR
}

const finalFaviconUrl = faviconUrl
	? (faviconUrl.startsWith('http://') || faviconUrl.startsWith('https://')
		? faviconUrl
		: new URL(faviconUrl, publicBackendUrl).toString())
	: new URL('/favicon.png', siteUrl).toString();

const socialImageUrl = finalFaviconUrl;
const gaMeasurementId = import.meta.env.PUBLIC_GA_MEASUREMENT_ID || '';
const structuredData = Astro.url.pathname === '/' ? {
	'@context': 'https://schema.org',
	'@type': 'SoftwareApplication',
	name: 'Sedelynk',
	applicationCategory: 'BusinessApplication',
	operatingSystem: 'Web',
	url: canonicalUrl,
	description,
	areaServed: {
		'@type': 'Country',
		name: 'Guatemala'
	},
	offers: {
		'@type': 'Offer',
		priceCurrency: 'GTQ'
	}
} : null;
---

<!DOCTYPE html>
<html lang="es-GT">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{title}</title>
    <meta name="description" content={description}>
    {keywords && <meta name="keywords" content={keywords}>}
    <meta name="robots" content={noindex ? 'noindex, nofollow, noarchive, nosnippet' : 'index, follow, max-image-preview:large'}>
    <meta name="googlebot" content={noindex ? 'noindex, nofollow, noarchive, nosnippet' : 'index, follow, max-image-preview:large'}>
    <meta name="geo.region" content="GT">
    <meta name="geo.placename" content="Guatemala">
    <link rel="canonical" href={canonicalUrl}>
    <link rel="alternate" hreflang="es-GT" href={canonicalUrl}>
    <link rel="alternate" hreflang="x-default" href={canonicalUrl}>
    <link rel="icon" type="image/png" href={finalFaviconUrl}>
    <link rel="apple-touch-icon" sizes="180x180" href={finalFaviconUrl}>
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="default">
    <meta name="apple-mobile-web-app-title" content={title}>
    <meta property="og:type" content="website">
    <meta property="og:locale" content={locale}>
    <meta property="og:site_name" content="Sedelynk">
    <meta property="og:title" content={title}>
    <meta property="og:description" content={description}>
    <meta property="og:url" content={canonicalUrl}>
    <meta property="og:image" content={socialImageUrl}>
    <meta name="twitter:card" content="summary">
    <meta name="twitter:title" content={title}>
    <meta name="twitter:description" content={description}>
    <meta name="twitter:image" content={socialImageUrl}>
    {structuredData && <script type="application/ld+json" set:html={JSON.stringify(structuredData)} />}
    {gaMeasurementId && (
        <>
            <script async src={`https://www.googletagmanager.com/gtag/js?id=${gaMeasurementId}`}></script>
            <script is:inline define:vars={{ gaMeasurementId }}>
                window.dataLayer = window.dataLayer || [];
                function gtag(){dataLayer.push(arguments);}
                gtag('js', new Date());
                gtag('config', gaMeasurementId, { anonymize_ip: true });
            </script>
        </>
    )}
    
    <!-- Tailwind CSS -->
    <script is:inline src="https://cdn.tailwindcss.com"></script>
    <script is:inline>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        primary: {
                            50: 'var(--color-primary-50)',
                            100: 'var(--color-primary-100)',
                            200: 'var(--color-primary-200)',
                            300: 'var(--color-primary-300)',
                            400: 'var(--color-primary-400)',
                            500: 'var(--color-primary-500)',
                            600: 'var(--color-primary-600)',
                            700: 'var(--color-primary-700)',
                            800: 'var(--color-primary-800)',
                            900: 'var(--color-primary-900)',
                            950: 'var(--color-primary-950)',
                        }
                    }
                }
            }
        }
    </script>
    <!-- FontAwesome Icons -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style is:inline>
        @import url('https://fonts.googleapis.com/css2?family=Outfit:wght@400;500;600;700;800;900&family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap');

        :root {
            --color-primary-50: #f0fdf4;
            --color-primary-100: #dcfce7;
            --color-primary-200: #a7f3d0;
            --color-primary-300: #6ee7b7;
            --color-primary-400: #34d399;
            --color-primary-500: #10b981;
            --color-primary-600: #059669;
            --color-primary-700: #047857;
            --color-primary-800: #065f46;
            --color-primary-900: #064e3b;
            --color-primary-950: #022c22;
            --color-primary-500-rgb: 16, 185, 129;
            --color-primary-900-rgb: 6, 78, 59;
        }
        
        html {
            height: 100%;
            overflow: hidden;
            margin: 0;
            padding: 0;
        }

        body {
            height: 100%;
            overflow-x: hidden;
            overflow-y: auto;
            scroll-behavior: smooth;
            margin: 0;
            padding: 0;
            font-family: 'Plus Jakarta Sans', sans-serif;
            background-color: #f8fafc; /* slate-50 */
        }
        
        h1, h2, h3, h4, .font-heading {
            font-family: 'Outfit', sans-serif;
        }

        /* Glassmorphism classes */
        .glass-header {
            background: rgba(var(--color-primary-900-rgb), 0.85); /* primary-900 with opacity */
            backdrop-filter: blur(12px);
            -webkit-backdrop-filter: blur(12px);
            border-bottom: 1px solid rgba(255, 255, 255, 0.1);
        }

        .glass-card {
            background: rgba(255, 255, 255, 0.8);
            backdrop-filter: blur(8px);
            -webkit-backdrop-filter: blur(8px);
        }
        
        /* Custom shadows and glow */
        .shadow-premium {
            box-shadow: 0 10px 30px -10px rgba(0, 0, 0, 0.04), 0 1px 1px 0 rgba(0, 0, 0, 0.01);
        }

        .shadow-premium-hover {
            box-shadow: 0 20px 40px -15px rgba(0, 0, 0, 0.08), 0 1px 3px 0 rgba(0, 0, 0, 0.02);
        }

        .glow-primary {
            box-shadow: 0 10px 25px -5px rgba(var(--color-primary-500-rgb), 0.15), 0 8px 10px -6px rgba(var(--color-primary-500-rgb), 0.15);
        }

        /* Custom active states */
        .card-active {
            border-color: var(--color-primary-500) !important; /* primary-500 */
            background-color: var(--color-primary-50); /* primary-50 */
            transform: translateY(-4px) scale(1.01);
            box-shadow: 0 15px 30px -10px rgba(var(--color-primary-500-rgb), 0.12);
        }

        .category-active {
            background-color: var(--color-primary-500) !important;
            color: white !important;
            box-shadow: 0 4px 14px rgba(var(--color-primary-500-rgb), 0.35);
        }

        .no-scrollbar::-webkit-scrollbar {
            display: none;
        }

        .no-scrollbar {
            -ms-overflow-style: none;
            scrollbar-width: none;
        }

        /* Animations */
        @keyframes slideUp {
            from {
                transform: translateY(20px);
                opacity: 0;
            }
            to {
                transform: translateY(0);
                opacity: 1;
            }
        }

        .animate-slide-up {
            animation: slideUp 0.4s cubic-bezier(0.16, 1, 0.3, 1) forwards;
        }

        /* Toggle switch */
        .toggle-dot {
            transition: transform 0.3s ease-in-out;
        }
        input:checked ~ .toggle-dot {
            transform: translateX(100%);
            background-color: var(--color-primary-500);
        }
        input:checked ~ .toggle-bg {
            background-color: var(--color-primary-50);
            border-color: var(--color-primary-200);
        }

        .private-nav-item {
            display: flex;
            align-items: center;
            gap: 0.85rem;
            border-radius: 1.1rem;
            padding: 0.9rem 1rem;
            color: #dbeafe;
            font-size: 0.82rem;
            font-weight: 800;
            transition: all 0.2s ease;
        }

        .private-nav-item:hover {
            background: rgba(255, 255, 255, 0.08);
            color: #ffffff;
        }

        .private-nav-active {
            background: linear-gradient(135deg, var(--color-primary-600), var(--color-primary-500));
            color: #ffffff !important;
            box-shadow: 0 14px 28px -16px rgba(var(--color-primary-500-rgb), 0.85);
        }
    </style>
</head>
<body class="transition-all duration-300">
	<slot />
</body>
</html>
