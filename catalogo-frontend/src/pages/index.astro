    <div id="support-modal" class="fixed inset-0 z-[110] hidden items-end justify-center bg-slate-950/60 p-4 backdrop-blur-sm sm:items-center">
        <form id="support-form" onsubmit="submitSupportTicket(event)" class="w-full max-w-md rounded-[2rem] bg-white p-6 shadow-2xl">
            <div class="flex items-start justify-between gap-4">
                <div>
                    <p class="text-[10px] font-black uppercase tracking-[0.24em] text-violet-600">SEDELYNK</p>
                    <h2 class="mt-1 text-2xl font-black text-slate-950">¿Cómo podemos ayudarte?</h2>
