        }
        window.registrarCuentaSaasLanding = registrarCuentaSaasLanding;

        async function solicitarRecuperacionLanding(event) {
            if (event) event.preventDefault();
            const identifier = document.getElementById("landing-recovery-identifier").value.trim();
            const submitBtn = document.getElementById('landing-recovery-submit');
            const form = document.getElementById('landing-recovery-form');
            const successEl = document.getElementById('landing-recovery-success');
            const devLinkEl = document.getElementById('landing-dev-reset-link');

            mostrarErrorRecoveryLanding('');
            mostrarEstadoRecoveryLanding('');
            if (!identifier) {
                mostrarErrorRecoveryLanding("Ingresa tu correo, usuario o número de cuenta.");
                return;
            }
            try {
                if (submitBtn) {
                    submitBtn.disabled = true;
                    submitBtn.classList.add('opacity-70', 'cursor-wait');
                    submitBtn.innerHTML = '<i class="fa-solid fa-spinner fa-spin mr-2"></i> Procesando...';
                }
                
                const res = await fetch(`${API_URL}/auth/forgot-password`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ identifier })
                });

                const data = await res.json().catch(() => ({}));
                if (res.ok) {
                    if (form) form.classList.add('hidden');
                    mostrarEstadoRecoveryLanding(data.message || "Hemos enviado un correo de recuperación.", true);
                    
                    if (data.devResetUrl) {
                        if (devLinkEl) {
                            devLinkEl.innerHTML = `
                                <div class="mt-4 p-4 bg-amber-50 border border-amber-200 rounded-2xl text-xs font-bold text-amber-800">
                                    <p class="uppercase tracking-wider text-[10px] text-amber-600 mb-1">Enlace de desarrollo (Localhost)</p>
                                    <a href="${data.devResetUrl}" target="_blank" class="underline break-all">${data.devResetUrl}</a>
                                </div>
                            `;
                            devLinkEl.classList.remove('hidden');
                        }
                    }
                } else {
                    mostrarErrorRecoveryLanding(data.error || "No se pudo procesar la solicitud.");
                }
            } catch (err) {
                mostrarErrorRecoveryLanding("Error de conexión al servidor.");
            } finally {
                if (submitBtn) {
                    submitBtn.disabled = false;
                    submitBtn.classList.remove('opacity-70', 'cursor-wait');
                    submitBtn.innerHTML = 'Recuperar acceso';
                }
            }
        }
        window.solicitarRecuperacionLanding = solicitarRecuperacionLanding;

        function abrirCambioCredencialesObligatorio({ tenant, accessKey, changeUsername, changePassword }) {
            window._pendingTenantSlug = tenant;
            window._pendingAccessKey = accessKey;
            window._forceChangeUsername = changeUsername === true;
            window._forceChangePassword = changePassword === true;
            const usernameWrapper = document.getElementById('force-username-wrapper');
            const passwordWrapper = document.getElementById('force-password-wrapper');
            const confirmWrapper = document.getElementById('force-confirm-wrapper');
            const usernameInput = document.getElementById('force-new-username');
            const passwordInput = document.getElementById('force-new-password');
            const confirmInput = document.getElementById('force-confirm-password');
            usernameWrapper?.classList.toggle('hidden', !window._forceChangeUsername);
            passwordWrapper?.classList.toggle('hidden', !window._forceChangePassword);
            confirmWrapper?.classList.toggle('hidden', !window._forceChangePassword);
            if (usernameInput) usernameInput.required = window._forceChangeUsername;
            if (passwordInput) passwordInput.required = window._forceChangePassword;
            if (confirmInput) confirmInput.required = window._forceChangePassword;
            document.getElementById('force-credentials-error')?.classList.add('hidden');
            const modal = document.getElementById('force-credentials-modal');
            modal?.classList.remove('hidden');
            modal?.classList.add('flex');
            setTimeout(() => (window._forceChangeUsername ? usernameInput : passwordInput)?.focus(), 20);
        }
        window.abrirCambioCredencialesObligatorio = abrirCambioCredencialesObligatorio;

        async function guardarCredencialesDefinitivas(event) {
            event?.preventDefault();
            const tenant = window._pendingTenantSlug;
            const accessKey = window._pendingAccessKey;
            const newUsername = document.getElementById('force-new-username')?.value.trim() || '';
            const newPassword = document.getElementById('force-new-password')?.value || '';
            const confirmPassword = document.getElementById('force-confirm-password')?.value || '';
            const error = document.getElementById('force-credentials-error');
            const submit = document.getElementById('force-credentials-submit');
            error?.classList.add('hidden');
            if (window._forceChangeUsername && newUsername.length < 3) {
                error.textContent = 'El nuevo usuario debe tener al menos 3 caracteres.';
                error.classList.remove('hidden');
                return;
            }
            if (window._forceChangePassword && (newPassword.length < 8 || newPassword !== confirmPassword)) {
                error.textContent = newPassword !== confirmPassword
                    ? 'Las contraseñas no coinciden.'
                    : 'La contraseña debe tener al menos 8 caracteres.';
                error.classList.remove('hidden');
                return;
            }
            try {
                submit.disabled = true;
                submit.textContent = 'Guardando...';
                const response = await fetch(`${API_URL}/${encodeURIComponent(tenant)}/auth/force-change-password`, {
                    method: 'POST',
                    credentials: 'include',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ newUsername, newPassword })
                });
                const data = await response.json().catch(() => ({}));
                if (!response.ok) {
                    error.textContent = data.error || 'No se pudieron actualizar las credenciales.';
                    error.classList.remove('hidden');
                    return;
                }
                window.open(`/c/${tenant}/p/${accessKey}`, '_blank');
                const modal = document.getElementById('force-credentials-modal');
                if (modal) {
                    modal.classList.add('hidden');
                    modal.classList.remove('flex');
                }
            } catch {
                error.textContent = 'No se pudo conectar con el servicio.';
                error.classList.remove('hidden');
            } finally {
                submit.disabled = false;
                submit.textContent = 'Guardar y entrar al panel';
            }
        }
        window.guardarCredencialesDefinitivas = guardarCredencialesDefinitivas;

        async function cargarSoporteSaas() {
            try {
                const res = await fetch(`${API_URL}/saas/settings`);
                if (!res.ok) return;
                saasSupportSettings = { ...saasSupportSettings, ...(await res.json()) };
                actualizarSoporteSaasUI();
            } catch (err) {
                console.error('Error al cargar soporte SaaS', err);
            }
        }

        function actualizarSoporteSaasUI() {
            const logoUrl = normalizarAssetUrl(saasSupportSettings.logoUrl || '');
            const img = document.getElementById('landing-logo-img');
            const fallback = document.getElementById('landing-logo-fallback');
            const logoAlt = saasSupportSettings.logoAltText || 'SEDELYNK';
            
            if (logoUrl) {
                if (img) {
                    img.src = logoUrl;
                    img.alt = logoAlt;
                    img.classList.remove('hidden');
                }
                if (fallback) fallback.classList.add('hidden');
            } else {
                if (img) img.classList.add('hidden');
                if (fallback) fallback.classList.remove('hidden');
            }

            if (saasSupportSettings.primaryColor) {
                document.documentElement.style.setProperty('--color-purple', saasSupportSettings.primaryColor);
            }
            if (saasSupportSettings.secondaryColor) {
                document.documentElement.style.setProperty('--color-pink', saasSupportSettings.secondaryColor);
            }
            if (saasSupportSettings.accentColor) {
                document.documentElement.style.setProperty('--color-orange', saasSupportSettings.accentColor);
            }

            const showPrice = saasSupportSettings.showPrice !== false;
            const preciosSec = document.getElementById('precios');
            if (preciosSec) preciosSec.classList.toggle('hidden', !showPrice);
            
            const promoCard = document.getElementById('landing-promo-card');
            if (promoCard) promoCard.classList.toggle('hidden', !showPrice);
            
            document.querySelectorAll('a[href="#precios"]').forEach(el => {
                el.classList.toggle('hidden', !showPrice);
            });

            const cardPriceLi = document.getElementById('landing-card-price-text')?.closest('li');
            if (cardPriceLi) {
                cardPriceLi.classList.toggle('hidden', !showPrice);
            }

            const monthlyPrice = typeof saasSupportSettings.monthlyPrice === 'number' ? saasSupportSettings.monthlyPrice : 50;
            const priceText = `Q${monthlyPrice}`;
            
            const promoPriceEl = document.getElementById('landing-promo-price');
            if (promoPriceEl) promoPriceEl.innerText = priceText;
            
            const cardPriceTextEl = document.getElementById('landing-card-price-text');
            if (cardPriceTextEl) cardPriceTextEl.innerText = `Plan mensual de Q${monthlyPrice}`;
            
            const priceMonthlyEl = document.getElementById('landing-price-monthly');
            if (priceMonthlyEl) priceMonthlyEl.innerText = priceText;
            
            document.querySelectorAll('.landing-faq-price').forEach(el => {
                el.innerText = priceText;
            });

            const trialDays = typeof saasSupportSettings.freeTrialDays === 'number' ? saasSupportSettings.freeTrialDays : 7;
            const trialText = `PRUÉBALO GRATIS POR ${trialDays} DÍAS`;
            const daysTextSuffix = `${trialDays} DÍAS`;
            
            const trialBadgeEl = document.getElementById('landing-trial-badge');
            if (trialBadgeEl) trialBadgeEl.innerText = trialText;
            
            const promoDaysEl = document.getElementById('landing-promo-days');
            if (promoDaysEl) promoDaysEl.innerText = daysTextSuffix;
            
            const cardTrialTextEl = document.getElementById('landing-card-trial-text');
            if (cardTrialTextEl) cardTrialTextEl.innerText = `Prueba ${trialDays} días gratis`;
            
            const registerTrialDaysEl = document.getElementById('landing-register-trial-days');
            if (registerTrialDaysEl) registerTrialDaysEl.innerText = `${trialDays} días gratis`;
            
            document.querySelectorAll('.landing-faq-days').forEach(el => {
                el.innerText = `${trialDays} días`;
            });

            const heroTextEl = document.getElementById('landing-hero-text');
            if (heroTextEl) {
                heroTextEl.innerText = saasSupportSettings.landingHeroText || 'Sedelynk te permite crear un catálogo digital, recibir pedidos por carrito y vender en línea sin comisiones. WhatsApp queda disponible como opción adicional para tus clientes.';
            }

            const logoFallback = document.getElementById('landing-logo-fallback');
            if (logoFallback && saasSupportSettings.platformName) {
                const pName = saasSupportSettings.platformName.toUpperCase();
                if (pName !== 'SEDELYNK') {
                    logoFallback.innerHTML = `<span class="text-xl font-black tracking-tight text-[#0B132B] uppercase">${pName}</span>`;
                }
            }

            const faqsContainer = document.getElementById('landing-faqs-container');
            if (faqsContainer && saasSupportSettings.landingFaqs) {
                try {
                    const faqs = JSON.parse(saasSupportSettings.landingFaqs);
                    if (Array.isArray(faqs) && faqs.length > 0) {
                        faqsContainer.innerHTML = faqs.map((faq) => `
                            <div class="faq-item landing-card p-5 cursor-pointer" onclick="this.classList.toggle('active')">
                                <div class="flex justify-between items-center gap-4">
                                    <h3 class="font-extrabold text-sm md:text-base text-slate-900 uppercase">${faq.question}</h3>
                                    <span class="faq-icon text-slate-400 shrink-0 transition-transform duration-200"><i class="fa-solid fa-chevron-down"></i></span>
                                </div>
                                <p class="faq-answer text-xs md:text-sm font-semibold text-slate-500 leading-relaxed">
                                    ${faq.answer}
                                </p>
                            </div>
                        `).join('');
                    }
                } catch (e) {
                    console.error("Error parsing dynamic FAQs", e);
                }
            }
        }

        async function iniciarApp() {
            const supportButton = document.getElementById('support-floating-button');
            supportButton?.classList.remove('hidden');
            supportButton?.classList.add('flex');
            cargarSoporteSaas();
        }

        // INICIAR LOCAL
        document.body.classList.add('landing-page');
        iniciarApp();

        // Close modal on backdrop click or escape key
        document.addEventListener('DOMContentLoaded', () => {
            const modal = document.getElementById('landing-auth-modal');
            if (modal) {
                modal.addEventListener('click', (e) => {
                    if (e.target === modal) {
                        mostrarLandingStep('close');
                    }
                });
            }
            
            document.addEventListener('keydown', (e) => {
                if (e.key === 'Escape') {
                    mostrarLandingStep('close');
                }
            });
        });
    </script>

</Layout>
