        function descargarPDFCliente() {
            const nombre = document.getElementById("nombre-cliente").value.trim() || "Cliente Genérico";
            const tel = document.getElementById("tel-cliente").value.trim() || "N/A";
            const fecha = new Date();
            const nroPedido = `PED-${fecha.getFullYear()}${(fecha.getMonth()+1).toString().padStart(2, '0')}${fecha.getDate().toString().padStart(2, '0')}-${Math.floor(1000 + Math.random() * 9000)}`;

            const items = [];
            let total = 0;
            productos.forEach(prod => {
                const cant = pedido[prod.id] || 0;
                if (cant > 0) {
                    items.push({
                        nombre: prod.n,
                        precio: prod.p,
                        cantidad: cant,
                        unidad: prod.u
                    });
                    total += cant * prod.p;
                }
            });

            if (items.length === 0) {
                showToast("Agrega al menos un producto al carrito.", "error");
                return;
            }

            generarPDFDesdeDatos({ nombre, telefono: tel }, items, total, fecha, nroPedido);
        }

        function descargarPDFPedido(pedidoId) {
            const ped = adminPedidos.find(p => p._id === pedidoId);
            if (!ped) return;
            const fecha = new Date(ped.fecha);
            const nroPedido = `PED-${fecha.getFullYear()}${(fecha.getMonth()+1).toString().padStart(2, '0')}${fecha.getDate().toString().padStart(2, '0')}-${ped._id.substring(ped._id.length - 4).toUpperCase()}`;
            generarPDFDesdeDatos(ped.cliente, ped.productos, ped.total, ped.fecha, nroPedido);
