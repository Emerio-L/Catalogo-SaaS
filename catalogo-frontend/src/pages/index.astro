            doc.setFont("helvetica", "normal");
            doc.text(`Fecha: ${fechaStr}`, 145, 27);

            // Información del Cliente
            doc.setTextColor(30, 41, 59); // slate-800
            doc.setFont("helvetica", "bold");
            doc.setFontSize(12);
            doc.text("DATOS DEL CLIENTE", 15, 55);

            doc.setFont("helvetica", "normal");
            doc.setFontSize(10);
