        async function mostrarAuthStep(step) {
            document.getElementById('auth2-login-step').classList.toggle('hidden', step !== 'login');
            document.getElementById('auth2-register-step').classList.toggle('hidden', step !== 'register');
            document.getElementById('auth2-recovery-step').classList.toggle('hidden', step !== 'recovery');
            document.getElementById('auth2-reset-step').classList.toggle('hidden', step !== 'reset');
            document.getElementById('auth2-main-heading')?.classList.toggle('hidden', step === 'register');
            if (step === 'register') {
                mostrarErrorRegistro('');
                const registerForm = document.getElementById('auth2-register-form');
                const registerResult = document.getElementById('auth2-register-result');
                if (registerForm) {
                    registerForm.classList.remove('hidden');
                    registerForm.dataset.submitting = 'false';
                    registerForm.dataset.completed = 'false';
                }
                if (registerResult) {
                    registerResult.classList.add('hidden');
                    registerResult.innerHTML = '';
                }
                setTimeout(() => document.getElementById('register-business-name')?.focus(), 10);
            } else if (step === 'login') {
                document.getElementById('auth2-main-heading')?.classList.remove('hidden');
            }
        }

        async function verificarPassword(e) {
            if (e) e.preventDefault();
            const identifier = document.getElementById("auth2-identifier").value.trim();
            const passwordV2 = document.getElementById("auth2-password").value;
            const submitBtn = document.getElementById('auth2-login-submit');
            mostrarErrorLogin('');
            if (!identifier || !passwordV2) {
                mostrarErrorLogin("Ingresa tu usuario y contraseña.");
                return;
            }
            try {
                if (submitBtn) {
                    submitBtn.disabled = true;
                    submitBtn.classList.add('opacity-70', 'cursor-wait');
                    submitBtn.innerHTML = '<i class="fa-solid fa-circle-notch fa-spin"></i> Validando acceso';
                }
                const res = await fetch(`${TENANT_API_URL}/auth/login`, {
                    method: 'POST',
                    credentials: 'include',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ identifier, password: passwordV2 })
                });
                const data = await res.json().catch(() => ({}));
                if (res.ok) {
                    if (data.devSessionToken) {
                        sessionStorage.setItem(DEV_SESSION_KEY, data.devSessionToken);
                    }
                    if (data.mustChangePassword || data.mustChangeUsername) {
                        abrirCambioCredencialesObligatorio({
                            tenant: tenantSlug,
                            accessKey: data.adminAccessKey || data.user?.adminAccessKey || adminAccessKey,
                            changeUsername: data.mustChangeUsername,
                            changePassword: data.mustChangePassword
                        });
                        return;
                    }
                    actualizarIdentidadAdmin(data.user || {});
                    adminAutenticado = true;
                    sessionStorage.setItem('admin_auth', 'true');
                    registrarActividadAdmin();
                    showToast("Acceso concedido", "success");
                    
                    const realAccessKey = data.adminAccessKey || data.user?.adminAccessKey;
                    if (realAccessKey && adminAccessKey !== realAccessKey) {
                        window.location.href = `/c/${tenantSlug}/p/${realAccessKey}`;
                        return;
                    }
                    switchView('admin');
                } else {
                    const mensaje = data.error === 'Credenciales inv\u00c3\u00a1lidas'
                        ? 'Credenciales inválidas'
                        : (data.error || "Credenciales inválidas. Revisa usuario y contraseña.");
                    mostrarErrorLogin(mensaje);
                    document.getElementById("auth2-password").value = "";
                    document.getElementById("auth2-password").focus();
                }
            } catch (err) {
                mostrarErrorLogin("No se pudo conectar con el backend. Verifica que el servidor esté activo.");
            } finally {
                if (submitBtn) {
                    submitBtn.disabled = false;
                    submitBtn.classList.remove('opacity-70', 'cursor-wait');
                    submitBtn.innerHTML = '<i class="fa-solid fa-arrow-right-to-bracket"></i> Entrar al panel';
                }
            }
            return;
            const password = document.getElementById("auth-password").value;
            
            try {
                const res = await fetch(`${API_URL}/admin/auth`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ password })
                });

                if (res.ok) {
                    adminAutenticado = true;
                    sessionStorage.setItem('admin_auth', 'true');
                    cerrarAuthModal();
                    showToast("Acceso concedido", "success");
                    switchView('admin');
                } else {
                    const data = await res.json();
                    showToast(data.error || "Contraseña incorrecta", "error");
                    document.getElementById("auth-password").value = "";
                    document.getElementById("auth-password").focus();
                }
            } catch (err) {
                showToast("Error de conexión al verificar", "error");
            }
        }

        async function recuperarPassword(e) {
            if (e) e.preventDefault();
            const identifier = document.getElementById("auth2-recovery-identifier").value.trim();
            const devLinkEl = document.getElementById("auth2-dev-reset-link");
            const form = document.getElementById('auth2-recovery-form');
            const success = document.getElementById('auth2-recovery-success');
            const submit = document.getElementById('auth2-recovery-submit');
            devLinkEl.classList.add('hidden');
            try {
                submit.disabled = true;
                submit.textContent = 'Enviando enlace...';
                const res = await fetch(`${TENANT_API_URL}/auth/forgot-password`, {
                    method: 'POST',
                    credentials: 'include',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ identifier })
                });
                const data = await res.json();
                if (!res.ok) {
                    showToast(data.error || "No se pudo solicitar la recuperación.", "error");
                    return;
                }
                form?.classList.add('hidden');
                success?.classList.remove('hidden');
                if (data.devResetUrl) {
                    devLinkEl.innerHTML = `Modo desarrollo: <a class="text-primary-600 font-black underline" href="${data.devResetUrl}">${data.devResetUrl}</a>`;
                    devLinkEl.classList.remove('hidden');
                }
            } catch (err) {
                showToast("Error de conexión al recuperar", "error");
            } finally {
                submit.disabled = false;
                submit.textContent = 'Enviar enlace a tu correo';
            }
            return;
            const pin = document.getElementById("recovery-pin").value.trim();
            const newPassword = document.getElementById("recovery-new-password").value;
            const confirmPass = document.getElementById("recovery-confirm-password").value;

            if (pin.length < 6 || isNaN(pin)) {
                showToast("El PIN de seguridad debe tener 6 dígitos", "error");
                return;
            }

            if (newPassword !== confirmPass) {
                showToast("Las contraseñas nuevas no coinciden", "error");
                return;
            }

            try {
                const res = await fetch(`${API_URL}/admin/auth/recovery`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ pin, newPassword })
                });

                if (res.ok) {
                    adminAutenticado = true;
                    sessionStorage.setItem('admin_auth', 'true');
                    cerrarAuthModal();
                    showToast("Contraseña restablecida y acceso concedido", "success");
                    switchView('admin');
                } else {
                    const data = await res.json();
                    showToast(data.error || "PIN de recuperación inválido", "error");
                }
            } catch (err) {
                showToast("Error de conexión al recuperar", "error");
            }
        }

        async function recuperarPorPregunta(e) {
            if (e) e.preventDefault();
            const newPasswordV2 = document.getElementById("auth2-reset-password").value;
            const confirmPassV2 = document.getElementById("auth2-reset-confirm").value;
            if (newPasswordV2 !== confirmPassV2) {
                showToast("Las contraseñas nuevas no coinciden", "error");
                return;
            }
            if (newPasswordV2.length < 8) {
                showToast("La contraseña debe tener al menos 8 caracteres", "error");
                return;
            }
            try {
                const res = await fetch(`${TENANT_API_URL}/auth/reset-password`, {
                    method: 'POST',
                    credentials: 'include',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ token: resetToken, password: newPasswordV2 })
                });
                const data = await res.json();
                if (res.ok) {
                    showToast("Contraseña actualizada. Inicia sesión.", "success");
                    mostrarAuthStep('login');
                } else {
                    showToast(data.error || "No se pudo restablecer", "error");
                }
            } catch (err) {
                showToast("Error de conexión al restablecer", "error");
            }
            return;
            const answer = document.getElementById("recovery-question-answer").value.trim();
            const newPassword = document.getElementById("recovery-question-new-password").value;
            const confirmPass = document.getElementById("recovery-question-confirm-password").value;

            if (newPassword !== confirmPass) {
                showToast("Las contraseñas nuevas no coinciden", "error");
                return;
            }

            try {
                const res = await fetch(`${API_URL}/admin/auth/recovery-question`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ answer, newPassword })
                });

                if (res.ok) {
                    adminAutenticado = true;
                    sessionStorage.setItem('admin_auth', 'true');
                    cerrarAuthModal();
                    showToast("Contraseña restablecida y acceso concedido", "success");
                    switchView('admin');
                } else {
                    const data = await res.json();
                    showToast(data.error || "Respuesta secreta incorrecta", "error");
                }
            } catch (err) {
                showToast("Error de conexión al recuperar", "error");
            }
        }

