        async function guardarProducto(e) {
            e.preventDefault();
            
            const id = document.getElementById('admin-id').value;
            const isEdit = id && id.trim() !== "";
            
            const formData = new FormData();
            const categoriaSeleccionada = document.getElementById('admin-categoria').value;
            if (!isEdit && !categoriaSeleccionada) {
                showToast("Crea o selecciona una categoría antes de guardar el producto", "error");
                return;
            }
            formData.append('nombre', document.getElementById('admin-nombre').value);
            if (categoriaSeleccionada) formData.append('categoria', categoriaSeleccionada);
            formData.append('unidad', document.getElementById('admin-unidad').value);
            formData.append('precio', document.getElementById('admin-precio').value);
            formData.append('orden', document.getElementById('admin-orden').value);
            formData.append('activo', document.getElementById('admin-activo').checked);
            
            const fileInput = document.getElementById('admin-foto');
            if (!isEdit && !fileInput.files[0]) {
                showToast("Selecciona una imagen para el producto", "error");
                return;
            }
            if (fileInput.files[0]) {
                const fileError = validarImagenParaSubir(fileInput.files[0]);
                if (fileError) {
                    showToast(fileError, "error");
                    return;
                }
                formData.append('foto', fileInput.files[0]);
            }

            try {
                let res;
                if (isEdit) {
                    res = await fetch(`${TENANT_API_URL}/admin/products/${id}`, { method: 'PUT', credentials: 'include', body: formData });
                } else {
                    res = await fetch(`${TENANT_API_URL}/admin/products`, { method: 'POST', credentials: 'include', body: formData });
                }

                if (res.ok) {
                    const data = await res.json();
                    showToast(isEdit ? "¡Producto actualizado con éxito!" : "¡Producto añadido e indexado con éxito!", "success");
                    document.getElementById('form-producto').reset();
                    cerrarAdminForm();
                    cargarAdminProductos();
                } else {
                    const errData = await res.json().catch(() => ({}));
                    showToast(errData.error || "Error al procesar el producto", "error");
                }
            } catch (err) {
                showToast("Ocurrió un error al conectar con el servidor", "error");
            }
        }

