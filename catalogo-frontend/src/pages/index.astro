                    configuracionNegocio = { ...configuracionNegocio, ...data };
                    aplicarTema(data.tema);
                    actualizarBotonTemaActivo(data.tema);
                    if (data.theme) aplicarPaletaTenant(data.theme);
                    if (data.telefonoWhatsApp || data.whatsapp) {
                        MI_WHATSAPP = data.telefonoWhatsApp || data.whatsapp;
                    }
                    configuracionNegocio.logo = data.logo || '';
                    configuracionNegocio.logoShape = data.logoShape || 'rectangle';
                    configuracionNegocio.logoRotation = Number(data.logoRotation) || 0;
                    configuracionNegocio.account = data.account || null;
                    configuracionNegocio.orderCartEnabled = data.orderCartEnabled !== false;
                    configuracionNegocio.orderWhatsappEnabled = data.orderWhatsappEnabled !== false;
                    configuracionNegocio.addressRequirement = data.addressRequirement || 'optional';
                    configuracionNegocio.commentRequirement = data.commentRequirement || 'optional';
                    actualizarTituloCatalogoUI(data.catalogTitle);
                    actualizarInformacionCuenta(configuracionNegocio.account);
                    actualizarLogoCatalogo(configuracionNegocio.logo, configuracionNegocio.logoShape, configuracionNegocio.logoRotation);
                    actualizarCheckoutOpciones();
                    const nombreEl = document.getElementById('catalog-business-name');
                    const searchWrapper = document.getElementById('catalog-search-wrapper');
                    const categoryButtons = document.getElementById('category-buttons');
                    if (nombreEl) nombreEl.innerText = data.nombreNegocio || 'Catálogo de Productos';
                    if (searchWrapper) searchWrapper.classList.toggle('hidden', data.mostrarBuscador === false);
                    if (categoryButtons) categoryButtons.classList.toggle('hidden', data.mostrarCategorias === false);
