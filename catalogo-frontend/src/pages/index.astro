        /* ===========================
        ENVIO POR WHATSAPP
        =========================== */
        function normalizarMensajeWhatsapp(message) {
            return String(message || '').replace(/%0A/g, '\n');
        }

        async function copiarMensajeWhatsapp(message) {
            try {
                if (navigator.clipboard?.writeText) {
                    await navigator.clipboard.writeText(normalizarMensajeWhatsapp(message));
                }
            } catch (err) {
                console.warn("No se pudo copiar el pedido al portapapeles", err);
            }
        }

        function crearWhatsappUrls(phone, message) {
            const cleanPhone = String(phone || '').replace(/\D/g, '');
            const plainMessage = normalizarMensajeWhatsapp(message);
            const encodedMessage = encodeURIComponent(plainMessage);
            const userAgent = navigator.userAgent || '';
            const isMobile = /Android|iPhone|iPad|iPod|IEMobile|Opera Mini/i.test(userAgent);
            const chromeMatch = userAgent.match(/(?:Chrome|CriOS)\/(\d+)/i);
            const isEdge = /Edg\/\d+/i.test(userAgent);
            const isEmbeddedBrowser = /Electron|Codex|wv|WebView/i.test(userAgent);
            const apiUrl = `https://api.whatsapp.com/send?phone=${cleanPhone}&text=${encodedMessage}`;
            if (!isMobile && (isEdge || isEmbeddedBrowser)) {
                return {
                    primary: `whatsapp://send?phone=${cleanPhone}&text=${encodedMessage}`,
                    fallback: apiUrl
                };
            }

            const isSupportedDesktopBrowser = !isMobile && (
                (!isEdge && chromeMatch && parseInt(chromeMatch[1], 10) >= 85) ||
                /Firefox\/\d+|Safari\/\d+/i.test(userAgent)
            );
            const baseUrl = isSupportedDesktopBrowser && !isEmbeddedBrowser
                ? 'https://web.whatsapp.com/send'
                : 'https://api.whatsapp.com/send';
            return {
                primary: `${baseUrl}?phone=${cleanPhone}&text=${encodedMessage}`,
                fallback: null
            };
        }

        function abrirWhatsapp(preopenedWindow, phone, message) {
            const urls = crearWhatsappUrls(phone, message);
            const target = preopenedWindow || window;
            target.location.href = urls.primary;
            if (urls.fallback) {
                setTimeout(() => {
                    try {
                        if (!preopenedWindow || !preopenedWindow.closed) {
                            target.location.href = urls.fallback;
                        }
                    } catch (err) {
                        window.location.href = urls.fallback;
                    }
                }, 1600);
            }
        }

        async function enviarOrden(options = {}) {
            const useWhatsapp = options.whatsapp !== false;
            if (useWhatsapp && configuracionNegocio.orderWhatsappEnabled === false) {
                showToast("La opción de WhatsApp no está disponible en este catálogo.", "error");
                return;
            }
            if (!useWhatsapp && configuracionNegocio.orderCartEnabled === false) {
                showToast("La opción de carrito no está disponible en este catálogo.", "error");
                return;
            }
            const nombre = document.getElementById("nombre-cliente").value.trim();
            const tel = document.getElementById("tel-cliente").value.trim();
            const direccion = document.getElementById("direccion-cliente")?.value.trim() || "";
            const comentario = document.getElementById("comentario-cliente")?.value.trim() || "";
            
            if (!validarCheckoutCliente({ nombre, tel, direccion, comentario })) {
                return;
            }
            if ((configuracionNegocio.addressRequirement || 'optional') === 'required' && !direccion) {
                showToast("Por favor, agrega la dirección de entrega.", "error");
                return;
            }
            if ((configuracionNegocio.commentRequirement || 'optional') === 'required' && !comentario) {
                showToast("Por favor, agrega el comentario del pedido.", "error");
                return;
            }

            const preopenedWindow = useWhatsapp ? window.open('about:blank', '_blank') : null;

            // Deshabilitar botón temporalmente para evitar doble envío
            const btnCarrito = document.querySelector("#modal-validacion button[onclick*='whatsapp: false']");
            const btnWhatsapp = document.querySelector("#modal-validacion button[onclick*='whatsapp: true']");
            const originalCarritoText = btnCarrito?.innerHTML || "";
            const originalWhatsappText = btnWhatsapp?.innerHTML || "";

            if (btnCarrito) btnCarrito.disabled = true;
            if (btnWhatsapp) btnWhatsapp.disabled = true;

            if (useWhatsapp && btnWhatsapp) {
                btnWhatsapp.innerHTML = `<i class="fa-solid fa-spinner fa-spin mr-2"></i> Procesando...`;
            } else if (!useWhatsapp && btnCarrito) {
                btnCarrito.innerHTML = `<i class="fa-solid fa-spinner fa-spin mr-2"></i> Procesando...`;
            }

            // No se guardan datos de contacto en localStorage para preservar la privacidad y limpieza

            // Estructurar ítems para guardar
            const items = [];
            let total = 0;
            let msg = `*NUEVA ORDEN DE PEDIDO*%0A`;
            msg += `---------------------------%0A`;
            msg += `*Cliente:* ${nombre}%0A`;
            if (direccion) msg += `*Dirección:* ${direccion}%0A`;
            if (comentario) msg += `*Comentario:* ${comentario}%0A`;
            msg += `*Teléfono:* ${tel}%0A`;
            msg += `---------------------------%0A%0A`;

            productos.forEach(p => {
                if (pedido[p.id] > 0) {
                    const sub = p.p * pedido[p.id];
                    msg += `• *${p.n}* (${pedido[p.id]} ${p.u}) -> _Q${sub.toFixed(2)}_%0A`;
                    items.push({
                        productId: p.id,
                        nombre: p.n,
                        precio: p.p,
                        cantidad: pedido[p.id],
                        unidad: p.u
                    });
                    total += sub;
                }
            });

            msg += `%0A---------------------------%0A`;
            msg += `*TOTAL DE LA ORDEN: Q${total.toFixed(2)}*%0A`;
            msg += `---------------------------%0A`;
            msg += `_¡Muchas gracias por su preferencia!_`;

            copiarMensajeWhatsapp(msg);

            try {
                // Registrar pedido en la base de datos de PostgreSQL
                const res = await fetch(`${TENANT_API_URL}/orders`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        cliente: { nombre, telefono: tel, direccion, comentario },
                        productos: items,
                        total: total,
                        channel: useWhatsapp ? 'whatsapp' : 'cart'
                    })
                });

                if (!res.ok) throw new Error('Error al registrar pedido');

                if (useWhatsapp) {
                    abrirWhatsapp(preopenedWindow, MI_WHATSAPP, msg);
                    showToast("¡Pedido registrado! Redirigiendo a WhatsApp...", "success");
                    document.getElementById("checkout-success-msg").innerText = "Tu pedido fue registrado en nuestro sistema. Te estamos redirigiendo a WhatsApp para completar el envío.";
                } else {
                    showToast("¡Pedido enviado correctamente al sistema!", "success");
                    document.getElementById("checkout-success-msg").innerText = "Tu pedido ha sido enviado y registrado con éxito en nuestro sistema.";
                }
                
                // Limpiar pedido local, campos de contacto y refrescar
                pedido = {};
                dibujar();
                recalcular();
                const inputNombre = document.getElementById("nombre-cliente");
                const inputTel = document.getElementById("tel-cliente");
                const inputDireccion = document.getElementById("direccion-cliente");
                const inputComentario = document.getElementById("comentario-cliente");
                if (inputNombre) inputNombre.value = "";
                if (inputTel) inputTel.value = "";
                if (inputDireccion) inputDireccion.value = "";
                if (inputComentario) inputComentario.value = "";

                // Mostrar pantalla de éxito
                document.getElementById("checkout-step-1").classList.add("hidden");
                document.getElementById("checkout-step-success").classList.remove("hidden");
            } catch (err) {
                console.error(err);
                if (useWhatsapp) {
                    showToast("Error al guardar pedido. Redirigiendo a WhatsApp...", "warning");
                    abrirWhatsapp(preopenedWindow, MI_WHATSAPP, msg);
                    document.getElementById("checkout-success-msg").innerText = "Te estamos redirigiendo a WhatsApp para procesar tu pedido.";
                    pedido = {};
                    dibujar();
                    recalcular();
                    const inputNombre = document.getElementById("nombre-cliente");
                    const inputTel = document.getElementById("tel-cliente");
                    const inputDireccion = document.getElementById("direccion-cliente");
                    const inputComentario = document.getElementById("comentario-cliente");
                    if (inputNombre) inputNombre.value = "";
                    if (inputTel) inputTel.value = "";
                    if (inputDireccion) inputDireccion.value = "";
                    if (inputComentario) inputComentario.value = "";
                    document.getElementById("checkout-step-1").classList.add("hidden");
                    document.getElementById("checkout-step-success").classList.remove("hidden");
                } else {
                    showToast("Error al enviar el pedido. Intenta nuevamente.", "error");
                }
            } finally {
                if (btnCarrito) {
                    btnCarrito.disabled = false;
                    btnCarrito.innerHTML = originalCarritoText;
                }
                if (btnWhatsapp) {
                    btnWhatsapp.disabled = false;
                    btnWhatsapp.innerHTML = originalWhatsappText;
                }
            }
        }

        function switchAdminTab(tab) {
            tabAdminActual = tab;
            const tabs = ['inventario', 'pedidos', 'perfil', 'config'];
            tabs.forEach(tabKey => {
                const section = document.getElementById(`admin-seccion-${tabKey}`);
                document.querySelectorAll(`[data-admin-tab="${tabKey}"]`).forEach(btn => {
                    const baseClass = btn.dataset.navBase || 'admin-nav-item w-full';
                    btn.className = tabKey === tab ? `${baseClass} admin-nav-active` : baseClass;
                });
                if (section) section.classList.add('hidden');
            });

            const seccionInventario = document.getElementById('admin-seccion-inventario');
            const seccionPedidos = document.getElementById('admin-seccion-pedidos');
            const seccionPerfil = document.getElementById('admin-seccion-perfil');
            const seccionConfig = document.getElementById('admin-seccion-config');

            if (tab === 'inventario') {
                seccionInventario.classList.remove('hidden');
                cargarAdminProductos();
            } else if (tab === 'pedidos') {
                seccionPedidos.classList.remove('hidden');
                cargarAdminPedidos();
            } else if (tab === 'perfil') {
                seccionPerfil.classList.remove('hidden');
                cargarConfigSeguridad();
            } else if (tab === 'config') {
                seccionConfig.classList.remove('hidden');
                cargarAjustesCatalogo();
            }
        }

        async function cargarAdminPedidos() {
            try {
                const response = await fetch(`${TENANT_API_URL}/admin/orders`, { credentials: 'include' });
                if (!response.ok) throw new Error('Error al obtener pedidos');
                adminPedidos = await response.json();
                actualizarMetricasPedidos();
                dibujarPedidos();
            } catch (err) {
                console.error(err);
                showToast("Error al cargar el historial de pedidos", "error");
            }
        }

        function obtenerPedidosFiltrados() {
            const busqueda = document.getElementById("pedidos-buscar").value.trim().toLowerCase();
            if (busqueda === "") return adminPedidos;

            return adminPedidos.filter(p => {
                const clienteNombre = p.cliente?.nombre || "";
                const clienteTelefono = p.cliente?.telefono || "";
                return (
                    clienteNombre.toLowerCase().includes(busqueda) ||
                    clienteTelefono.toLowerCase().includes(busqueda) ||
                    (p._id && p._id.toLowerCase().includes(busqueda))
                );
            });
        }

        function inicioDelDia(fecha) {
            const d = new Date(fecha);
            d.setHours(0, 0, 0, 0);
            return d;
        }

        function inicioDeSemana(fecha = new Date()) {
            const d = inicioDelDia(fecha);
            const dia = d.getDay() || 7;
            d.setDate(d.getDate() - dia + 1);
            return d;
        }

        function obtenerPedidosParaAgrupar() {
            const modo = document.getElementById('pedidos-agrupar-modo')?.value || 'selected';
            const visibles = obtenerPedidosFiltrados();
            const ahora = new Date();
            const hoy = inicioDelDia(ahora);
            const manana = new Date(hoy);
            manana.setDate(manana.getDate() + 1);
            const semana = inicioDeSemana(ahora);
            const mes = new Date(ahora.getFullYear(), ahora.getMonth(), 1);

            if (modo === 'today') {
                return visibles.filter(p => {
                    const fecha = new Date(p.fecha);
                    return fecha >= hoy && fecha < manana;
                });
            }
            if (modo === 'week') {
                return visibles.filter(p => new Date(p.fecha) >= semana);
            }
            if (modo === 'month') {
                return visibles.filter(p => new Date(p.fecha) >= mes);
            }

            return visibles.filter(p => pedidosSeleccionados.has(String(p._id)));
        }

        function colorPedidoPorDia(fechaPedido) {
            const colores = [
                'bg-emerald-100 border-l-8 border-emerald-600',
                'bg-sky-100 border-l-8 border-sky-600',
                'bg-violet-100 border-l-8 border-violet-600',
                'bg-amber-100 border-l-8 border-amber-600',
                'bg-rose-100 border-l-8 border-rose-600',
                'bg-cyan-100 border-l-8 border-cyan-600',
                'bg-lime-100 border-l-8 border-lime-600'
            ];
            const hoy = inicioDelDia(new Date());
            const fecha = inicioDelDia(fechaPedido);
            const diff = Math.floor((hoy - fecha) / (24 * 60 * 60 * 1000));
            return colores[Math.abs(diff) % colores.length];
        }

        function etiquetaPedidoPorDia(fechaPedido) {
            const hoy = inicioDelDia(new Date());
            const fecha = inicioDelDia(fechaPedido);
            const diff = Math.floor((hoy - fecha) / (24 * 60 * 60 * 1000));
            if (diff === 0) return 'Hoy';
            if (diff === 1) return 'Ayer';
            if (diff > 1 && diff < 7) return `Hace ${diff} dias`;
            return fecha.toLocaleDateString();
        }

        function actualizarSeleccionPedidosUI(listaVisible = obtenerPedidosFiltrados()) {
            const countEl = document.getElementById('pedidos-seleccionados-count');
            const selectAll = document.getElementById('pedidos-select-all');
            const visiblesIds = listaVisible.map(p => String(p._id));
            const seleccionadosVisibles = visiblesIds.filter(id => pedidosSeleccionados.has(id)).length;
            if (countEl) countEl.innerText = `${pedidosSeleccionados.size} pedido${pedidosSeleccionados.size === 1 ? '' : 's'} seleccionado${pedidosSeleccionados.size === 1 ? '' : 's'}`;
            if (selectAll) {
                selectAll.checked = visiblesIds.length > 0 && seleccionadosVisibles === visiblesIds.length;
                selectAll.indeterminate = seleccionadosVisibles > 0 && seleccionadosVisibles < visiblesIds.length;
            }
        }

        function toggleSeleccionPedido(id, checked) {
            const pedidoId = String(id);
            if (checked) {
                pedidosSeleccionados.add(pedidoId);
            } else {
                pedidosSeleccionados.delete(pedidoId);
            }
            actualizarSeleccionPedidosUI();
        }

        function toggleSeleccionPedidosVisibles(checked) {
            obtenerPedidosFiltrados().forEach(p => {
                const id = String(p._id);
                if (checked) {
                    pedidosSeleccionados.add(id);
                } else {
                    pedidosSeleccionados.delete(id);
                }
            });
            dibujarPedidos();
        }

        function detalleClientePedido(cliente = {}) {
            const partes = [];
            if (cliente.direccion) partes.push(`<div class="text-[9px] text-slate-500">Dir: ${cliente.direccion}</div>`);
            if (cliente.comentario) partes.push(`<div class="text-[9px] text-slate-500">Nota: ${cliente.comentario}</div>`);
            if (cliente.channel) partes.push(`<div class="mt-1 inline-flex rounded-full bg-white/80 px-2 py-0.5 text-[8px] font-black uppercase tracking-wider text-slate-500 ring-1 ring-slate-200">${cliente.channel === 'whatsapp' ? 'WhatsApp' : 'Carrito'}</div>`);
