        async function guardarLogoShapeCatalogo(options = {}) {
            const logoShape = document.getElementById('perfil-logo-shape')?.value === 'circle' ? 'circle' : 'rectangle';
            const requestedRotation = Number(document.getElementById('perfil-logo-rotation')?.value);
            const logoRotation = [0, 90, 180, 270].includes(requestedRotation) ? requestedRotation : 0;
            try {
                const res = await fetch(`${TENANT_API_URL}/admin/settings`, {
                    method: 'PUT',
                    credentials: 'include',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ logoShape, logoRotation })
                });
                if (!res.ok) {
                    if (!options.silent) showToast("Error al guardar forma del logo", "error");
                    return false;
                }
                configuracionNegocio.logoShape = logoShape;
                configuracionNegocio.logoRotation = logoRotation;
                actualizarLogoCatalogo(configuracionNegocio.logo, logoShape, logoRotation);
                if (!options.silent) showToast("Forma del logo actualizada", "success");
                return true;
            } catch (err) {
                if (!options.silent) showToast("Error de conexión al guardar forma", "error");
                return false;
            }
        }

