        function asignarArchivoImagen(file) {
            if (!file) return false;
            if (!file.type || !file.type.startsWith('image/')) {
                showToast("Selecciona un archivo de imagen válido", "error");
                return false;
            }
            const input = document.getElementById('admin-foto');
            const label = document.getElementById('admin-foto-label');
            const dataTransfer = new DataTransfer();
            dataTransfer.items.add(file);
            input.files = dataTransfer.files;
            if (label) label.innerText = file.name;
            const reader = new FileReader();
            reader.onload = function(e) {
                const preview = document.getElementById('admin-foto-preview');
                const placeholder = document.getElementById('admin-foto-placeholder');
                preview.src = e.target.result;
                preview.classList.remove('hidden');
                if (placeholder) placeholder.classList.add('hidden');
            };
            reader.readAsDataURL(file);
            return true;
        }

