        function actualizarCheckoutOpciones() {
            const cartEnabled = configuracionNegocio.orderCartEnabled !== false;
            const whatsappEnabled = configuracionNegocio.orderWhatsappEnabled !== false;
            const addressRequirement = configuracionNegocio.addressRequirement || 'optional';
            const commentRequirement = configuracionNegocio.commentRequirement || 'optional';
            const cartBtn = document.getElementById('checkout-cart-btn');
            const whatsappBtn = document.getElementById('checkout-whatsapp-btn');
            const actions = document.getElementById('checkout-actions');
            const separator = document.getElementById('checkout-or-separator');
            const addressWrapper = document.getElementById('checkout-address-wrapper');
            const commentWrapper = document.getElementById('checkout-comment-wrapper');
            const addressInput = document.getElementById('direccion-cliente');
            const commentInput = document.getElementById('comentario-cliente');

            if (cartBtn) {
                cartBtn.classList.toggle('hidden', !cartEnabled);
                cartBtn.style.display = cartEnabled ? '' : 'none';
            }
            if (whatsappBtn) {
                whatsappBtn.classList.toggle('hidden', !whatsappEnabled);
                whatsappBtn.style.display = whatsappEnabled ? '' : 'none';
            }
            if (separator) {
                separator.classList.toggle('hidden', !(cartEnabled && whatsappEnabled));
                separator.style.display = cartEnabled && whatsappEnabled ? '' : 'none';
            }
            if (actions) {
                actions.className = cartEnabled && whatsappEnabled
                    ? 'grid gap-3 md:grid-cols-[1fr_1.45fr_auto_1.45fr] md:items-center md:gap-4'
                    : 'grid gap-3 md:grid-cols-[1fr_1.8fr] md:items-center md:gap-4';
            }
            if (addressWrapper) addressWrapper.classList.toggle('hidden', addressRequirement === 'disabled');
            if (commentWrapper) commentWrapper.classList.toggle('hidden', commentRequirement === 'disabled');
            if (addressInput) {
                addressInput.required = addressRequirement === 'required';
                addressInput.placeholder = addressRequirement === 'required' ? 'Dirección de entrega (obligatoria)' : 'Dirección de entrega';
            }
            if (commentInput) {
                commentInput.required = commentRequirement === 'required';
                commentInput.placeholder = commentRequirement === 'required' ? 'Comentario del pedido (obligatorio)' : 'Comentario del pedido';
            }
        }

        function posicionarCheckoutDefault() {
            const modal = document.getElementById("modal-validacion");
            const panel = document.getElementById("checkout-panel");
            if (!modal || !panel) return;

            modal.classList.add('checkout-open');
            modal.style.display = 'flex';
            modal.style.alignItems = window.innerWidth >= 768 ? 'center' : 'flex-end';
            modal.style.justifyContent = window.innerWidth >= 768 ? 'flex-end' : 'center';
            modal.style.padding = window.innerWidth >= 768 ? '24px' : '0';
            modal.style.gap = '0';

            panel.dataset.dragX = '0';
            panel.dataset.dragY = '0';
            panel.style.transform = 'translate(0px, 0px)';
            panel.classList.remove('translate-y-4', 'scale-95');
            panel.style.maxHeight = window.innerWidth >= 768 ? 'calc(100vh - 48px)' : '92vh';
            panel.style.marginLeft = window.innerWidth >= 768 ? 'auto' : '0';
            panel.style.marginRight = window.innerWidth >= 768 ? '0' : '0';
            panel.style.width = window.innerWidth >= 768 ? 'min(760px, calc(100vw - 48px))' : '100%';
            const productsList = document.getElementById('checkout-resumen-productos');
            if (productsList) {
                productsList.style.maxHeight = window.innerWidth >= 768 ? '230px' : '30vh';
            }

        }

        async function abrirValidacion() {
            if (!Object.values(pedido).some(v => v > 0)) {
                showToast("Agrega al menos un producto al carrito.", "error");
                return;
            }
            await cargarConfiguracionPublica();
            asegurarCheckoutProfesional();
            if (configuracionNegocio.orderCartEnabled === false && configuracionNegocio.orderWhatsappEnabled === false) {
                showToast("Este catálogo no tiene métodos de pedido activos.", "error");
                return;
            }
            
            // Limpiar datos de contacto para que aparezcan vacíos
            const inputNombre = document.getElementById("nombre-cliente");
            const inputTel = document.getElementById("tel-cliente");
            const inputDireccion = document.getElementById("direccion-cliente");
            const inputComentario = document.getElementById("comentario-cliente");
            if (inputNombre) inputNombre.value = "";
            if (inputTel) inputTel.value = "";
            if (inputDireccion) inputDireccion.value = "";
            if (inputComentario) inputComentario.value = "";

            limpiarErroresCheckout();
            renderCheckoutResumen();
            // Generar el resumen de productos y total
            const resumenContenedor = document.getElementById("checkout-resumen-productos");
            const totalContenedor = document.getElementById("checkout-total-resumen");
            if (resumenContenedor && totalContenedor) {
                let resumenHtml = "";
                let total = 0;
                productos.forEach(p => {
                    if (pedido[p.id] > 0) {
                        const sub = p.p * pedido[p.id];
                        total += sub;
                        resumenHtml += `
                            <div class="flex justify-between items-center text-xs font-bold text-slate-600 py-1 border-b border-slate-100 last:border-b-0">
                                <div class="truncate pr-2">
                                    <span class="font-extrabold text-slate-800">${pedido[p.id]}x</span> ${p.n}
                                </div>
                                <div class="font-black text-slate-900 shrink-0">Q${sub.toFixed(2)}</div>
                            </div>
                        `;
                    }
                });
                resumenContenedor.innerHTML = resumenHtml;
                totalContenedor.innerText = `Q${total.toFixed(2)}`;
            }

            renderCheckoutResumen();
            // Mostrar el paso 1
            actualizarCheckoutOpciones();
            document.getElementById("checkout-step-1").classList.remove("hidden");

            const modal = document.getElementById("modal-validacion");
            modal.classList.remove("hidden");
            posicionarCheckoutDefault();
            setTimeout(() => {
                document.getElementById('checkout-panel')?.classList.remove('translate-y-4', 'scale-95', 'opacity-0');
            }, 10);
        }


        function renderCheckoutResumen() {
            const resumenContenedor = document.getElementById("checkout-resumen-productos");
            const totalContenedor = document.getElementById("checkout-total-resumen");
            const subtotalContenedor = document.getElementById("checkout-subtotal-resumen");
            const totalHeader = document.getElementById("checkout-total-header");
            const countEl = document.getElementById("checkout-item-count");
            const { items, cantidad, subtotal, total } = obtenerTotalesPedido();
            const totalText = `Q${total.toFixed(2)}`;
            if (resumenContenedor) {
                resumenContenedor.innerHTML = items.map(item => `
                    <div class="grid min-h-[70px] grid-cols-[52px_1fr_auto] items-center gap-3 border-b border-[#E2E8F0] px-3 py-2 last:border-b-0 md:grid-cols-[58px_1fr_132px_88px_36px] md:px-0">
                        <img src="${item.img}" alt="${item.n}" class="h-12 w-12 rounded-xl border border-[#E2E8F0] object-cover md:ml-2" onerror="this.src='https://via.placeholder.com/120?text=${encodeURIComponent(item.n)}'">
                        <div class="min-w-0">
                            <p class="truncate text-sm font-black text-[#0F172A]">${item.n}</p>
                            <p class="mt-1 text-xs font-bold text-[#64748B]">Q${item.p.toFixed(2)} / ${item.u}</p>
                        </div>
                        <div class="col-span-2 ml-[64px] inline-flex h-9 w-fit items-center rounded-2xl md:col-span-1 md:ml-0 md:justify-self-center">
                            <button onclick="updateCheckoutItem('${item.id}', -1)" class="flex h-8 w-8 items-center justify-center rounded-xl border border-[#E2E8F0] bg-white text-[#64748B] hover:text-[#0F172A]" aria-label="Restar"><i class="fa-solid fa-minus text-[10px]"></i></button>
                            <span class="w-10 text-center text-sm font-black text-[#0F172A]">${item.cantidad}</span>
                            <button onclick="updateCheckoutItem('${item.id}', 1)" class="flex h-8 w-8 items-center justify-center rounded-xl border border-[#E2E8F0] bg-white text-[#64748B] hover:text-[#0F172A]" aria-label="Sumar"><i class="fa-solid fa-plus text-[10px]"></i></button>
                        </div>
                        <p class="hidden text-right text-sm font-black text-[#0F172A] md:block">Q${item.subtotal.toFixed(2)}</p>
                        <button onclick="removeCheckoutItem('${item.id}')" class="hidden h-8 w-8 items-center justify-center rounded-xl bg-[#F8FAFC] text-[#64748B] hover:text-[#EF4444] md:flex" aria-label="Eliminar"><i class="fa-solid fa-trash-can text-xs"></i></button>
                    </div>
                `).join('');
            }
            if (totalContenedor) totalContenedor.innerText = totalText;
            if (subtotalContenedor) subtotalContenedor.innerText = `Q${subtotal.toFixed(2)}`;
            if (totalHeader) totalHeader.innerText = totalText;
            if (countEl) countEl.innerText = textoArticulos(cantidad);
        }

        function updateCheckoutItem(id, delta) {
            update(id, delta);
            if (!Object.values(pedido).some(v => v > 0)) {
                cerrarValidacion();
                return;
            }
            renderCheckoutResumen();
        }
        window.updateCheckoutItem = updateCheckoutItem;

        function removeCheckoutItem(id) {
            pedido[id] = 0;
            update(id, 0);
            if (!Object.values(pedido).some(v => v > 0)) {
                cerrarValidacion();
                return;
            }
            renderCheckoutResumen();
        }
        window.removeCheckoutItem = removeCheckoutItem;

        function setCheckoutError(inputId, errorId, visible) {
            const input = document.getElementById(inputId);
            const error = document.getElementById(errorId);
            if (input) input.classList.toggle('checkout-invalid', visible);
            if (error) error.classList.toggle('hidden', !visible);
        }

        function limpiarErroresCheckout() {
            setCheckoutError('nombre-cliente', 'nombre-cliente-error', false);
            setCheckoutError('tel-cliente', 'tel-cliente-error', false);
            setCheckoutError('direccion-cliente', 'direccion-cliente-error', false);
            setCheckoutError('comentario-cliente', 'comentario-cliente-error', false);
        }

        function validarCheckoutCliente({ nombre, tel, direccion, comentario }) {
            limpiarErroresCheckout();
            const telValido = String(tel || '').replace(/\D/g, '').length >= 8;
            const errores = {
                nombre: !nombre,
                tel: !telValido,
                direccion: (configuracionNegocio.addressRequirement || 'optional') === 'required' && !direccion,
                comentario: (configuracionNegocio.commentRequirement || 'optional') === 'required' && !comentario
            };
            setCheckoutError('nombre-cliente', 'nombre-cliente-error', errores.nombre);
            setCheckoutError('tel-cliente', 'tel-cliente-error', errores.tel);
            setCheckoutError('direccion-cliente', 'direccion-cliente-error', errores.direccion);
            setCheckoutError('comentario-cliente', 'comentario-cliente-error', errores.comentario);
