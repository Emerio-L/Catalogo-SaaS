            Object.entries(tabs).forEach(([key, el]) => {
                if (!el) return;
                el.className = `palette-tab rounded-2xl border px-4 py-2.5 text-xs font-black uppercase tracking-wider transition ${tabPaletaClass(paletteTabActiva === key)}`;
            });
        }

        function renderColorActualHTML(theme) {
            const selected = theme.selectedColor || theme.colors.primary;
            return `<h4 class="text-lg font-black text-slate-950">Elige tu color principal</h4>
                <p class="mt-1 max-w-2xl text-sm font-semibold text-slate-500">Selecciona un color y se aplicará automáticamente en todo tu catálogo y panel.</p>
                <div class="mt-6 flex flex-wrap gap-3">
                    ${PREDEFINED_COLOR_OPTIONS.map(([label, color]) => {
                        const active = selected.toUpperCase() === color.toUpperCase();
                        const textColor = colorTextoSobre(color);
                        return `<button type="button" onclick="seleccionarColorPredefinido('${color}', '${label.replace(/'/g, "\\'")}')" title="${label}" class="flex h-10 w-10 items-center justify-center rounded-full border-[3px] transition hover:scale-105 ${active ? 'border-slate-950 shadow-lg' : 'border-white shadow-sm ring-1 ring-slate-200'}" style="background:${color}; color:${textColor}">
                            ${active ? '<i class="fa-solid fa-check text-xs"></i>' : ''}
                        </button>`;
                    }).join('')}
                </div>`;
        }

        function renderPersonalizaHTML(theme) {
            const color = theme.selectedColor || theme.colors.primary;
            const picker = document.getElementById('custom-main-color');
            if (picker) picker.value = color;
            return `<h4 class="text-lg font-black text-slate-950">Color personalizado</h4>
                <p class="mt-1 max-w-2xl text-sm font-semibold text-slate-500">Elige un color principal. El sistema calculará automáticamente variaciones para hover, acento y estados secundarios.</p>
                <button type="button" onclick="document.getElementById('custom-main-color')?.click()" class="mt-6 inline-flex items-center gap-4 rounded-[1.5rem] border border-slate-200 bg-white p-4 text-left shadow-sm transition hover:-translate-y-0.5 hover:shadow-premium">
                    <span class="flex h-16 w-16 items-center justify-center rounded-full shadow-lg" style="background:${color}; color:${colorTextoSobre(color)}"><i class="fa-solid fa-eye-dropper"></i></span>
                    <span>
                        <span class="block text-sm font-black text-slate-900">Color personalizado</span>
                        <span class="text-xs font-semibold text-slate-500">${color.toUpperCase()}</span>
                    </span>
                </button>`;
        }

        function renderNegociosHTML(theme) {
            const activeCategory = theme.businessCategory || '';
            return `<h4 class="text-lg font-black text-slate-950">Selecciona tu tipo de negocio</h4>
                <p class="mt-1 max-w-2xl text-sm font-semibold text-slate-500">Aplica una paleta recomendada según el tipo de catálogo.</p>
                <div class="mt-5 grid grid-cols-1 gap-2 md:grid-cols-2">
                    ${BUSINESS_PALETTES.map((item, index) => {
                        const active = activeCategory === item.name;
                        const color = completarColores(item.colors).primary;
                        return `<button type="button" onclick="seleccionarPaletaNegocio(${index})" class="flex items-center justify-between gap-3 rounded-2xl border p-3 text-left transition ${active ? 'border-blue-500 bg-blue-50' : 'border-slate-200 bg-white hover:border-slate-300'}">
                            <span class="flex min-w-0 items-center gap-3">
                                <span class="flex h-9 w-9 shrink-0 items-center justify-center rounded-xl bg-slate-100 text-slate-600"><i class="fa-solid ${item.icon} text-sm"></i></span>
                                <span class="truncate text-sm font-black text-slate-800">${item.name}</span>
                            </span>
                            <span class="flex shrink-0 items-center gap-2">
                                <span class="h-5 w-5 rounded-full border border-white shadow-sm ring-1 ring-slate-200" style="background:${color}"></span>
                                ${active ? '<i class="fa-solid fa-check text-blue-600"></i>' : ''}
                            </span>
                        </button>`;
                    }).join('')}
                </div>`;
        }

        function renderPaletaColores() {
            if (!paletteDraft) paletteDraft = normalizarTenantTheme(configuracionNegocio.theme);
            const content = document.getElementById('palette-tab-content');
            const saveBtn = document.getElementById('palette-save-btn');
            const theme = normalizarTenantTheme(paletteDraft);
            const primary = theme.selectedColor || theme.colors.primary;

            renderTabsPaleta();
            if (content) {
                if (paletteTabActiva === 'custom') content.innerHTML = renderPersonalizaHTML(theme);
                else if (paletteTabActiva === 'business') content.innerHTML = renderNegociosHTML(theme);
                else content.innerHTML = renderColorActualHTML(theme);
            }
            if (saveBtn) {
                saveBtn.style.background = primary;
                saveBtn.style.color = colorTextoSobre(primary);
            }
        }

        async function guardarThemeTenant(theme) {
            const normalized = normalizarTenantTheme(theme);
            const res = await fetch(`${TENANT_API_URL}/admin/settings`, {
                method: 'PUT',
                credentials: 'include',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ theme: normalized })
            });
            if (!res.ok) throw new Error('No se pudo guardar la paleta');
            configuracionNegocio.theme = normalized;
            paletteDraft = normalized;
            aplicarPaletaTenant(normalized);
            renderPaletaColores();
            actualizarPreviewCatalogo();
        }

        async function guardarPaletaSeleccionada() {
            try {
                await guardarThemeTenant(paletteDraft || configuracionNegocio.theme || DEFAULT_TENANT_THEME);
                cerrarModalCambiosColor();
                showToast("Paleta de colores guardada", "success");
            } catch (err) {
                showToast("Error al guardar la paleta", "error");
            }
        }

        async function crearCategoriaAdmin(e) {
            if (e) e.preventDefault();
            const input = document.getElementById('nueva-categoria-nombre');
            const nombre = input?.value.trim();
            if (!nombre) {
                showToast("Escribe el nombre de la categoría", "error");
                return;
            }
            if (categorias.some(cat => String(cat.nombre).trim().toLocaleLowerCase() === nombre.toLocaleLowerCase())) {
                showToast("La categoría ya existe", "error");
                return;
            }
            try {
                const res = await fetch(`${TENANT_API_URL}/admin/categories`, {
                    method: 'POST',
                    credentials: 'include',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ nombre, orden: categorias.length + 1 })
                });
                const data = await res.json();
                if (!res.ok) {
                    showToast(res.status === 409 ? "La categoría ya existe" : (data.error || "Error al crear categoría"), "error");
                    return;
                }
                if (input) input.value = '';
                showToast("Categoría creada", "success");
                await cargarCategorias();
            } catch (err) {
                showToast("Error de conexión al crear categoría", "error");
            }
        }

        let categoriaAccionActual = { tipo: 'crear', id: null };

        function abrirModalCategoria(tipo, id = null, nombreActual = '') {
            categoriaAccionActual = { tipo, id };
            const modal = document.getElementById('modal-admin-categoria');
            const input = document.getElementById('admin-categoria-nombre-input');
            const titulo = document.getElementById('admin-categoria-modal-titulo');
            
            titulo.innerText = tipo === 'crear' ? 'Nueva Categoría' : 'Editar Categoría';
            input.value = nombreActual;
            
            modal.classList.remove('hidden');
            setTimeout(() => {
                modal.firstElementChild.classList.remove('scale-95', 'opacity-0');
                modal.firstElementChild.classList.add('scale-100', 'opacity-100');
                input.focus();
            }, 10);
        }

        function cerrarModalCategoria() {
            const modal = document.getElementById('modal-admin-categoria');
            modal.firstElementChild.classList.remove('scale-100', 'opacity-100');
            modal.firstElementChild.classList.add('scale-95', 'opacity-0');
            setTimeout(() => modal.classList.add('hidden'), 300);
        }

        async function guardarCategoriaDesdeModal(event) {
            event.preventDefault();
            const input = document.getElementById('admin-categoria-nombre-input');
            const nombreLimpio = input.value.trim();
            if (!nombreLimpio) {
                showToast("El nombre no puede estar vacío", "error");
                return;
            }
            const categoriaDuplicada = categorias.some(cat =>
                String(cat.nombre).trim().toLocaleLowerCase() === nombreLimpio.toLocaleLowerCase()
                && String(cat._id) !== String(categoriaAccionActual.id || '')
            );
            if (categoriaDuplicada) {
                showToast("La categoría ya existe", "error");
                return;
            }

            const btnSubmit = document.getElementById('admin-categoria-submit');
            const btnText = btnSubmit.innerText;
            btnSubmit.innerText = 'Guardando...';
            btnSubmit.disabled = true;

            try {
                if (categoriaAccionActual.tipo === 'crear') {
                    const res = await fetch(`${TENANT_API_URL}/admin/categories`, {
                        method: 'POST',
                        credentials: 'include',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ nombre: nombreLimpio, orden: categorias.length + 1 })
                    });
                    const data = await res.json();
                    if (!res.ok) {
                        throw new Error(res.status === 409 ? "La categoría ya existe" : (data.error || "Error al crear categoría"));
                    }
                    
                    showToast("Categoría creada", "success");
                    await cargarCategorias();
                    const adminCategoria = document.getElementById("admin-categoria");
                    if (adminCategoria && data?._id) adminCategoria.value = data._id;
                } else {
                    const id = categoriaAccionActual.id;
                    const categoria = categorias.find(cat => cat._id === id);
                    const res = await fetch(`${TENANT_API_URL}/admin/categories/${id}`, {
                        method: 'PUT',
                        credentials: 'include',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ nombre: nombreLimpio, orden: categoria?.orden || 999 })
                    });
                    const data = await res.json();
                    if (!res.ok) throw new Error(data.error || "Error al editar categoría");

                    showToast("Categoría actualizada", "success");
                    await cargarCategorias();
                    await cargarAdminProductos();
                }
                cerrarModalCategoria();
            } catch (err) {
                showToast(err.message || "Error de conexión", "error");
            } finally {
                btnSubmit.innerText = btnText;
                btnSubmit.disabled = false;
            }
        }

        function crearCategoriaDesdeFormulario() {
            abrirModalCategoria('crear');
        }

        function editarCategoriaAdmin(id, nombreActual) {
            abrirModalCategoria('editar', id, nombreActual);
        }

        async function eliminarCategoriaAdmin(id) {
            if (!confirm("¿Eliminar esta categoría? Solo se puede eliminar si no tiene productos.")) return;
            try {
                const res = await fetch(`${TENANT_API_URL}/admin/categories/${id}`, {
                    method: 'DELETE',
                    credentials: 'include'
                });
                const data = await res.json();
                if (!res.ok) {
                    showToast(data.error || "No se pudo eliminar la categoría", "error");
                    return;
                }
                showToast("Categoría eliminada", "success");
                await cargarCategorias();
                await cargarAdminProductos();
            } catch (err) {
                showToast("Error de conexión al eliminar categoría", "error");
            }
        }

        async function cargarCategorias() {
            try {
                const response = await fetch(`${TENANT_API_URL}/categories`);
                if (!response.ok) throw new Error('Error al obtener categorías');
                categorias = await response.json();
                renderCategorias();
            } catch (err) {
                console.error(err);
                showToast("Error al cargar categorías", "error");
            }
        }

        async function cargarDesdeAPI() {
            try {
                if (categorias.length === 0) {
                    await cargarCategorias();
                }
                const response = await fetch(`${TENANT_API_URL}/products`);
                if (!response.ok) {
                    const errorData = await response.json().catch(() => ({}));
                    if (errorData.status === 'suspended') {
                        document.getElementById("grid-productos").innerHTML = `
                        <div class="col-span-full rounded-3xl border border-slate-100 bg-white p-8 text-center shadow-premium">
                            <div class="mx-auto mb-4 flex h-14 w-14 items-center justify-center rounded-2xl bg-slate-50 text-slate-400"><i class="fa-solid fa-clock-rotate-left"></i></div>
                            <p class="text-sm font-black uppercase tracking-wider text-slate-900">Catálogo temporalmente no disponible</p>
                            <p class="mx-auto mt-2 max-w-md text-sm font-semibold text-slate-500">Este catálogo se encuentra en mantenimiento. Por favor, intenta de nuevo más tarde.</p>
                        </div>`;
                        return;
                    }
                    throw new Error(errorData.error || 'Error de servidor');
                }
                const data = await response.json();
                
                productos = data.map(p => ({
                    id: p._id,
                    c: p.categoriaId || p.categoria,
                    cn: p.categoria,
                    n: p.nombre,
                    p: p.precio,
                    u: p.unidadMedida || p.unidad,
                    img: (p.imagenUrl || p.imagen).startsWith('/') ? `${BACKEND_URL}${p.imagenUrl || p.imagen}` : (p.imagenUrl || p.imagen),
                    o: p.ordenVisualizacion || p.orden
                }));

                dibujar();
            } catch (err) {
                console.error(err);
                document.getElementById("grid-productos").innerHTML = `
                <div class="col-span-full text-center py-20">
                    <div class="w-16 h-16 bg-rose-50 text-rose-500 rounded-2xl flex items-center justify-center text-2xl mx-auto mb-4"><i class="fa-solid fa-triangle-exclamation"></i></div>
                    <p class="text-sm font-bold text-slate-800">Error al cargar el catálogo</p>
                    <p class="text-xs text-slate-400 mt-1">Por favor verifica la conexión a la Base de Datos</p>
                    <button onclick="cargarDesdeAPI()" class="mt-4 px-4 py-2 bg-primary-500 hover:bg-primary-600 text-white text-xs font-bold rounded-xl transition-all">Reintentar</button>
                </div>`;
            }
        }

        async function cargarAdminProductos() {
            try {
                if (categorias.length === 0) {
                    await cargarCategorias();
                }
                const response = await fetch(`${TENANT_API_URL}/admin/products`, { credentials: 'include' });
                if (!response.ok) throw new Error('Error al obtener productos');
                adminProductos = await response.json();
                if (adminPedidos.length === 0) {
                    try {
                        const pedidosResponse = await fetch(`${TENANT_API_URL}/admin/orders`, { credentials: 'include' });
                        if (pedidosResponse.ok) adminPedidos = await pedidosResponse.json();
                    } catch (err) {
                        console.warn('No se pudieron cargar pedidos para métricas', err);
                    }
                }
                
                // Actualizar métricas del dashboard
                document.getElementById('stat-total').innerText = adminProductos.length;
                document.getElementById('stat-activos').innerText = adminProductos.filter(p => p.activo).length;
                document.getElementById('stat-inactivos').innerText = adminProductos.filter(p => !p.activo).length;
                actualizarMetricasPedidos();

                dibujarAdmin();
            } catch (err) {
                console.error(err);
                showToast("Error al cargar inventario para el Panel", "error");
            }
        }

        /* ===========================
        DIBUJAR PRODUCTOS (CLIENTE)
        =========================== */
        function dibujar() {
            const container = document.getElementById("grid-productos");
            const busqueda = obtenerBusquedaCatalogo();

            let lista = filtroActual === "todos" 
                ? productos 
                : productos.filter(p => p.c === filtroActual);

            if (busqueda !== "") {
                lista = lista.filter(p => p.n.toLowerCase().includes(busqueda));
            }

            if (lista.length === 0) {
                container.innerHTML = `
                <div class="col-span-full text-center py-20 bg-white rounded-3xl border border-slate-100 shadow-premium">
                    <div class="w-14 h-14 bg-slate-50 text-slate-400 rounded-2xl flex items-center justify-center text-xl mx-auto mb-3"><i class="fa-solid fa-basket-shopping"></i></div>
                    <p class="text-xs font-bold text-slate-500 uppercase tracking-widest">No hay productos disponibles</p>
                </div>`;
                return;
            }

            container.innerHTML = lista.map(prod => {
                const badgeColor = 'bg-primary-50 text-primary-700 ring-1 ring-primary-100';
                return `
                <div id="card-${prod.id}" class="group flex h-full flex-col overflow-hidden rounded-[1.5rem] border border-slate-100 bg-white shadow-premium transition-all duration-300 md:rounded-[2rem] ${pedido[prod.id] > 0 ? 'card-active' : 'hover:-translate-y-1 hover:shadow-premium-hover'}">
                    
                    <div class="relative h-36 overflow-hidden bg-slate-50 md:h-48">
                        <span class="absolute left-3 top-3 z-10 ${badgeColor} rounded-full px-2.5 py-1 text-[8px] font-black uppercase tracking-wider">
                            ${prod.cn}
                        </span>
                        <img src="${prod.img}" class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-110" onerror="this.src='https://via.placeholder.com/300?text=${encodeURIComponent(prod.n)}'">
                    </div>

                    <div class="flex flex-1 flex-col p-3 md:p-4">
                        <h3 class="line-clamp-2 min-h-[2.25rem] text-[12px] font-extrabold uppercase tracking-tight text-slate-900 md:text-sm">
                            ${prod.n}
                        </h3>
                        
                        <p class="mt-1 mb-3 text-base font-black text-primary-600 md:text-lg">
                            Q${prod.p.toFixed(2)} <span class="text-slate-400 font-bold text-[10px]">/ ${prod.u}</span>
                        </p>

                        <div class="mt-auto flex items-center justify-between rounded-2xl border border-slate-100 bg-slate-50 p-1.5">
                            <button onclick="update('${prod.id}', -1)" 
                                class="flex h-8 w-8 items-center justify-center rounded-xl bg-white font-black text-slate-600 shadow-sm transition-all hover:bg-slate-100 active:scale-95">
                                <i class="fa-solid fa-minus text-[10px]"></i>
                            </button>
                            <span id="cant-${prod.id}" class="font-black text-slate-800 text-sm">
                                ${pedido[prod.id] || 0}
                            </span>
                            <button onclick="update('${prod.id}', 1)" 
                                class="flex h-8 w-8 items-center justify-center rounded-xl bg-slate-900 font-black text-white shadow-sm transition-all hover:bg-slate-800 active:scale-95">
                                <i class="fa-solid fa-plus text-[10px]"></i>
                            </button>
                        </div>
                    </div>
                </div>`;
            }).join('');
        }

        /* ===========================
        DIBUJAR PRODUCTOS (ADMIN)
        =========================== */
        function dibujarAdmin() {
            const tbody = document.getElementById("admin-tabla-body");
            const movilList = document.getElementById("admin-movil-list");
            const busqueda = document.getElementById("admin-buscar").value.trim().toLowerCase();
            const filtroCat = document.getElementById("admin-filtro-categoria").value;
            const pageSizeEl = document.getElementById("admin-page-size");
            adminProductosPorPagina = parseInt(pageSizeEl?.value, 10) || 10;

            let lista = filtroCat === "todos" 
                ? adminProductos 
                : adminProductos.filter(p => (p.categoriaId || p.categoria) === filtroCat);

            if (busqueda !== "") {
                lista = lista.filter(p => p.nombre.toLowerCase().includes(busqueda));
            }

            const totalPaginas = Math.max(1, Math.ceil(lista.length / adminProductosPorPagina));
            adminPaginaActual = Math.min(Math.max(adminPaginaActual, 1), totalPaginas);
            const inicio = (adminPaginaActual - 1) * adminProductosPorPagina;
            const fin = Math.min(inicio + adminProductosPorPagina, lista.length);
            const listaPagina = lista.slice(inicio, fin);

            if (lista.length === 0) {
                const paginationText = document.getElementById("admin-pagination-text");
                if (paginationText) paginationText.innerText = "Mostrando 0 a 0 de 0 productos";
                actualizarControlesPaginacion(1, 1);
                const vacioMsg = `
                <tr>
                    <td colspan="7" class="text-center py-16 text-slate-400 font-bold uppercase text-[10px] tracking-wider">
                        No hay productos que coincidan en el inventario
                    </td>
                </tr>`;
                tbody.innerHTML = vacioMsg;
                movilList.innerHTML = `
                <div class="text-center py-10 text-slate-400 font-bold uppercase text-[10px] tracking-wider">
                    No hay productos que coincidan en el inventario
                </div>`;
                return;
            }

            const paginationText = document.getElementById("admin-pagination-text");
            if (paginationText) {
                paginationText.innerText = `Mostrando ${inicio + 1} a ${fin} de ${lista.length} productos`;
            }
            actualizarControlesPaginacion(adminPaginaActual, totalPaginas);

            // Renderizar versión Escritorio (Tabla)
            tbody.innerHTML = listaPagina.map(prod => {
                const productId = getProductId(prod);
                if (!productId) console.warn('Producto sin id estable en inventario', prod);
                const imgUrl = prod.imagen.startsWith('/') ? `${BACKEND_URL}${prod.imagen}` : prod.imagen;
                const statusBadge = prod.activo 
                    ? `<span class="inline-flex items-center rounded-full bg-primary-50 px-3 py-1.5 text-[10px] font-black uppercase tracking-wider text-primary-700 ring-1 ring-primary-200"><i class="fa-solid fa-circle text-[6px] mr-2"></i>Activo</span>`
                    : `<span class="inline-flex items-center rounded-full bg-rose-50 px-3 py-1.5 text-[10px] font-black uppercase tracking-wider text-rose-700 ring-1 ring-rose-200"><i class="fa-solid fa-circle text-[6px] mr-2"></i>Inactivo</span>`;
                
                return `
                <tr class="hover:bg-slate-50/70 transition-colors">
                    <td class="px-6 py-4">
                        <div class="w-16 h-16 bg-slate-50 border border-slate-100 rounded-2xl overflow-hidden shadow-sm">
                            <img src="${imgUrl}" class="w-full h-full object-cover" onerror="this.src='https://via.placeholder.com/300?text=${encodeURIComponent(prod.nombre)}'">
                        </div>
                    </td>
                    <td class="px-4 py-4">
                        <div class="font-extrabold text-slate-950">${prod.nombre}</div>
                        <div class="text-[10px] text-slate-400 uppercase tracking-wide">ID: ${productId}</div>
                    </td>
                    <td class="px-4 py-4">
                        <span class="text-xs uppercase font-extrabold px-3 py-1 rounded-full bg-slate-100 text-slate-700">${prod.categoria || 'Sin categoría'}</span>
                    </td>
                    <td class="px-4 py-4">
                        <div class="font-black text-primary-600">Q${prod.precio.toFixed(2)}</div>
                        <div class="text-[10px] text-slate-400">Por ${prod.unidad}</div>
                    </td>
                    <td class="px-4 py-4 text-center">
                        <span class="bg-slate-100 text-slate-700 font-black px-3 py-1.5 rounded-xl text-xs">${prod.orden ?? prod.ordenVisualizacion ?? '-'}</span>
                    </td>
                    <td class="px-4 py-4 text-center">
                        <button onclick="toggleProductStatus('${productId}', ${!prod.activo})" class="transition-transform active:scale-95">
                            ${statusBadge}
                        </button>
                    </td>
                    <td class="px-6 py-4 text-right">
                        <div class="flex justify-end gap-2">
                            <button onclick="editarProducto('${productId}')" class="rounded-xl bg-slate-100 px-3 py-2 text-xs font-black text-slate-700 transition hover:bg-slate-200" title="Editar"><i class="fa-solid fa-pen mr-1.5 text-[10px]"></i>Editar</button>
                            <button onclick="abrirConfirmDelete('${productId}')" class="rounded-xl bg-rose-50 px-3 py-2 text-xs font-black text-rose-600 transition hover:bg-rose-100" title="Eliminar"><i class="fa-solid fa-trash-can mr-1.5 text-[10px]"></i>Eliminar</button>
                        </div>
                    </td>
                </tr>`;
            }).join('');

            // Renderizar versión Móvil (Tarjetas)
            movilList.innerHTML = listaPagina.map(prod => {
                const productId = getProductId(prod);
                if (!productId) console.warn('Producto sin id estable en inventario', prod);
                const imgUrl = prod.imagen.startsWith('/') ? `${BACKEND_URL}${prod.imagen}` : prod.imagen;
