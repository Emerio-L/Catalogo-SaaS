                if (submitBtn) {
                    submitBtn.disabled = true;
                    submitBtn.classList.add('opacity-70', 'cursor-wait');
                    submitBtn.innerHTML = '<i class="fa-solid fa-circle-notch fa-spin"></i> Guardando catálogo';
                }
                const res = await fetch(`${API_URL}/tenants/register`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(payload)
                });
                const data = await res.json().catch(() => ({}));
                if (!res.ok) {
                    if (data.existingAccount && data.publicUrl && data.adminUrl) {
                        mostrarErrorRegistroLanding('');
                        if (form) form.classList.add('hidden');
                        if (resultEl) {
                            resultEl.innerHTML = `
                                <div class="space-y-4 text-slate-800">
                                    <div class="flex items-center gap-3 text-emerald-800">
                                        <div class="flex h-10 w-10 items-center justify-center rounded-2xl bg-emerald-500 text-white text-lg"><i class="fa-solid fa-circle-check"></i></div>
                                        <div>
                                            <p class="text-sm font-black uppercase text-slate-900">La cuenta ya existe</p>
                                            <p class="text-[11px] font-semibold text-slate-500">Te mostramos los accesos del catálogo configurado.</p>
                                        </div>
                                    </div>
                                    <div class="rounded-2xl bg-slate-50 p-4 ring-1 ring-slate-200/60 space-y-3">
                                        <div>
                                            <p class="text-[10px] font-black uppercase tracking-wider text-slate-400">Tu catálogo público</p>
                                            <a href="${data.publicUrl}" target="_blank" class="text-xs font-black text-emerald-600 underline break-all">${window.location.origin}${data.publicUrl}</a>
                                        </div>
                                        <div>
                                            <p class="text-[10px] font-black uppercase tracking-wider text-slate-400">Tu panel de administración privado</p>
                                            <a href="${data.adminUrl}" target="_blank" class="text-xs font-black text-slate-800 underline break-all">${window.location.origin}${data.adminUrl}</a>
                                        </div>
                                    </div>
                                    <p class="text-[10px] font-semibold text-slate-500 text-center">¡Guarda el enlace administrativo! Es la única forma de acceder a tu panel.</p>
                                </div>
                            `;
                            resultEl.classList.remove('hidden');
                        }
                        showToast('La cuenta ya existe. Te mostramos tus enlaces.', 'info');
                        return;
                    }
                    const mensaje = data.error || 'No se pudo crear la cuenta.';
                    mostrarErrorRegistroLanding(res.status === 409
                        ? `${mensaje}. Cambia el enlace del catálogo o usa otro nombre para tu negocio.`
                        : mensaje);
                    return;
                }

                mostrarErrorRegistroLanding('');
                if (form) form.classList.add('hidden');
                if (resultEl) {
                    resultEl.innerHTML = `
                        <div class="space-y-4 text-slate-800">
                            <div class="flex items-center gap-3 text-emerald-800">
                                <div class="flex h-10 w-10 items-center justify-center rounded-2xl bg-emerald-500 text-white text-lg"><i class="fa-solid fa-circle-check"></i></div>
                                <div>
                                    <p class="text-sm font-black uppercase text-slate-900">¡Cuenta creada con éxito!</p>
                                    <p class="text-[11px] font-semibold text-slate-500">Bienvenido a Sedelynk. Tu catálogo profesional está listo.</p>
                                </div>
                            </div>
                            <div class="rounded-2xl bg-slate-50 p-4 ring-1 ring-slate-200/60 space-y-3">
                                <div>
                                    <p class="text-[10px] font-black uppercase tracking-wider text-slate-400">Tu catálogo público</p>
                                    <a href="${data.publicUrl}" target="_blank" class="text-xs font-black text-emerald-600 underline break-all">${window.location.origin}${data.publicUrl}</a>
                                </div>
                                <div>
                                    <p class="text-[10px] font-black uppercase tracking-wider text-slate-400">Tu panel de administración privado</p>
                                    <a href="${data.adminUrl}" target="_blank" class="text-xs font-black text-slate-800 underline break-all">${window.location.origin}${data.adminUrl}</a>
                                </div>
                            </div>
                            <p class="text-[10px] font-semibold text-slate-500 text-center">¡Importante: Guarda el enlace administrativo en tus favoritos! Es la única forma de acceder a tu panel.</p>
                        </div>
                    `;
                    resultEl.classList.remove('hidden');
                }
                showToast('Cuenta creada correctamente', 'success');
            } catch (err) {
                mostrarErrorRegistroLanding('Error de conexión al crear cuenta.');
            } finally {
                if (submitBtn) {
                    submitBtn.disabled = false;
                    submitBtn.classList.remove('opacity-70', 'cursor-wait');
                    submitBtn.innerHTML = '<i class="fa-solid fa-store"></i> Guardar y crear catálogo';
                }
            }
        }
        window.registrarCuentaSaasLanding = registrarCuentaSaasLanding;

        window.trialCountdownInterval = null;
        function iniciarTrialCountdown(trialEndDateISO) {
            if (window.trialCountdownInterval) {
                clearInterval(window.trialCountdownInterval);
                window.trialCountdownInterval = null;
            }

            const banner = document.getElementById('trial-countdown-banner');
            const timerEl = document.getElementById('trial-countdown-timer');
            if (!banner || !timerEl) return;

            if (!trialEndDateISO) {
                banner.classList.add('hidden');
                return;
            }

            const targetDate = new Date(trialEndDateISO).getTime();
            if (isNaN(targetDate)) {
                banner.classList.add('hidden');
                return;
            }

            function actualizarTimer() {
                const now = new Date().getTime();
                const diff = targetDate - now;

                if (diff <= 0) {
                    timerEl.innerText = "Expirado";
                    banner.classList.remove('bg-amber-50', 'border-amber-200/60', 'text-amber-900');
                    banner.classList.add('bg-rose-50', 'border-rose-200/60', 'text-rose-900');
                    const badge = banner.querySelector('.bg-amber-500');
                    if (badge) {
                        badge.classList.remove('bg-amber-500');
                        badge.classList.add('bg-rose-500');
                    }
                    clearInterval(window.trialCountdownInterval);
                    window.trialCountdownInterval = null;
                    return;
                }

                const dias = Math.floor(diff / (1000 * 60 * 60 * 24));
                const horas = Math.floor((diff % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
                const minutos = Math.floor((diff % (1000 * 60 * 60)) / (1000 * 60));
                const segundos = Math.floor((diff % (1000 * 60)) / 1000);

                timerEl.innerText = `${dias}d ${horas}h ${minutos}m ${segundos}s`;
            }

            actualizarTimer();
            banner.classList.remove('hidden');
            banner.classList.add('flex');
            window.trialCountdownInterval = setInterval(actualizarTimer, 1000);
        }
        window.iniciarTrialCountdown = iniciarTrialCountdown;

        async function iniciarApp() {
            if (isLandingPage) {
                const supportButton = document.getElementById('support-floating-button');
                supportButton?.classList.remove('hidden');
                supportButton?.classList.add('flex');
                cargarSoporteSaas();
                if (isResetRoute && resetToken) {
                    abrirAuthModal();
                }
                return;
            }

            cargarSoporteSaas();
            if (isAdminRoute) {
                const rutaAdminValida = await validarRutaAdmin();
                if (!rutaAdminValida) {
                    const clientView = document.getElementById('client-view');
                    if (clientView) clientView.classList.remove('hidden');
                    ocultarAuthModalInmediato();
                    await cargarConfiguracionPublica();
                    await cargarCategorias();
                    await cargarDesdeAPI();
                    return;
                }

                if (await verificarSesionAdminActiva()) {
                    await cargarConfiguracionPublica();
                    await cargarCategorias();
                    switchView('admin');
                } else {
                    mostrarPanelAdminProtegido();
                }
                return;
            }

            await cargarConfiguracionPublica();
            await cargarCategorias();
            await cargarDesdeAPI();
            if (isResetRoute && resetToken) {
                abrirAuthModal();
            }
        }

        // INICIAR LOCAL
        actualizarTituloPagina();
        iniciarMonitorInactividadAdmin();
        iniciarApp();
    </script>
</Layout>



