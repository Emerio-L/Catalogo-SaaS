        function actualizarMetricasPedidos() {
            const pedidosHoyEl = document.getElementById('stat-pedidos-hoy');
            const comparacionEl = document.getElementById('stat-pedidos-comparacion');
            if (!pedidosHoyEl) return;

            const inicioHoy = new Date();
            inicioHoy.setHours(0, 0, 0, 0);
            const inicioManana = new Date(inicioHoy);
            inicioManana.setDate(inicioManana.getDate() + 1);
            const inicioAyer = new Date(inicioHoy);
            inicioAyer.setDate(inicioAyer.getDate() - 1);

            const pedidosHoy = adminPedidos.filter(p => {
                const fecha = new Date(p.fecha);
                return fecha >= inicioHoy && fecha < inicioManana;
            }).length;
            const pedidosAyer = adminPedidos.filter(p => {
                const fecha = new Date(p.fecha);
                return fecha >= inicioAyer && fecha < inicioHoy;
            }).length;

            pedidosHoyEl.innerText = pedidosHoy;
            if (!comparacionEl) return;

            if (pedidosHoy === 0 && pedidosAyer === 0) {
                comparacionEl.className = 'hidden rounded-full bg-blue-50 px-2.5 py-1 text-[10px] font-black text-blue-600';
                comparacionEl.innerText = '';
                return;
            }

            if (pedidosAyer === 0) {
                comparacionEl.innerText = pedidosHoy > 0 ? 'Nuevo hoy' : '';
                comparacionEl.className = pedidosHoy > 0
                    ? 'rounded-full bg-primary-50 px-2.5 py-1 text-[10px] font-black text-primary-700'
                    : 'hidden rounded-full bg-blue-50 px-2.5 py-1 text-[10px] font-black text-blue-600';
                return;
            }

            const variacion = Math.round(((pedidosHoy - pedidosAyer) / pedidosAyer) * 100);
            if (variacion === 0) {
                comparacionEl.innerText = 'Igual que ayer';
                comparacionEl.className = 'rounded-full bg-slate-100 px-2.5 py-1 text-[10px] font-black text-slate-600';
                return;
            }

            comparacionEl.innerText = `${variacion > 0 ? '+' : ''}${variacion}% vs ayer`;
            comparacionEl.className = variacion > 0
                ? 'rounded-full bg-primary-50 px-2.5 py-1 text-[10px] font-black text-primary-700'
                : 'rounded-full bg-rose-50 px-2.5 py-1 text-[10px] font-black text-rose-700';
        }

