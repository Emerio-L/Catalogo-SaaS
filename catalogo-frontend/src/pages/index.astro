---
import Layout from '../layouts/Layout.astro';
import heroCommerce from '../assets/landing/hero-commerce-sedelynk.png';
import laptopWhatsapp from '../assets/landing/laptop-whatsapp.png';

const publicBackendUrl = import.meta.env.PUBLIC_BACKEND_URL || '';
---

<Layout
    title="Sedelynk | Tienda en línea con carrito para negocios en Guatemala"
    description="Crea tu tienda en línea con carrito de compras en Guatemala. Recibe pedidos organizados, administra productos y vende sin comisiones con Sedelynk."
    keywords="tienda en línea Guatemala, carrito de compras para negocio, crear tienda online Guatemala, catálogo digital con carrito, sistema de pedidos en línea, vender productos en línea Guatemala, tienda virtual para emprendedores, catálogo online para negocios"
>
    <!-- FLOATING TOAST NOTIFICATIONS CONTAINER -->
    <div id="toast-container" class="fixed top-5 right-5 z-[100] flex flex-col gap-3 max-w-sm w-full pointer-events-none"></div>

    <script define:vars={{ publicBackendUrl }}>
        window.__PUBLIC_BACKEND_URL__ = publicBackendUrl;
    </script>

    <div id="landing-view" class="w-full min-h-screen landing-view text-slate-800 selection:bg-purple-500 selection:text-white font-sans relative flex flex-col justify-between">
            {/* CONTENEDOR HERO SECTION (PRIMERA PANTALLA) */}
            <div class="hero-section relative overflow-hidden flex flex-col justify-between">
                {/* Dotted grid on the left */}
                <div class="absolute inset-0 pointer-events-none z-0">
                    <div class="absolute top-28 left-8 w-36 h-36 dot-pattern opacity-60"></div>
                </div>

            {/* STYLE DECLARATIONS */}
            <style is:inline>
                :root {
                  --color-bg: #FFFFFF;
                  --color-surface: #FFFFFF;
                  --color-text-primary: #070B24;
                  --color-text-secondary: #607089;

                  --color-purple: #7C3AED;
                  --color-pink: #D946EF;
                  --color-orange: #FF6B1A;
                  --color-blue: #2563EB;
                  --color-green: #22C55E;

                  --gradient-primary: linear-gradient(135deg, #7C3AED 0%, #D946EF 45%, #FF6B1A 100%);
                  --gradient-blue: linear-gradient(135deg, #2563EB 0%, #1D4ED8 100%);
                  --gradient-soft-purple: linear-gradient(135deg, #F3E8FF 0%, #EEF2FF 100%);

                  --border-soft: #E5EAF5;
                  --shadow-card: 0 20px 50px rgba(7, 11, 36, 0.08);
                  --radius-card: 28px;
                  --radius-button: 14px;
                }

                body.landing-page {
                    background-color: var(--color-bg) !important;
                }

                .landing-view {
                    background-color: var(--color-bg);
                    color: var(--color-text-primary);
                }

                .landing-card {
                    background-color: var(--color-surface);
                    border: 1px solid var(--border-soft);
                    border-radius: var(--radius-card);
                    box-shadow: var(--shadow-card);
                }

                .landing-btn-primary {
                    background: var(--gradient-primary);
                    color: white !important;
                    border-radius: var(--radius-button);
                    transition: all 0.2s ease-in-out;
                }
                .landing-btn-primary:hover {
                    opacity: 0.9;
                    transform: translateY(-1px);
                }
                .landing-btn-primary:active {
                    transform: translateY(0);
                }

                .landing-btn-secondary {
                    background: white;
                    border: 1.5px solid var(--color-purple);
                    color: var(--color-purple) !important;
                    border-radius: var(--radius-button);
                    transition: all 0.2s ease-in-out;
                }
                .landing-btn-secondary:hover {
                    background-color: rgba(124, 58, 237, 0.04);
                    transform: translateY(-1px);
                }

                .faq-answer {
                    max-height: 0;
                    overflow: hidden;
                    transition: max-height 0.3s ease-out, padding 0.3s ease-out;
                }
                .faq-item.active .faq-answer {
                    max-height: 200px;
                    padding-top: 1rem;
                }
                .faq-item.active .faq-icon {
                    transform: rotate(180deg);
                }

                /* Contenedor principal de la primera pantalla visible */
                .hero-section {
                  min-height: 100vh;
                  justify-content: flex-start;
                  gap: 14px;
                  background:
                    radial-gradient(circle at -4% 0%, rgba(124, 58, 237, 0.34) 0px, rgba(124, 58, 237, 0.24) 118px, transparent 300px),
                    radial-gradient(circle at 45% 34%, rgba(124, 58, 237, 0.13) 0px, transparent 390px),
                    radial-gradient(circle at 96% 24%, rgba(59, 130, 246, 0.08) 0px, transparent 360px),
                    linear-gradient(135deg, #f6f7ff 0%, #eef3ff 44%, #f8f4ff 100%);
                }

                .logoContainer {
                  width: 230px;
                  max-width: 100%;
                  height: 72px;
                  display: flex;
                  align-items: center;
                  justify-content: flex-start;
                  flex-shrink: 0;
                  overflow: hidden;
                }

                .logoContainer img {
                  width: 100%;
                  height: 100%;
                  object-fit: contain;
                  display: block;
                  opacity: 1;
                  filter: none;
                  transform: scale(1.65);
                  transform-origin: center;
                }

                .logoContainer img.hidden {
                  display: none;
                }

                .logoContainer #landing-logo-fallback {
                  height: 100%;
                  max-width: 100%;
                  width: 100%;
                  align-items: center;
                  justify-content: flex-start;
                }

                .logoContainer #landing-logo-fallback svg {
                  width: 100%;
                  height: 100%;
                  display: block;
                }

                .landingHeader,
                .heroContent,
                #landing-promo-card {
                  width: calc(100% - 120px);
                  max-width: 1500px;
                }

                .heroContent {
                  display: grid;
                  grid-template-columns: minmax(310px, 0.9fr) 360px minmax(500px, 1.05fr);
                  gap: 24px;
                  align-items: center;
                  flex: 0 0 auto;
                }

                .heroVisual {
                  width: 360px;
                  height: 360px;
                  display: flex;
                  align-items: center;
                  justify-content: center;
                  flex-shrink: 0;
                  position: relative;
                }

                .heroVisual img {
                  width: 100%;
                  max-width: 360px;
                  height: auto;
                  object-fit: contain;
                  display: block;
                }

                /* Medidas y proporción de las tarjetas principales */
                .heroActionCards {
                  display: flex;
                  gap: 16px;
                  align-items: stretch;
                }

                .heroActionCard {
                  width: 240px;
                  min-height: 410px;
                  padding: 20px 20px 18px;
                  border-radius: 24px;
                  background: #ffffff;
                  position: relative;
                  overflow: hidden;
                  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
                }

                .heroActionCard:hover {
                  transform: translateY(-5px);
                  box-shadow:
                    0 35px 75px rgba(124, 58, 237, 0.20),
                    0 12px 28px rgba(15, 23, 42, 0.08);
                }

                .heroActionCard.portal:hover {
                  box-shadow:
                    0 35px 75px rgba(15, 107, 255, 0.18),
                    0 12px 28px rgba(15, 23, 42, 0.08);
                }

                .heroActionCard.signup {
                  border: 1.5px solid rgba(124, 58, 237, 0.36);
                  box-shadow:
                    0 28px 65px rgba(124, 58, 237, 0.16),
                    0 10px 24px rgba(15, 23, 42, 0.06);
                }

                .heroActionCard.portal {
                  border: 1.5px solid rgba(15, 107, 255, 0.36);
                  box-shadow:
                    0 28px 65px rgba(15, 107, 255, 0.14),
                    0 10px 24px rgba(15, 23, 42, 0.06);
                }

                .heroActionCard::before {
                  content: "";
                  position: absolute;
                  inset: 0;
                  border-radius: inherit;
                  padding: 1px;
                  pointer-events: none;
                  background: linear-gradient(135deg, rgba(124,58,237,.45), rgba(59,130,246,.35), rgba(249,115,22,.22));
                  -webkit-mask:
                    linear-gradient(#fff 0 0) content-box,
                    linear-gradient(#fff 0 0);
                  -webkit-mask-composite: xor;
                  mask-composite: exclude;
                }

                .heroActionCard .cardBadge {
                  margin-bottom: 14px;
                }

                .heroActionCard .cardIcon {
                  width: 46px;
                  height: 46px;
                  margin-bottom: 14px;
                }

                .heroActionCard h3 {
                  font-size: 21px;
                  line-height: 1.08;
                  margin-bottom: 6px;
                }

                .heroActionCard .cardSubtitle {
                  font-size: 13px;
                  margin-bottom: 14px;
                }

                .heroActionCard .cardDivider {
                  margin: 0 0 14px;
                }

                .heroActionCard ul {
                  display: grid;
                  gap: 8px;
                  margin-bottom: 16px;
                }

                .heroActionCard ul li {
                  font-size: 11px;
                  font-weight: 700;
                  color: #4B5563;
                }

                .heroActionCard button,
                .heroActionCard a.button {
                  width: 100%;
                  height: 46px;
                  border-radius: 14px;
                  font-weight: 800;
                }

                #landing-promo-card {
                  padding-left: 0;
                  padding-right: 0;
                  margin-top: 0;
                }

                @media (min-width: 1400px) {
                  .heroContent {
                    grid-template-columns: minmax(350px, 0.95fr) 380px minmax(500px, 1.05fr);
                    gap: 26px;
                  }

                  .heroVisual {
                    width: 380px;
                    height: 380px;
                  }

                  .heroVisual img {
                    max-width: 380px;
                  }
                }

                /* Responsive */
                @media (max-width: 1200px) {
                  .heroContent {
                    grid-template-columns: 1fr;
                    gap: 32px;
                  }

                  .heroVisual {
                    width: 320px;
                    height: 320px;
                    margin: 0 auto;
                  }

                  .heroVisual img {
                    max-width: 320px;
                  }
                }

                @media (max-width: 1100px) {
                  .heroActionCards {
                    gap: 20px;
                  }

                  .heroActionCard {
                    width: 280px;
                    min-height: 480px;
                  }
                }

                @media (max-width: 900px) {
                  .heroActionCards {
                    flex-direction: column;
                  }

                  .heroActionCard {
                    width: 100%;
                    max-width: 360px;
                    min-height: auto;
                  }
                }

                @media (max-width: 768px) {
                  .landingHeader,
                  .heroContent,
                  #landing-promo-card {
                    width: calc(100% - 32px);
                  }

                  .logoContainer {
                    width: min(44vw, 190px);
                    height: 60px;
                  }

                  .logoContainer img {
                    transform: scale(1.65);
                  }

                  .logoContainer #landing-logo-fallback {
                    width: 100%;
                    height: 100%;
                  }

                  .heroVisual {
                    width: 100%;
                    max-width: 320px;
                    height: auto;
                    margin: 24px auto;
                  }

                  .heroVisual img {
                    max-width: 320px;
                  }
                }

                .dot-pattern {
                  background-image: radial-gradient(rgba(124, 58, 237, 0.15) 1.5px, transparent 1.5px);
                  background-size: 16px 16px;
                }

                @keyframes float {
                  0%, 100% { transform: translateY(0px); }
                  50% { transform: translateY(-10px); }
                }

                .animate-float {
                  animation: float 4s ease-in-out infinite;
                }
            </style>

            <script is:inline>
                document.body.classList.add('landing-page');
            </script>

            {/* NAVBAR */}
            <header class="landingHeader relative z-50 mx-auto px-5 md:px-8 py-3.5 md:py-4 flex justify-between items-center bg-white shadow-xl shadow-purple-950/[0.03] border border-slate-100/80 rounded-3xl sticky top-3 mt-3 w-[calc(100%-24px)] md:w-auto">
                <div class="flex items-center">
                    <a href="/" class="flex items-center gap-3">
                        <div class="logoContainer">
                            <img id="landing-logo-img" src="" alt="SEDELYNK Logo" class="hidden" style="opacity: 1 !important; filter: none !important;">
                            <div id="landing-logo-fallback" class="flex items-center">
                                <svg class="w-auto h-full" viewBox="0 0 400 120" fill="none" xmlns="http://www.w3.org/2000/svg">
                                  <path d="M40 70H100M20 52H90M30 35H80" stroke="url(#paint0_linear_nav)" stroke-width="4" stroke-linecap="round"/>
                                  <path d="M85 85H140L150 95L155 85H165C175 85 180 80 180 70V50C180 40 175 35 165 35H115C105 35 100 40 100 50V70C100 78 105 85 115 85" stroke="#0B132B" stroke-width="5" stroke-linecap="round" stroke-linejoin="round"/>
                                  <circle cx="120" cy="60" r="5" fill="#8B5CF6"/>
                                  <circle cx="138" cy="60" r="5" fill="#EC4899"/>
                                  <circle cx="156" cy="60" r="5" fill="#F97316"/>
                                  <path d="M105 45C115 35 130 20 155 20C170 20 190 28 200 45C185 43 175 42 165 44C160 40 155 35 145 38C140 40 142 45 138 48C125 46 115 46 105 45Z" fill="#0B132B"/>
                                  <path d="M140 22C145 12 155 5 165 10C160 15 158 20 155 25C150 24 145 23 140 22Z" fill="#0B132B"/>
                                  <circle cx="185" cy="35" r="2" fill="white"/>
                                  <text x="200" y="65" font-family="'Outfit', 'Plus Jakarta Sans', sans-serif" font-weight="900" font-size="36" fill="#0B132B" letter-spacing="-0.02em">SEDE</text>
                                  <text x="295" y="65" font-family="'Outfit', 'Plus Jakarta Sans', sans-serif" font-weight="900" font-size="36" fill="url(#paint1_linear_nav)" letter-spacing="-0.02em">LYNK</text>
                                  <text x="200" y="85" font-family="'Plus Jakarta Sans', sans-serif" font-weight="800" font-size="9" fill="#0B132B" letter-spacing="0.08em">CONECTA TU NEGOCIO, RECIBE MÁS PEDIDOS</text>
                                  <defs>
                                    <linearGradient id="paint0_linear_nav" x1="20" y1="52" x2="100" y2="52" gradientUnits="userSpaceOnUse">
                                      <stop stop-color="#8B5CF6"/>
                                      <stop offset="0.5" stop-color="#EC4899"/>
                                      <stop offset="1" stop-color="#F97316"/>
                                    </linearGradient>
                                    <linearGradient id="paint1_linear_nav" x1="295" y1="65" x2="390" y2="65" gradientUnits="userSpaceOnUse">
                                      <stop stop-color="#8B5CF6"/>
                                      <stop offset="0.5" stop-color="#EC4899"/>
                                      <stop offset="1" stop-color="#F97316"/>
                                    </linearGradient>
                                  </defs>
                                </svg>
                            </div>
                        </div>
                    </a>
                </div>
                
                {/* Menú de navegación desktop */}
                <nav class="hidden md:flex items-center gap-8 text-sm font-extrabold text-slate-600">
                    <a href="#como-funciona" class="hover:text-slate-900 transition-colors">¿Cómo funciona?</a>
                    <a href="#beneficios" class="hover:text-slate-900 transition-colors">Beneficios</a>
                    <a href="#precios" class="hover:text-slate-900 transition-colors">Precios</a>
                    <a href="#faq" class="hover:text-slate-900 transition-colors">Preguntas frecuentes</a>
                </nav>

                <div class="flex items-center gap-3">
                    <button onclick="mostrarLandingStep('login')" class="hidden sm:inline-flex items-center justify-center landing-btn-secondary px-5 py-2.5 text-xs font-black uppercase tracking-wider gap-2">
                        <i class="fa-solid fa-right-to-bracket text-xs"></i> INGRESAR AL PORTAL
                    </button>
                    <button onclick="mostrarLandingStep('register')" class="landing-btn-primary px-5 py-2.5 text-xs font-black uppercase tracking-wider shadow-md">
                        COMENZAR GRATIS
                    </button>
                    <button onclick="toggleMobileMenu()" class="md:hidden text-slate-700 p-2 focus:outline-none" aria-label="Menú">
                        <i class="fa-solid fa-bars text-xl"></i>
                    </button>
                </div>
            </header>

            {/* Menú Móvil */}
            <div id="mobile-menu" class="hidden fixed inset-0 z-50 bg-white flex flex-col p-6 space-y-6">
                <div class="flex justify-between items-center">
                    <span class="text-lg font-black text-slate-900 uppercase">Menú</span>
                    <button onclick="toggleMobileMenu()" class="text-slate-700 p-2 text-xl"><i class="fa-solid fa-xmark"></i></button>
                </div>
                <nav class="flex flex-col gap-4 text-base font-extrabold text-slate-600">
                    <a href="#como-funciona" onclick="toggleMobileMenu()" class="hover:text-slate-900">¿Cómo funciona?</a>
                    <a href="#beneficios" onclick="toggleMobileMenu()" class="hover:text-slate-900">Beneficios</a>
                    <a href="#precios" onclick="toggleMobileMenu()" class="hover:text-slate-900">Precios</a>
                    <a href="#faq" onclick="toggleMobileMenu()" class="hover:text-slate-900">Preguntas frecuentes</a>
                </nav>
                <div class="flex flex-col gap-3 pt-6 border-t border-slate-100">
                    <button onclick="toggleMobileMenu(); mostrarLandingStep('login');" class="w-full border border-blue-200 bg-white text-blue-600 font-extrabold text-sm px-5 py-3.5 rounded-xl text-center">Ingresar al portal</button>
                    <button onclick="toggleMobileMenu(); mostrarLandingStep('register');" class="w-full bg-gradient-to-r from-violet-600 via-pink-500 to-orange-500 text-white font-extrabold text-sm px-5 py-3.5 rounded-xl text-center">Comenzar gratis</button>
                </div>
            </div>

            {/* HERO SECTION */}
            <main class="heroContent relative z-10 mx-auto px-0 py-4 lg:py-6 flex-1">
                {/* Columna Izquierda */}
                <div class="text-left space-y-4">
                    <h1 id="landing-hero-title" class="text-3xl md:text-4xl lg:text-[2.85rem] font-black tracking-tight text-[#070B24] leading-[1.15] max-w-xl">
                        Crea tu tienda en línea con carrito de compras en <span class="text-[#FF6B1A]">Guatemala</span>
                    </h1>
                    
                    <p id="landing-hero-text" class="text-slate-500 text-xs md:text-sm font-semibold leading-relaxed max-w-xl">
                        Sedelynk te permite crear un catálogo digital, recibir pedidos por carrito y vender en línea sin comisiones. WhatsApp queda disponible como opción adicional para tus clientes.
                    </p>

                    {/* Mini Beneficios en dos columnas estilo tarjetas blancas con sombra */}
                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-2 max-w-xl">
                        <div class="flex items-center gap-2.5 bg-white border border-slate-100 rounded-2xl p-2.5 shadow-sm shadow-purple-950/[0.02]">
                            <span class="flex h-8 w-8 shrink-0 items-center justify-center rounded-xl bg-purple-50 text-purple-600"><i class="fa-solid fa-cart-shopping text-xs"></i></span>
                            <span class="text-slate-800 font-extrabold text-[10px] leading-tight">Sin comisiones ni<br>cargos ocultos</span>
                        </div>
                        <div class="flex items-center gap-2.5 bg-white border border-slate-100 rounded-2xl p-2.5 shadow-sm shadow-purple-950/[0.02]">
                            <span class="flex h-8 w-8 shrink-0 items-center justify-center rounded-xl bg-pink-50 text-pink-600"><i class="fa-solid fa-bolt text-xs"></i></span>
                            <span class="text-slate-800 font-extrabold text-[10px] leading-tight">Empieza tu tienda<br>en minutos</span>
                        </div>
                        <div class="flex items-center gap-2.5 bg-white border border-slate-100 rounded-2xl p-2.5 shadow-sm shadow-purple-950/[0.02]">
                            <span class="flex h-8 w-8 shrink-0 items-center justify-center rounded-xl bg-emerald-50 text-emerald-600"><i class="fa-brands fa-whatsapp text-sm"></i></span>
                            <span class="text-slate-800 font-extrabold text-[10px] leading-tight">Carrito de pedidos<br>organizado</span>
                        </div>
                        <div class="flex items-center gap-2.5 bg-white border border-slate-100 rounded-2xl p-2.5 shadow-sm shadow-purple-950/[0.02]">
                            <span class="flex h-8 w-8 shrink-0 items-center justify-center rounded-xl bg-violet-50 text-violet-600"><i class="fa-solid fa-box-open text-xs"></i></span>
                            <span class="text-slate-800 font-extrabold text-[10px] leading-tight">Organiza y envía sin<br>complicaciones</span>
                        </div>
                    </div>
                </div>

                {/* Columna Central (Ilustración 3D) */}
                <div class="heroVisual">
                    <div class="absolute inset-0 bg-gradient-to-tr from-purple-500/5 to-orange-500/5 rounded-full blur-3xl pointer-events-none"></div>
                    <img src={heroCommerce.src} alt="Catálogo Digital Ilustración" class="relative z-10 animate-float" />
                </div>

                {/* Columna Derecha (Tarjetas de Selección Side by Side) */}
                <div class="heroActionCards lg:col-span-1">
                    {/* Tarjeta Cliente Nuevo */}
                    <div class="heroActionCard signup flex flex-col justify-between items-stretch">
                        <div>
                            <span class="cardIcon flex shrink-0 items-center justify-center rounded-2xl bg-purple-50 text-purple-600 border border-purple-100/50 shadow-sm text-2xl">
                                <i class="fa-solid fa-cart-shopping"></i>
                            </span>
                            <span class="cardBadge inline-block bg-purple-50 border border-purple-100 rounded-full px-2.5 py-0.5 text-[9px] font-black uppercase tracking-widest text-purple-700">¿ERES NUEVO?</span>
                            <div>
                                <h3 class="font-black text-slate-900 leading-tight">Crea tu cuenta</h3>
                                <p class="cardSubtitle font-semibold text-slate-500 mt-0.5">y comienza a vender</p>
                            </div>
                            <hr class="cardDivider border-t border-slate-100/80" />
                            <ul>
                                <li class="flex items-center gap-2"><i class="fa-solid fa-circle-check text-purple-600 text-xs"></i> <span id="landing-card-trial-text">Prueba 7 días gratis</span></li>
                                <li class="flex items-center gap-2"><i class="fa-solid fa-circle-check text-purple-600 text-xs"></i> <span id="landing-card-price-text">Plan mensual de Q50</span></li>
                                <li class="flex items-center gap-2"><i class="fa-solid fa-circle-check text-purple-600 text-xs"></i> Sin comisiones por ventas</li>
                                <li class="flex items-center gap-2"><i class="fa-solid fa-circle-check text-purple-600 text-xs"></i> Vende cualquier tipo de producto</li>
                            </ul>
                        </div>
                        <div class="mt-auto space-y-2">
                            <button onclick="mostrarLandingStep('register')" class="w-full text-xs font-black uppercase tracking-wider landing-btn-primary shadow-lg shadow-purple-500/15">
                                Comenzar gratis
                            </button>
                            <p class="text-[10px] font-bold text-slate-400 text-center flex items-center justify-center gap-1.5"><i class="fa-solid fa-lock text-[8px]"></i> Sin tarjeta de crédito</p>
                        </div>
                    </div>

                    {/* Tarjeta Cliente Existente */}
                    <div class="heroActionCard portal flex flex-col justify-between items-stretch">
                        <div>
                            <span class="cardIcon flex shrink-0 items-center justify-center rounded-2xl bg-blue-50 text-blue-600 border border-blue-100/50 shadow-sm text-2xl">
                                <i class="fa-solid fa-user"></i>
                            </span>
                            <span class="cardBadge inline-block bg-blue-50 border border-blue-100 rounded-full px-2.5 py-0.5 text-[9px] font-black uppercase tracking-widest text-blue-700">¿YA TIENES CUENTA?</span>
                            <div>
                                <h3 class="font-black text-slate-900 leading-tight">Ingresa al portal</h3>
                                <p class="cardSubtitle font-semibold text-slate-500 mt-0.5">y gestiona tu negocio</p>
                            </div>
                            <hr class="cardDivider border-t border-slate-100/80" />
                            <ul>
                                <li class="flex items-center gap-2"><i class="fa-solid fa-circle-check text-blue-600 text-xs"></i> Gestiona productos y precios</li>
                                <li class="flex items-center gap-2"><i class="fa-solid fa-circle-check text-blue-600 text-xs"></i> Revisa y responde pedidos</li>
                                <li class="flex items-center gap-2"><i class="fa-solid fa-circle-check text-blue-600 text-xs"></i> Actualiza tu catálogo</li>
