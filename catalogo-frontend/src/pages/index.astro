        function descargarTodosPDFPedidos() {
            const lista = obtenerPedidosFiltrados();
            if (!lista.length) {
                showToast("No hay recibos para descargar", "error");
                return;
            }

            const { jsPDF } = window.jspdf;
            const doc = new jsPDF();

            lista.forEach((ped, index) => {
                if (index > 0) doc.addPage();
                const fecha = new Date(ped.fecha);
                const nroPedido = `PED-${fecha.getFullYear()}${(fecha.getMonth()+1).toString().padStart(2, '0')}${fecha.getDate().toString().padStart(2, '0')}-${ped._id.substring(ped._id.length - 4).toUpperCase()}`;
                dibujarReciboEnPDF(doc, ped.cliente, ped.productos, ped.total, ped.fecha, nroPedido);
            });

            const fechaArchivo = new Date().toISOString().slice(0, 10);
            const cleanTenant = (tenantSlug || "catalogo").replace(/[^a-z0-9-]/gi, "_").toLowerCase();
            doc.save(`recibos_${cleanTenant}_${fechaArchivo}.pdf`);
            showToast(`${lista.length} recibo${lista.length === 1 ? "" : "s"} descargado${lista.length === 1 ? "" : "s"} en un solo PDF`, "success");
        }

        function consolidarProductosPedidos(pedidos) {
            const mapa = new Map();

            pedidos.forEach((pedidoItem) => {
                const clienteNombre = pedidoItem.cliente?.nombre || 'Cliente';
                (pedidoItem.productos || []).forEach((producto) => {
                    const nombre = String(producto.nombre || 'Producto').trim();
                    const unidad = String(producto.unidad || producto.unidadMedida || 'unidad').trim();
                    const precio = Number(producto.precio) || 0;
                    const cantidad = Number(producto.cantidad) || 0;
                    if (!nombre || cantidad <= 0) return;

                    const key = `${nombre.toLowerCase()}|${unidad.toLowerCase()}|${precio.toFixed(4)}`;
                    if (!mapa.has(key)) {
                        mapa.set(key, {
                            nombre,
                            unidad,
                            precio,
                            cantidad: 0,
                            subtotal: 0,
                            pedidos: 0,
                            clientes: new Map()
                        });
                    }

                    const item = mapa.get(key);
                    item.cantidad += cantidad;
                    item.subtotal += cantidad * precio;
                    item.pedidos += 1;
                    item.clientes.set(clienteNombre, (item.clientes.get(clienteNombre) || 0) + cantidad);
                });
            });

            return Array.from(mapa.values()).sort((a, b) => a.nombre.localeCompare(b.nombre, 'es'));
        }

        function descargarResumenPreparacion() {
            const modo = document.getElementById('pedidos-agrupar-modo')?.value || 'selected';
            const lista = obtenerPedidosParaAgrupar();
            if (!lista.length) {
                const mensaje = modo === 'selected'
                    ? "Selecciona al menos un pedido para agrupar"
                    : "No hay pedidos en el periodo seleccionado";
                showToast(mensaje, "error");
                return;
            }

            const resumen = consolidarProductosPedidos(lista);
            if (!resumen.length) {
                showToast("No hay productos para resumir", "error");
                return;
            }

            const { jsPDF } = window.jspdf;
            const doc = new jsPDF();
            const pdfColor = obtenerColorPdfActual();
            const fechaGeneracion = new Date();
            const totalGeneral = lista.reduce((acc, pedidoItem) => acc + (Number(pedidoItem.total) || 0), 0);
            const totalUnidades = resumen.reduce((acc, item) => acc + item.cantidad, 0);
            const nombreNegocio = configuracionNegocio.nombreNegocio || document.getElementById('catalog-business-name')?.innerText || tenantSlug;

            doc.setFillColor(pdfColor[0], pdfColor[1], pdfColor[2]);
            doc.rect(0, 0, 210, 34, 'F');
            doc.setTextColor(255, 255, 255);
            doc.setFont("helvetica", "bold");
            doc.setFontSize(17);
            doc.text("PEDIDOS AGRUPADOS", 14, 17);
            doc.setFont("helvetica", "normal");
            doc.setFontSize(9);
            doc.text(String(nombreNegocio).toUpperCase(), 14, 24);
            doc.text(`Generado: ${fechaGeneracion.toLocaleDateString()} ${fechaGeneracion.toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' })}`, 145, 17);
            doc.text(`Pedidos incluidos: ${lista.length}`, 145, 24);

            doc.setTextColor(30, 41, 59);
            doc.setFont("helvetica", "bold");
            doc.setFontSize(11);
            doc.text("Productos consolidados para preparar", 14, 46);
            doc.setFont("helvetica", "normal");
            doc.setFontSize(9);
            doc.setTextColor(100, 116, 139);
            doc.text("Las cantidades se agrupan por producto, unidad y precio para evitar mezclar presentaciones distintas.", 14, 52);

            const filas = resumen.map((item) => {
                const clientes = Array.from(item.clientes.entries())
                    .sort((a, b) => b[1] - a[1])
                    .slice(0, 4)
                    .map(([cliente, cantidad]) => `${cliente}: ${cantidad}`)
                    .join(' | ');
                const clientesExtra = item.clientes.size > 4 ? ` +${item.clientes.size - 4} más` : '';
                return [
                    item.nombre.toUpperCase(),
                    item.cantidad.toFixed(item.cantidad % 1 === 0 ? 0 : 2),
                    item.unidad,
                    `Q${item.precio.toFixed(2)}`,
                    `Q${item.subtotal.toFixed(2)}`,
                    `${item.pedidos}`,
                    `${clientes}${clientesExtra}`
                ];
            });

            doc.autoTable({
                startY: 60,
                head: [['Producto', 'Cantidad', 'Unidad', 'Precio', 'Subtotal', 'Pedidos', 'Clientes']],
                body: filas,
                headStyles: {
                    fillColor: pdfColor,
                    textColor: [255, 255, 255],
                    fontStyle: 'bold',
                    fontSize: 8
                },
                bodyStyles: {
                    textColor: [51, 65, 85],
                    fontSize: 8,
                    valign: 'middle'
                },
                columnStyles: {
                    0: { cellWidth: 38, fontStyle: 'bold' },
                    1: { cellWidth: 18, halign: 'right' },
                    2: { cellWidth: 20 },
                    3: { cellWidth: 18, halign: 'right' },
                    4: { cellWidth: 20, halign: 'right', fontStyle: 'bold' },
                    5: { cellWidth: 15, halign: 'center' },
                    6: { cellWidth: 51, fontSize: 7 }
                },
                alternateRowStyles: {
                    fillColor: [248, 250, 252]
                },
                margin: { left: 14, right: 14 },
                didDrawPage: function(data) {
                    const pageCount = doc.internal.getNumberOfPages();
                    doc.setFontSize(8);
                    doc.setTextColor(148, 163, 184);
                    doc.text(`Pagina ${data.pageNumber} de ${pageCount}`, 180, 288);
                }
            });

            const finalY = doc.lastAutoTable.finalY + 10;
            const necesitaNuevaPagina = finalY > 255;
            if (necesitaNuevaPagina) doc.addPage();
            const resumenY = necesitaNuevaPagina ? 24 : finalY;

            doc.setFillColor(248, 250, 252);
            doc.roundedRect(14, resumenY, 182, 24, 3, 3, 'F');
            doc.setTextColor(30, 41, 59);
            doc.setFont("helvetica", "bold");
            doc.setFontSize(10);
            doc.text(`Total de pedidos: ${lista.length}`, 20, resumenY + 8);
            doc.text(`Productos consolidados: ${resumen.length}`, 20, resumenY + 15);
            doc.text(`Cantidad total: ${totalUnidades.toFixed(totalUnidades % 1 === 0 ? 0 : 2)}`, 95, resumenY + 8);
            doc.text(`Total acumulado: Q${totalGeneral.toFixed(2)}`, 95, resumenY + 15);

            const fechaArchivo = fechaGeneracion.toISOString().slice(0, 10);
            const cleanTenant = (tenantSlug || "catalogo").replace(/[^a-z0-9-]/gi, "_").toLowerCase();
            doc.save(`pedidos_agrupados_${cleanTenant}_${fechaArchivo}.pdf`);
            if (modo === 'selected') {
                pedidosSeleccionados.clear();
                dibujarPedidos();
            }
            showToast("Pedidos agrupados generados en PDF", "success");
        }

