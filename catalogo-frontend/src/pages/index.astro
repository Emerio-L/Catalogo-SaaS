        async function subirComprobantePago(event) {
            event.preventDefault();
            const form = event.currentTarget;
            const submitBtn = form?.querySelector('button[type="submit"]');
            if (form?.dataset.submitting === 'true') return;
            if (form) form.dataset.submitting = 'true';
            const originalSubmit = submitBtn?.innerHTML || '';
            if (submitBtn) {
                submitBtn.disabled = true;
                submitBtn.innerHTML = '<i class="fa-solid fa-circle-notch fa-spin mr-2"></i> Enviando...';
            }
            const file = document.getElementById('payment-receipt-file')?.files?.[0];
            const formData = new FormData();
            if (file) formData.append('receipt', file);
            formData.append('amount', document.getElementById('payment-receipt-amount')?.value || configuracionNegocio.account?.monthlyPrice || 0);
            formData.append('paymentMonth', document.getElementById('payment-receipt-month')?.value || '');
            formData.append('paymentMethod', document.getElementById('payment-receipt-method')?.value || 'Transferencia');
            try {
                const res = await fetch(`${TENANT_API_URL}/admin/payments/receipt`, {
                    method: 'POST',
                    credentials: 'include',
                    body: formData
                });
                const data = await res.json().catch(() => ({}));
                if (!res.ok) {
                    showToast(data.error || 'No se pudo subir el comprobante', 'error');
                    return;
                }
                if (data.account) {
                    configuracionNegocio.account = data.account;
                    actualizarInformacionCuenta(configuracionNegocio.account);
                }
                event.target.reset();
                await cargarHistorialPagosPerfil();
                showToast(file ? 'Comprobante enviado para revision' : 'Pago reportado para revision', 'success');
            } catch (err) {
                showToast('Error de conexion al subir comprobante', 'error');
            } finally {
                if (form) form.dataset.submitting = 'false';
                if (submitBtn) {
                    submitBtn.disabled = false;
                    submitBtn.innerHTML = originalSubmit;
                }
            }
        }

        function paymentStatusClass(status) {
            if (status === 'aprobado') return 'bg-emerald-50 text-emerald-700 ring-emerald-100';
            if (status === 'rechazado') return 'bg-rose-50 text-rose-700 ring-rose-100';
            return 'bg-amber-50 text-amber-700 ring-amber-100';
        }

        async function cargarHistorialPagosPerfil() {
            const list = document.getElementById('payment-history-list');
            if (!list) return;
            try {
                const res = await fetch(`${TENANT_API_URL}/admin/payments`, { credentials: 'include' });
                if (!res.ok) {
                    list.innerHTML = '<p class="rounded-2xl bg-slate-50 p-4 text-center text-xs font-bold text-slate-400">No se pudo cargar el historial.</p>';
                    return;
                }
                const payments = await res.json();
                list.innerHTML = payments.length ? payments.map(payment => {
                    const receiptLink = payment.receiptUrl
                        ? `<a href="${normalizarAssetUrl(payment.receiptUrl)}" target="_blank" rel="noopener" class="text-[11px] font-black uppercase tracking-wider text-primary-600 hover:text-primary-700">Ver comprobante</a>`
                        : '<span class="text-[11px] font-bold text-slate-400">Sin comprobante</span>';
                    return `
                        <div class="rounded-2xl bg-slate-50 p-4 ring-1 ring-slate-100">
                            <div class="flex items-start justify-between gap-3">
                                <div>
                                    <p class="font-black text-slate-900">${formatAccountMoney(payment.amount)} <span class="text-xs text-slate-400">/ ${payment.paymentMonth || 'Sin mes'}</span></p>
                                    <p class="mt-1 text-xs font-semibold text-slate-500">${payment.paymentMethod || 'Metodo no registrado'} - ${formatAccountDate(payment.paidAt || payment.createdAt)}</p>
                                </div>
                                <span class="rounded-full px-2.5 py-1 text-[10px] font-black uppercase tracking-wider ring-1 ${paymentStatusClass(payment.status)}">${payment.status || 'pendiente'}</span>
                            </div>
                            <div class="mt-2">${receiptLink}</div>
                        </div>
                    `;
                }).join('') : '<p class="rounded-2xl bg-slate-50 p-4 text-center text-xs font-bold text-slate-400">Aun no hay pagos reportados.</p>';
            } catch (err) {
                list.innerHTML = '<p class="rounded-2xl bg-slate-50 p-4 text-center text-xs font-bold text-slate-400">Error de conexion al cargar pagos.</p>';
            }
        }

        function normalizarAssetUrl(url = '') {
            if (!url) return '';
            return String(url).startsWith('/') ? `${BACKEND_URL}${url}` : String(url);
        }

        function aplicarLogoShape(shape = 'rectangle') {
            const brandMark = document.getElementById('catalog-brand-mark');
            const safeShape = shape === 'circle' ? 'circle' : 'rectangle';
            if (!brandMark) return;
            brandMark.classList.toggle('rounded-full', safeShape === 'circle');
            brandMark.classList.toggle('rounded-[1.5rem]', safeShape !== 'circle');
        }

        function actualizarPreviewRotacionLogo(rotation) {
            const safeRotation = [0, 90, 180, 270].includes(Number(rotation)) ? Number(rotation) : 0;
            ['catalog-logo', 'perfil-logo-preview', 'perfil-logo-modal-preview'].forEach(id => {
                const image = document.getElementById(id);
                if (image) image.style.transform = `rotate(${safeRotation}deg)`;
            });
        }

        function actualizarLogoCatalogo(
            logo = '',
            shape = configuracionNegocio.logoShape || 'rectangle',
            rotation = configuracionNegocio.logoRotation || 0
        ) {
            const logoUrl = normalizarAssetUrl(logo);
            const catalogLogo = document.getElementById('catalog-logo');
            const catalogFallback = document.getElementById('catalog-logo-fallback');
            const perfilPreview = document.getElementById('perfil-logo-preview');
            const perfilPlaceholder = document.getElementById('perfil-logo-placeholder');
            const modalPreview = document.getElementById('perfil-logo-modal-preview');
            const modalPlaceholder = document.getElementById('perfil-logo-modal-placeholder');
            const shapeSelect = document.getElementById('perfil-logo-shape');
            const rotationSelect = document.getElementById('perfil-logo-rotation');
            const safeRotation = [0, 90, 180, 270].includes(Number(rotation)) ? Number(rotation) : 0;
            aplicarLogoShape(shape);
            if (shapeSelect) shapeSelect.value = shape === 'circle' ? 'circle' : 'rectangle';
            if (rotationSelect) rotationSelect.value = String(safeRotation);
            actualizarPreviewRotacionLogo(safeRotation);
            if (catalogLogo) {
                catalogLogo.src = logoUrl;
                catalogLogo.classList.toggle('hidden', !logoUrl);
            }
            if (catalogFallback) {
                catalogFallback.classList.toggle('hidden', Boolean(logoUrl));
            }
            if (perfilPreview) {
                perfilPreview.src = logoUrl;
                perfilPreview.classList.toggle('hidden', !logoUrl);
            }
            if (perfilPlaceholder) {
                perfilPlaceholder.classList.toggle('hidden', Boolean(logoUrl));
            }
            if (modalPreview) {
                modalPreview.src = logoUrl;
                modalPreview.classList.toggle('hidden', !logoUrl);
            }
            if (modalPlaceholder) {
                modalPlaceholder.classList.toggle('hidden', Boolean(logoUrl));
            }
            const perfilLogoLabel = document.getElementById('perfil-logo-label');
            if (perfilLogoLabel) {
                perfilLogoLabel.innerText = logoUrl ? 'Imagen cargada. Puedes editarla cuando quieras.' : 'Aún no hay imagen cargada.';
            }
            const modalLabel = document.getElementById('perfil-logo-modal-label');
            if (modalLabel) modalLabel.innerText = logoUrl ? 'Cambiar imagen si deseas' : 'Seleccionar o arrastrar imagen';
        }

