        async function recuperarPasswordLanding(e) {
            if (e) e.preventDefault();
            const identifier = document.getElementById('landing-recovery-identifier')?.value.trim();
            const submitBtn = document.getElementById('landing-recovery-submit');
            const devLinkEl = document.getElementById('landing-dev-reset-link');
            mostrarErrorRecoveryLanding('');
            mostrarEstadoRecoveryLanding('');
            if (devLinkEl) {
                devLinkEl.classList.add('hidden');
                devLinkEl.innerHTML = '';
            }
            if (!identifier) {
                mostrarErrorRecoveryLanding('Ingresa tu correo, usuario o número de cuenta.');
                return;
            }

            try {
                if (submitBtn) {
                    submitBtn.disabled = true;
                    submitBtn.classList.add('opacity-70', 'cursor-wait');
                    submitBtn.innerHTML = '<i class="fa-solid fa-circle-notch fa-spin"></i> Enviando enlace';
                }
                const res = await fetch(`${API_URL}/auth/forgot-password`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ identifier })
                });
                const data = await res.json().catch(() => ({}));
                if (!res.ok) {
                    mostrarErrorRecoveryLanding(data.error || 'No se pudo solicitar la recuperación.');
                    return;
                }
                mostrarEstadoRecoveryLanding(
                    `${data.mensaje || 'Solicitud recibida.'} Revisa también la carpeta de spam. Si no llega, contacta a soporte para verificar el correo asociado a la cuenta.`
                );
                document.getElementById('landing-recovery-form')?.classList.add('hidden');
                document.getElementById('landing-recovery-success')?.classList.remove('hidden');
                if (data.devResetUrl && devLinkEl) {
                    devLinkEl.innerHTML = `Modo desarrollo: <a class="text-purple-600 font-black underline" href="${data.devResetUrl}">${data.devResetUrl}</a>`;
                    devLinkEl.classList.remove('hidden');
                }
            } catch (err) {
                mostrarErrorRecoveryLanding('Error de conexión al recuperar contraseña.');
            } finally {
                if (submitBtn) {
                    submitBtn.disabled = false;
                    submitBtn.classList.remove('opacity-70', 'cursor-wait');
                    submitBtn.innerHTML = 'Enviar enlace a tu correo';
                }
            }
        }
        window.recuperarPasswordLanding = recuperarPasswordLanding;

        async function verificarPasswordLanding(e) {
            if (e) e.preventDefault();
            const identifier = document.getElementById("landing-login-identifier").value.trim();
            const password = document.getElementById("landing-login-password").value;
            const submitBtn = document.getElementById('landing-login-submit');

            mostrarErrorLoginLanding('');
            if (!identifier || !password) {
                mostrarErrorLoginLanding("Ingresa tu correo, usuario o número de cuenta y contraseña.");
                return;
            }
            try {
                if (submitBtn) {
                    submitBtn.disabled = true;
                    submitBtn.classList.add('opacity-70', 'cursor-wait');
                    submitBtn.innerHTML = '<i class="fa-solid fa-spinner fa-spin mr-2"></i> Validando...';
                }
                
                const res = await fetch(`${API_URL}/auth/login`, {
                    method: 'POST',
                    credentials: 'include',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ identifier, password })
                });

                const data = await res.json().catch(() => ({}));
                if (res.ok) {
                    const tSlug = data.tenantSlug || data.user?.tenantSlug;
                    const aKey = data.adminAccessKey;
                    
                    if (data.devSessionToken) {
                        sessionStorage.setItem(`catalogo_dev_session_${tSlug}`, data.devSessionToken);
                    }
                    
                    if (data.mustChangePassword || data.mustChangeUsername) {
                        mostrarLandingStep('close');
                        abrirCambioCredencialesObligatorio({
                            tenant: tSlug,
                            accessKey: aKey,
                            changeUsername: data.mustChangeUsername,
                            changePassword: data.mustChangePassword
                        });
                        return;
                    }
                    
                    window.open(`/c/${tSlug}/p/${aKey}`, '_blank');
                    mostrarLandingStep('close');
                } else {
                    mostrarErrorLoginLanding(data.error || "Credenciales inválidas.");
                }
            } catch (err) {
                mostrarErrorLoginLanding("Error de conexión al servidor.");
            } finally {
                if (submitBtn) {
                    submitBtn.disabled = false;
                    submitBtn.classList.remove('opacity-70', 'cursor-wait');
                    submitBtn.innerHTML = '<i class="fa-solid fa-arrow-right-to-bracket"></i> Entrar al panel';
                }
            }
        }
        window.verificarPasswordLanding = verificarPasswordLanding;

        async function registrarCuentaSaasLanding(e) {
