        function verificarInactividadAdmin() {
            if (!isAdminRoute || !adminAutenticado) return;
            const ultimaActividad = Number(sessionStorage.getItem(ADMIN_LAST_ACTIVITY_KEY) || 0);
            if (!ultimaActividad) {
                registrarActividadAdmin();
                return;
            }
            if (Date.now() - ultimaActividad >= ADMIN_IDLE_TIMEOUT_MS) {
                cerrarSesionPorInactividad();
            }
        }

        function iniciarMonitorInactividadAdmin() {
            if (!isAdminRoute) return;
            const eventosActividad = ['click', 'keydown', 'mousemove', 'scroll', 'touchstart'];
            eventosActividad.forEach((evento) => {
                window.addEventListener(evento, registrarActividadAdmin, { passive: true });
            });
            window.addEventListener('focus', verificarInactividadAdmin);
            document.addEventListener('visibilitychange', () => {
                if (!document.hidden) verificarInactividadAdmin();
            });
            setInterval(verificarInactividadAdmin, 60 * 1000);
        }

        cargarConfigSeguridad = async function() {
            try {
                const [settingsRes, meRes] = await Promise.all([
                    fetch(`${TENANT_API_URL}/admin/settings`, { credentials: 'include' }),
                    fetch(`${TENANT_API_URL}/auth/me`, { credentials: 'include' })
                ]);
                if (settingsRes.ok) {
                    const data = await settingsRes.json();
                    const whatsappValue = data.telefonoWhatsApp || data.whatsapp || "50235387468";
                    const settingsWhatsapp = document.getElementById('settings-whatsapp');
                    if (settingsWhatsapp) settingsWhatsapp.value = whatsappValue;
                    const perfilWhatsapp = document.getElementById('perfil-whatsapp-display');
                    if (perfilWhatsapp) perfilWhatsapp.innerText = `+${String(whatsappValue).replace(/\D/g, '').replace(/^(\d{3})(\d{4})(\d+)/, '$1 $2 $3')}`;
                    const perfilWhatsappInput = document.getElementById('perfil-whatsapp-input');
                    if (perfilWhatsappInput) perfilWhatsappInput.value = whatsappValue;
                    const profileName = document.getElementById('perfil-business-name');
                    const profileNameDisplay = document.getElementById('perfil-business-name-display');
                    const logoShape = document.getElementById('perfil-logo-shape');
                    const logoRotation = document.getElementById('perfil-logo-rotation');
                    if (profileName) profileName.value = data.nombreNegocio || '';
                    if (profileNameDisplay) profileNameDisplay.innerText = data.nombreNegocio || 'Nombre del negocio';
                    if (logoShape) logoShape.value = data.logoShape || 'rectangle';
                    if (logoRotation) logoRotation.value = String(data.logoRotation || 0);
                    actualizarTituloCatalogoUI(data.catalogTitle);
                    configuracionNegocio.logo = data.logo || '';
                    configuracionNegocio.logoShape = data.logoShape || 'rectangle';
                    configuracionNegocio.logoRotation = Number(data.logoRotation) || 0;
                    configuracionNegocio.account = data.account || null;
                    configuracionNegocio.orderCartEnabled = data.orderCartEnabled !== false;
                    configuracionNegocio.orderWhatsappEnabled = data.orderWhatsappEnabled !== false;
                    configuracionNegocio.addressRequirement = data.addressRequirement || 'optional';
                    configuracionNegocio.commentRequirement = data.commentRequirement || 'optional';
                    actualizarInformacionCuenta(configuracionNegocio.account);
                    await cargarHistorialPagosPerfil();
                    actualizarLogoCatalogo(configuracionNegocio.logo, configuracionNegocio.logoShape, configuracionNegocio.logoRotation);
                    if (data.tema) {
                        aplicarTema(data.tema);
                        actualizarBotonTemaActivo(data.tema);
                    }
                    if (data.theme) aplicarPaletaTenant(data.theme);
                }
                if (meRes.ok) {
                    const me = await meRes.json();
                    actualizarIdentidadAdmin(me.user || {});
                    const userValue = me.user?.usuario || 'admin';
                    const emailValue = me.user?.email || 'Correo de la cuenta';
                    const settingsUser = document.getElementById('settings-user');
                    const settingsEmail = document.getElementById('settings-email');
                    if (settingsUser) settingsUser.value = userValue;
                    if (settingsEmail) settingsEmail.value = emailValue;
                }
                const currentPasswordEl = document.getElementById('settings-current-password');
                const newPasswordEl = document.getElementById('settings-new-password');
                const confirmPasswordEl = document.getElementById('settings-confirm-password');
                if (currentPasswordEl) currentPasswordEl.value = '';
                if (newPasswordEl) newPasswordEl.value = '';
                if (confirmPasswordEl) confirmPasswordEl.value = '';
            } catch (err) {
                console.error("Error al cargar la configuración de seguridad", err);
            }
        }

