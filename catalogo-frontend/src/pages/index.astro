        window.currentThemeKey = 'emerald';

        function aplicarTema(themeKey) {
            const theme = THEMES[themeKey] || THEMES.emerald;
            for (const [key, val] of Object.entries(theme.vars)) {
                document.documentElement.style.setProperty(key, val);
            }
            window.currentThemeKey = themeKey;
        }

        function hexToRgb(hex) {
            const safe = /^#[0-9A-Fa-f]{6}$/.test(hex || '') ? hex : '#3B82F6';
            const value = safe.replace('#', '');
            return [parseInt(value.slice(0, 2), 16), parseInt(value.slice(2, 4), 16), parseInt(value.slice(4, 6), 16)];
        }

        function normalizarTenantTheme(theme = {}) {
            const base = DEFAULT_TENANT_THEME.colors;
            const inputColors = theme.colors || {};
            const colors = {};
            const selectedInput = /^#[0-9A-Fa-f]{6}$/.test(theme.selectedColor || '') ? theme.selectedColor.toUpperCase() : null;
            Object.keys(base).forEach(key => {
                colors[key] = /^#[0-9A-Fa-f]{6}$/.test(inputColors[key] || '') ? inputColors[key].toUpperCase() : base[key];
            });
            if (!/^#[0-9A-Fa-f]{6}$/.test(inputColors.primary || '') && selectedInput) colors.primary = selectedInput;
            colors.primaryHover = /^#[0-9A-Fa-f]{6}$/.test(colors.primaryHover || '') ? colors.primaryHover : colors.button;
            colors.button = /^#[0-9A-Fa-f]{6}$/.test(colors.button || '') ? colors.button : colors.primary;
            const selectedColor = selectedInput || colors.primary;
            return {
                mode: ['default', 'custom', 'business_suggestion'].includes(theme.mode) ? theme.mode : 'default',
                selectedColor,
                businessCategory: theme.businessCategory || null,
                paletteName: theme.paletteName || DEFAULT_TENANT_THEME.paletteName,
                colors
            };
        }

        function aplicarPaletaTenant(theme = DEFAULT_TENANT_THEME) {
            const normalized = normalizarTenantTheme(theme);
            const c = normalized.colors;
            const root = document.documentElement;
            const headerText = colorTextoSobre(c.primary);
            const headerUsesLightText = headerText === '#FFFFFF';
            root.style.setProperty('--tenant-primary', c.primary);
            root.style.setProperty('--tenant-secondary', c.secondary);
            root.style.setProperty('--tenant-background', c.background);
            root.style.setProperty('--tenant-surface', c.surface);
            root.style.setProperty('--tenant-button', c.button);
            root.style.setProperty('--tenant-text', c.text);
            root.style.setProperty('--tenant-accent', c.accent);
            root.style.setProperty('--tenant-header-text', headerText);
            root.style.setProperty('--tenant-header-muted', headerUsesLightText ? 'rgba(255,255,255,.82)' : 'rgba(15,23,42,.78)');
            root.style.setProperty('--tenant-search-bg', '#FFFFFF');
            root.style.setProperty('--tenant-search-text', '#0F172A');
            root.style.setProperty('--tenant-search-border', 'rgba(15,23,42,.14)');
            root.style.setProperty('--tenant-search-placeholder', 'rgba(51,65,85,.72)');
            root.style.setProperty('--color-primary-50', c.background);
            root.style.setProperty('--color-primary-100', c.secondary);
            root.style.setProperty('--color-primary-200', c.secondary);
            root.style.setProperty('--color-primary-300', c.accent);
            root.style.setProperty('--color-primary-400', c.accent);
            root.style.setProperty('--color-primary-500', c.primary);
            root.style.setProperty('--color-primary-600', c.button);
            root.style.setProperty('--color-primary-700', c.button);
            root.style.setProperty('--color-primary-800', c.surface);
            root.style.setProperty('--color-primary-900', c.surface);
            root.style.setProperty('--color-primary-950', c.background);
            root.style.setProperty('--color-primary-500-rgb', hexToRgb(c.primary).join(', '));
            root.style.setProperty('--color-primary-900-rgb', hexToRgb(c.surface).join(', '));
            configuracionNegocio.theme = normalized;
        }

        function obtenerColorPrincipalActual() {
            const theme = normalizarTenantTheme(configuracionNegocio.theme || DEFAULT_TENANT_THEME);
            return theme.colors.primary || theme.selectedColor || DEFAULT_TENANT_THEME.colors.primary;
        }

        function obtenerColorPdfActual() {
            return hexToRgb(obtenerColorPrincipalActual());
        }

        function actualizarTituloPagina() {
            if (isLandingPage) {
                document.title = "Sedelynk";
                return;
            }
            const nombre = (configuracionNegocio.nombreNegocio || tenantSlug || 'Catálogo').trim();
            document.title = isAdminRoute ? `Panel administrativo - ${nombre}` : `${nombre} - Catálogo`;
        }

        function actualizarBotonTemaActivo(themeKey) {
            document.querySelectorAll("#theme-selector-container button").forEach(btn => {
                btn.classList.remove("ring-4", "ring-offset-2", "ring-slate-900", "scale-110");
            });
            document.querySelectorAll("#extended-theme-palette button").forEach(btn => {
                btn.classList.remove("ring-4", "ring-offset-2", "ring-slate-900", "scale-110");
            });
            const activeBtn = document.getElementById("theme-btn-" + themeKey);
            if (activeBtn) {
                activeBtn.classList.add("ring-4", "ring-offset-2", "ring-slate-900", "scale-110");
            }
        }

        async function guardarTema(themeKey) {
            try {
                const res = await fetch(`${TENANT_API_URL}/admin/settings`, {
                    method: 'PUT',
                    credentials: 'include',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ tema: themeKey })
                });
                if (res.ok) {
                    configuracionNegocio.tema = themeKey;
                    aplicarTema(themeKey);
                    actualizarBotonTemaActivo(themeKey);
                    actualizarPreviewCatalogo();
                    showToast(`Tema ${THEMES[themeKey].name} guardado y aplicado`, "success");
                } else {
                    showToast("Error al intentar guardar el tema", "error");
                }
            } catch (err) {
                showToast("Error al conectar con el servidor", "error");
            }
        }

        /* ===========================
        NOTIFICACIONES (TOASTS)
        =========================== */
        function showToast(mensaje, tipo = 'success') {
            const container = document.getElementById('toast-container');
            if (!container) return;

            const toast = document.createElement('div');
            toast.className = `flex items-center gap-3 px-5 py-4 rounded-2xl shadow-2xl border backdrop-blur-md transform translate-y-3 opacity-0 transition-all duration-300 max-w-sm w-full pointer-events-auto`;
            
            if (tipo === 'success') {
                toast.className += ' bg-emerald-700 border-emerald-400/40 text-white';
                toast.innerHTML = `<div class="w-7 h-7 bg-emerald-500 text-white rounded-lg flex items-center justify-center flex-shrink-0 text-sm"><i class="fa-solid fa-check"></i></div>`;
            } else if (tipo === 'error') {
                toast.className += ' bg-rose-700 border-rose-400/40 text-white';
                toast.innerHTML = `<div class="w-7 h-7 bg-rose-500 text-white rounded-lg flex items-center justify-center flex-shrink-0 text-sm"><i class="fa-solid fa-exclamation"></i></div>`;
            } else {
                toast.className += ' bg-slate-800 border-slate-500/40 text-white';
                toast.innerHTML = `<div class="w-7 h-7 bg-slate-600 text-white rounded-lg flex items-center justify-center flex-shrink-0 text-sm"><i class="fa-solid fa-info"></i></div>`;
            }

            toast.innerHTML += `<span class="text-[11px] font-black uppercase tracking-wider flex-grow">${mensaje}</span>`;

            container.appendChild(toast);

            // Animate in
            setTimeout(() => {
                toast.classList.remove('translate-y-3', 'opacity-0');
            }, 50);

            // Animate out and remove
            setTimeout(() => {
                toast.classList.add('translate-y-3', 'opacity-0');
                setTimeout(() => {
                    toast.remove();
                }, 300);
            }, 3500);
        }

