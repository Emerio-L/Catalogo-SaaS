        const productosCambiandoEstado = new Set();

        async function toggleProductStatus(id, desiredStatus) {
            const productId = String(id || '').trim();
            if (!productId) {
                console.warn('No se puede cambiar estado: producto sin id');
                return;
            }
            if (productosCambiandoEstado.has(productId)) return;
            productosCambiandoEstado.add(productId);
            try {
                const res = await fetch(`${TENANT_API_URL}/admin/products/${encodeURIComponent(productId)}/toggle`, {
                    method: 'PATCH',
                    credentials: 'include',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ activo: Boolean(desiredStatus) })
                });
                if (res.ok) {
                    const data = await res.json();
                    if (String(data.id || '') !== productId) {
                        throw new Error('El servidor actualizo un producto distinto');
                    }
                    adminProductos = adminProductos.map(producto => (
                        getProductId(producto) === String(data.id)
                            ? { ...producto, activo: data.activo }
                            : producto
                    ));
                    dibujarAdmin();
                    showToast(data.activo ? 'Producto activado' : 'Producto desactivado', 'success');
                    await cargarDesdeAPI();
                } else {
                    throw new Error('Error al cambiar el estado');
                }
            } catch (err) {
                console.error(err);
                showToast("No se pudo cambiar el estado del producto", "error");
            } finally {
                productosCambiandoEstado.delete(productId);
            }
        }
        window.toggleProductStatus = toggleProductStatus;
        window.toggleActivo = toggleProductStatus;

        function validarImagenParaSubir(file) {
            if (!file) return '';
            const allowedTypes = ['image/jpeg', 'image/png', 'image/webp', 'image/gif', 'image/avif'];
            if (!allowedTypes.includes(file.type)) {
                return 'Usa una imagen JPG, PNG, WEBP, GIF o AVIF';
            }
            if (file.size > 5 * 1024 * 1024) {
                return 'La imagen no puede superar 5 MB';
            }
            return '';
        }

