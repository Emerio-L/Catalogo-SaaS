    <!-- MODAL AUTENTICACION ADMIN V2 -->
    <!-- MODAL AUTENTICACION ADMIN V2 (Nuevo diseño unificado sin columna lateral) -->
    <div id="modal-admin-auth-v2" class={`fixed inset-0 bg-slate-950/70 backdrop-blur-sm z-[70] flex items-center justify-center p-4 transition-all duration-300 ${isAdminInitialRoute ? '' : 'hidden'}`}>
        <div class={`w-full max-w-lg rounded-[2rem] border border-slate-200 bg-white p-6 md:p-8 shadow-2xl relative max-h-[calc(100vh-2rem)] overflow-y-auto transform transition-all duration-300 ${isAdminInitialRoute ? '' : 'scale-95 opacity-0'}`}>
            <button onclick="cerrarAuthModal()" class="absolute right-4 top-4 flex h-9 w-9 items-center justify-center rounded-full bg-slate-50 text-slate-400 transition hover:bg-slate-100 hover:text-slate-700" aria-label="Cerrar modal">
                <i class="fa-solid fa-xmark text-lg"></i>
            </button>

            {/* LOGIN STEP */}
            <div id="auth2-login-step" class="w-full space-y-6">
                <div class="text-center md:text-left">
                    <div class="mx-auto mb-4 flex h-14 w-14 items-center justify-center rounded-2xl bg-slate-900 text-white shadow-lg md:mx-0">
                        <i class="fa-solid fa-user-check text-xl"></i>
                    </div>
                    <p class="text-[10px] font-black uppercase tracking-[0.24em] text-purple-600">Ingresar a tu cuenta</p>
