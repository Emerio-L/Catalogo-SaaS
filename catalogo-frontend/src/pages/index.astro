        let paletteTabActiva = 'current';
        let paletteDraft = null;

        function esHexValido(color) {
            return /^#[0-9A-Fa-f]{6}$/.test(color || '');
        }

        function rgbToHex([r, g, b]) {
            return `#${[r, g, b].map(v => Math.max(0, Math.min(255, Math.round(v))).toString(16).padStart(2, '0')).join('')}`.toUpperCase();
        }

        function mezclarHex(color, destino, peso) {
            const a = hexToRgb(color);
            const b = hexToRgb(destino);
            return rgbToHex(a.map((v, i) => v + (b[i] - v) * peso));
        }

        function colorTextoSobre(color) {
            const [r, g, b] = hexToRgb(color);
            const luminancia = (0.299 * r + 0.587 * g + 0.114 * b) / 255;
            return luminancia > 0.66 ? '#0F172A' : '#FFFFFF';
        }

        function generarColoresDesdePrincipal(primary, overrides = {}) {
            const safePrimary = esHexValido(primary) ? primary.toUpperCase() : DEFAULT_TENANT_THEME.colors.primary;
            return {
                primary: safePrimary,
                primaryHover: overrides.primaryHover || mezclarHex(safePrimary, '#000000', 0.18),
                secondary: overrides.secondary || mezclarHex(safePrimary, '#FFFFFF', 0.72),
                background: overrides.background || mezclarHex(safePrimary, '#FFFFFF', 0.94),
                surface: overrides.surface || '#FFFFFF',
                button: overrides.button || safePrimary,
                text: overrides.text || '#0F172A',
                accent: overrides.accent || mezclarHex(safePrimary, '#FFFFFF', 0.35),
                success: '#22C55E',
                warning: '#F59E0B',
                error: '#EF4444'
            };
        }

        function completarColores(colors = {}) {
            const primary = esHexValido(colors.primary) ? colors.primary.toUpperCase() : DEFAULT_TENANT_THEME.colors.primary;
            const generated = generarColoresDesdePrincipal(primary, colors);
            return { ...generated, ...colors, primary, button: colors.button || primary };
        }

        function crearThemeDesdeColor(primary, mode = 'default', extra = {}) {
            const colors = completarColores({ primary });
            return normalizarTenantTheme({
                mode,
                selectedColor: colors.primary,
                businessCategory: extra.businessCategory || null,
                paletteName: extra.paletteName || 'Color seleccionado',
                colors: { ...colors, ...(extra.colors || {}) }
            });
        }

        function cambiarTabPaleta(tab) {
            paletteTabActiva = ['current', 'custom', 'business'].includes(tab) ? tab : 'current';
            renderPaletaColores();
        }

        function setPaletteDraft(theme) {
            paletteDraft = normalizarTenantTheme(theme);
            aplicarPaletaTenant(paletteDraft);
            actualizarPreviewCatalogo();
            renderPaletaColores();
            mostrarModalCambiosColor();
        }

        function mostrarModalCambiosColor() {
            const modal = document.getElementById('modal-color-pendiente');
            if (!modal) return;
            modal.classList.remove('hidden');
            modal.classList.add('flex');
        }

        function cerrarModalCambiosColor() {
            const modal = document.getElementById('modal-color-pendiente');
            if (!modal) return;
            modal.classList.add('hidden');
            modal.classList.remove('flex');
        }

        function cancelarCambiosColor() {
            paletteDraft = normalizarTenantTheme(configuracionNegocio.theme || DEFAULT_TENANT_THEME);
            aplicarPaletaTenant(paletteDraft);
            renderPaletaColores();
            cerrarModalCambiosColor();
        }

        function seleccionarColorPredefinido(color, label) {
            if (!esHexValido(color)) return;
            setPaletteDraft(crearThemeDesdeColor(color, 'default', { paletteName: label || 'Color actual' }));
        }

        function seleccionarColorPersonalizado(color) {
            if (!esHexValido(color)) return;
            setPaletteDraft(crearThemeDesdeColor(color, 'custom', { paletteName: 'Color personalizado' }));
        }

        function seleccionarPaletaNegocio(index) {
            const item = BUSINESS_PALETTES[index];
            if (!item) return;
            const colors = completarColores(item.colors);
            setPaletteDraft(normalizarTenantTheme({
                mode: 'business_suggestion',
                selectedColor: colors.primary,
                businessCategory: item.name,
                paletteName: item.name,
                colors
            }));
        }

