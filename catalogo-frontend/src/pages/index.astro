            const form = document.getElementById('landing-register-step')?.querySelector('form');
            const submitBtn = document.getElementById('landing-register-submit');
            const resultEl = document.getElementById('landing-register-result');
            if (resultEl) {
                resultEl.classList.add('hidden');
                resultEl.innerHTML = '';
            }
            const payload = {
                nombre: document.getElementById('landing-register-name')?.value.trim(),
                whatsapp: document.getElementById('landing-register-whatsapp')?.value.trim(),
                usuario: document.getElementById('landing-register-user')?.value.trim(),
                email: document.getElementById('landing-register-email')?.value.trim(),
                password: document.getElementById('landing-register-password')?.value,
                tipoNegocio: document.getElementById('landing-register-type')?.value || 'personalizado'
            };

            mostrarErrorRegistroLanding('');
            if (!payload.nombre || !payload.whatsapp || !payload.usuario || !payload.email || !payload.password) {
                mostrarErrorRegistroLanding('Completa los campos requeridos para crear la cuenta.');
