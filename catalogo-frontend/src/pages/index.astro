    <button id="support-floating-button" type="button" onclick="openSupportModal()" class="fixed bottom-[18px] right-[18px] z-[90] hidden items-center gap-2 rounded-full bg-[#7C3AED] px-4 py-3 text-sm font-black text-white shadow-[0_18px_40px_rgba(124,58,237,0.35)] transition hover:bg-[#6D28D9] md:bottom-7 md:right-7 md:px-[22px] md:py-[14px]">
