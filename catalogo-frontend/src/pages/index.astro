        function update(id, delta) {
            pedido[id] = Math.max(0, (pedido[id] || 0) + delta);
            
            const span = document.getElementById(`cant-${id}`);
            if (span) span.innerText = pedido[id];

            const card = document.getElementById(`card-${id}`);
            if (card) {
                if (pedido[id] > 0) {
                    card.classList.add("card-active");
                } else {
                    card.classList.remove("card-active");
                }
            }

            recalcular();
        }

        function recalcular() {
            let total = 0;
            productos.forEach(p => {
                if (pedido[p.id]) {
                    total += pedido[p.id] * p.p;
                }
            });
            const totalEl = document.getElementById("total-val");
            if (totalEl) totalEl.innerText = "Q" + total.toFixed(2);
            actualizarMiniCarrito();
        }

