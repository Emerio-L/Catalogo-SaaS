        async function registrarCuentaSaas(e) {
            if (e) e.preventDefault();
            const form = document.getElementById('auth2-register-form');
            if (form?.dataset.submitting === 'true' || form?.dataset.completed === 'true') {
                return;
            }
            if (form) form.dataset.submitting = 'true';
            const submitBtn = document.getElementById('auth2-register-submit');
            const resultEl = document.getElementById('auth2-register-result');
            if (resultEl) {
                resultEl.classList.add('hidden');
                resultEl.innerHTML = '';
            }
            const payload = {
                nombre: document.getElementById('register-business-name')?.value.trim(),
                slug: slugifyClient(document.getElementById('register-slug')?.value.trim()),
                whatsapp: document.getElementById('register-whatsapp')?.value.trim(),
                usuario: document.getElementById('register-user')?.value.trim(),
                email: document.getElementById('register-email')?.value.trim() || undefined,
                password: document.getElementById('register-password')?.value,
                tipoNegocio: document.getElementById('register-business-type')?.value || 'personalizado'
            };

            mostrarErrorRegistro('');
            if (!payload.nombre || !payload.slug || !payload.whatsapp || !payload.usuario || !payload.password) {
                mostrarErrorRegistro('Completa los campos requeridos para crear la cuenta.');
                return;
            }
            if (payload.password.length < 8) {
                mostrarErrorRegistro('La contraseña debe tener al menos 8 caracteres.');
                return;
            }

            try {
                if (submitBtn) {
                    submitBtn.disabled = true;
                    submitBtn.classList.add('opacity-70', 'cursor-wait');
                    submitBtn.innerHTML = '<i class="fa-solid fa-circle-notch fa-spin"></i> Guardando catálogo';
                }
                const res = await fetch(`${API_URL}/tenants/register`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(payload)
                });
                const data = await res.json().catch(() => ({}));
                if (!res.ok) {
                    if (data.existingAccount && data.publicUrl && data.adminUrl) {
                        mostrarErrorRegistro('');
                        mostrarLinksCuenta(data, 'Cuenta encontrada');
                        showToast('La cuenta ya existe. Te mostramos tus enlaces.', 'info');
                        if (form) form.dataset.completed = 'true';
                        return;
                    }
                    const mensaje = data.error || 'No se pudo crear la cuenta.';
                    mostrarErrorRegistro(res.status === 409
                        ? `${mensaje}. Cambia el enlace del catálogo o usa otro nombre para tu negocio.`
                        : mensaje);
                    return;
                }

                mostrarErrorRegistro('');
                mostrarLinksCuenta(data, data.existingAccount ? 'Cuenta encontrada' : 'Cuenta creada correctamente');
                showToast(data.existingAccount ? 'La cuenta ya existe. Te mostramos tus enlaces.' : 'Cuenta creada correctamente', 'success');
                if (form) form.dataset.completed = 'true';
                if (submitBtn) {
                    submitBtn.disabled = true;
                    submitBtn.classList.add('opacity-70');
                    submitBtn.innerHTML = '<i class="fa-solid fa-check"></i> Cuenta creada';
                }
            } catch (err) {
                mostrarErrorRegistro('Error de conexión al crear cuenta.');
            } finally {
                if (submitBtn && !resultEl?.classList.contains('hidden')) {
                    return;
                }
                if (submitBtn) {
                    submitBtn.disabled = false;
                    submitBtn.classList.remove('opacity-70', 'cursor-wait');
                    submitBtn.innerHTML = '<i class="fa-solid fa-store"></i> Guardar y crear catálogo';
                }
                if (form) form.dataset.submitting = 'false';
            }
        }
        window.registrarCuentaSaas = registrarCuentaSaas;

