        guardarConfigSeguridad = async function(e) {
            if (e) e.preventDefault();
            const telefonoWhatsApp = document.getElementById('settings-whatsapp').value.trim();
            const currentPassword = document.getElementById('settings-current-password').value;
            const newPassword = document.getElementById('settings-new-password').value;
            const confirmPassword = document.getElementById('settings-confirm-password').value;

            if (telefonoWhatsApp === "") {
                showToast("El número de WhatsApp no puede estar vacío", "error");
                return;
            }
            if ((currentPassword || newPassword || confirmPassword) && (!currentPassword || !newPassword || !confirmPassword)) {
                showToast("Completa los tres campos para cambiar contraseña", "error");
                return;
            }
            if (newPassword && newPassword !== confirmPassword) {
                showToast("Las contraseñas nuevas no coinciden", "error");
                return;
            }
            if (newPassword && newPassword.length < 8) {
                showToast("La nueva contraseña debe tener al menos 8 caracteres", "error");
                return;
            }

            try {
                const settingsRes = await fetch(`${TENANT_API_URL}/admin/settings`, {
                    method: 'PUT',
                    credentials: 'include',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ telefonoWhatsApp })
                });
                if (!settingsRes.ok) {
                    showToast("Error al guardar WhatsApp", "error");
                    return;
                }

                if (newPassword) {
                    const passwordRes = await fetch(`${TENANT_API_URL}/auth/password`, {
                        method: 'PUT',
                        credentials: 'include',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ currentPassword, newPassword })
                    });
                    const passwordData = await passwordRes.json();
                    if (!passwordRes.ok) {
                        showToast(passwordData.error || "Error al cambiar contraseña", "error");
                        return;
                    }
                }

                showToast("Seguridad actualizada con éxito", "success");
                cargarConfigSeguridad();
            } catch (err) {
                showToast("Error de conexión al guardar cambios", "error");
            }
        }

        function togglePaletaExtendida() {
            const palette = document.getElementById('extended-theme-palette');
            const label = document.getElementById('more-colors-label');
            const icon = document.getElementById('more-colors-icon');
            if (!palette) return;
            const isHidden = palette.classList.toggle('hidden');
            if (label) label.innerText = isHidden ? 'Ver más colores' : 'Ver menos colores';
            if (icon) {
                icon.classList.toggle('fa-chevron-down', isHidden);
                icon.classList.toggle('fa-chevron-up', !isHidden);
            }
        }

        function cargarAjustesCatalogo() {
            const buscar = document.getElementById('setting-mostrar-buscador');
            const categoriasToggle = document.getElementById('setting-mostrar-categorias');
            const moneda = document.getElementById('setting-moneda-visible');
            const cartEnabled = document.getElementById('setting-order-cart-enabled');
            const whatsappEnabled = document.getElementById('setting-order-whatsapp-enabled');
            const addressRequirement = document.getElementById('setting-address-requirement');
            const commentRequirement = document.getElementById('setting-comment-requirement');
            if (buscar) buscar.checked = configuracionNegocio.mostrarBuscador !== false;
            if (categoriasToggle) categoriasToggle.checked = configuracionNegocio.mostrarCategorias !== false;
            if (moneda) moneda.value = configuracionNegocio.monedaVisible || 'GTQ';
            if (cartEnabled) cartEnabled.checked = configuracionNegocio.orderCartEnabled !== false;
            if (whatsappEnabled) whatsappEnabled.checked = configuracionNegocio.orderWhatsappEnabled !== false;
            if (addressRequirement) addressRequirement.value = configuracionNegocio.addressRequirement || 'optional';
            if (commentRequirement) commentRequirement.value = configuracionNegocio.commentRequirement || 'optional';
            renderPaletaColores();
            actualizarPreviewCatalogo();
        }

        function confirmarCambioMetodoPedido(tipo, input) {
            const cartInput = document.getElementById('setting-order-cart-enabled');
            const whatsappInput = document.getElementById('setting-order-whatsapp-enabled');
            if (!input) return;

            if (!input.checked) {
                const label = tipo === 'cart' ? 'enviar por carrito' : 'enviar por WhatsApp';
                const otherActive = tipo === 'cart' ? whatsappInput?.checked : cartInput?.checked;
                if (!otherActive) {
                    input.checked = true;
                    showToast('Debes mantener al menos una forma de recibir pedidos activa.', 'warning');
                    return;
                }
                const ok = confirm(`Vas a desactivar ${label}. Tus clientes dejarán de ver esa opción al confirmar pedidos. ¿Deseas continuar?`);
                if (!ok) input.checked = true;
            }
        }
        window.confirmarCambioMetodoPedido = confirmarCambioMetodoPedido;

        function actualizarPreviewCatalogo() {
            const nombre = document.getElementById('preview-business-name');
            const descripcion = document.getElementById('preview-business-description');
            const search = document.getElementById('preview-search');
            const cats = document.getElementById('preview-categories');
            if (nombre) nombre.innerText = configuracionNegocio.nombreNegocio || 'Catálogo de Productos';
            if (descripcion) {
                descripcion.innerText = configuracionNegocio.descripcionNegocio || 'Selecciona tus productos y confirma tu pedido';
                descripcion.classList.remove('hidden');
            }
            if (search) search.classList.toggle('hidden', document.getElementById('setting-mostrar-buscador')?.checked === false);
            if (cats) cats.classList.toggle('hidden', document.getElementById('setting-mostrar-categorias')?.checked === false);
        }

        async function guardarPreferenciasCatalogo() {
            const payload = {
                mostrarBuscador: document.getElementById('setting-mostrar-buscador')?.checked === true,
                mostrarCategorias: document.getElementById('setting-mostrar-categorias')?.checked === true,
                vistaPredeterminada: configuracionNegocio.vistaPredeterminada || 'grid',
                monedaVisible: document.getElementById('setting-moneda-visible')?.value || 'GTQ',
                orderCartEnabled: document.getElementById('setting-order-cart-enabled')?.checked !== false,
                orderWhatsappEnabled: document.getElementById('setting-order-whatsapp-enabled')?.checked !== false,
                addressRequirement: document.getElementById('setting-address-requirement')?.value || 'optional',
                commentRequirement: document.getElementById('setting-comment-requirement')?.value || 'optional'
            };
            if (!payload.orderCartEnabled && !payload.orderWhatsappEnabled) {
                showToast('Activa al menos una forma de recibir pedidos.', 'warning');
                return;
            }
            try {
                const res = await fetch(`${TENANT_API_URL}/admin/settings`, {
                    method: 'PUT',
                    credentials: 'include',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(payload)
                });
                const data = await res.json().catch(() => ({}));
                if (!res.ok) throw new Error(data.error || 'Error al guardar preferencias');
                const savedSettings = data.settings || payload;
                configuracionNegocio = { ...configuracionNegocio, ...savedSettings };
                showToast("Ajustes del catálogo guardados", "success");
                actualizarCheckoutOpciones();
                cargarAjustesCatalogo();
                renderCategorias();
            } catch (err) {
                console.error(err);
                showToast(err.message || "Error al guardar ajustes", "error");
            }
        }

        /* ===========================
        MODALES ACCIONES
        =========================== */
        function itemsPedidoActual() {
            return productos
                .filter(p => (pedido[p.id] || 0) > 0)
                .map(p => ({
                    ...p,
                    cantidad: pedido[p.id] || 0,
                    subtotal: (pedido[p.id] || 0) * p.p
                }));
        }

        function obtenerTotalesPedido() {
            const items = itemsPedidoActual();
            const subtotal = items.reduce((acc, item) => acc + item.subtotal, 0);
            return {
                items,
                cantidad: items.reduce((acc, item) => acc + item.cantidad, 0),
                subtotal,
                total: subtotal
            };
        }

        function textoArticulos(cantidad) {
            return `${cantidad} articulo${cantidad === 1 ? '' : 's'}`;
        }

        function actualizarMiniCarrito() {
            const { cantidad, total } = obtenerTotalesPedido();
            const totalText = `Q${total.toFixed(2)}`;
            const totalEl = document.getElementById("total-val");
            const badgeEl = document.getElementById("floating-cart-badge");
            const countEl = document.getElementById("mini-cart-count");
            if (totalEl) totalEl.innerText = totalText;
            if (badgeEl) badgeEl.innerText = cantidad;
            if (countEl) countEl.innerText = textoArticulos(cantidad);
        }

