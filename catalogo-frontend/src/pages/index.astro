    <script is:inline>
        /* ===========================
        CONFIGURACION Y VARIABLES
        =========================== */
        // Configuración dinámica del servidor de API.
        const CONFIGURED_BACKEND_URL = String(window.__PUBLIC_BACKEND_URL__ || '').replace(/\/$/, '');
        const BACKEND_URL = CONFIGURED_BACKEND_URL || window.location.origin;
        const API_URL = '/api';
        
        let saasSupportSettings = {
            supportWhatsapp: '',
            supportMessage: 'Hola, necesito ayuda con mi catalogo.',
            emulatorUrl: '',
            emulatorEnabled: false,
            logoUrl: ''
        };

        function normalizarAssetUrl(url) {
            if (!url) return '';
            if (url.startsWith('http://') || url.startsWith('https://') || url.startsWith('data:')) {
                return url;
            }
            const backend = (window.__PUBLIC_BACKEND_URL__ || window.location.origin).replace(/\/$/, '');
            return `${backend}/${url.replace(/^\//, '')}`;
        }

        /* ===========================
        NOTIFICACIONES (TOASTS)
        =========================== */
        function showToast(mensaje, tipo = 'success') {
            const container = document.getElementById('toast-container');
            if (!container) return;

            const toast = document.createElement('div');
            toast.className = `flex items-center gap-3 px-5 py-4 rounded-2xl shadow-2xl border backdrop-blur-md transform translate-y-3 opacity-0 transition-all duration-300 max-w-sm w-full pointer-events-auto`;
            
            if (tipo === 'success') {
                toast.className += ' bg-emerald-700 border-emerald-400/40 text-white';
                toast.innerHTML = `<div class="w-7 h-7 bg-emerald-500 text-white rounded-lg flex items-center justify-center flex-shrink-0 text-sm"><i class="fa-solid fa-check"></i></div>`;
            } else if (tipo === 'error') {
                toast.className += ' bg-rose-700 border-rose-400/40 text-white';
                toast.innerHTML = `<div class="w-7 h-7 bg-rose-500 text-white rounded-lg flex items-center justify-center flex-shrink-0 text-sm"><i class="fa-solid fa-exclamation"></i></div>`;
            } else {
                toast.className += ' bg-slate-800 border-slate-500/40 text-white';
                toast.innerHTML = `<div class="w-7 h-7 bg-slate-600 text-white rounded-lg flex items-center justify-center flex-shrink-0 text-sm"><i class="fa-solid fa-info"></i></div>`;
            }

            toast.innerHTML += `<span class="text-[11px] font-black uppercase tracking-wider flex-grow">${mensaje}</span>`;

            container.appendChild(toast);

            // Animate in
            setTimeout(() => {
                toast.classList.remove('translate-y-3', 'opacity-0');
            }, 50);

            // Animate out and remove
            setTimeout(() => {
                toast.classList.add('translate-y-3', 'opacity-0');
                setTimeout(() => {
                    toast.remove();
                }, 300);
            }, 4000);
        }
        window.showToast = showToast;

        /* ===========================
        LANDING PAGE & SUPPORT HANDLERS
        =========================== */
        function mostrarLandingStep(step) {
            const modal = document.getElementById('landing-auth-modal');
            const login = document.getElementById('landing-login-step');
            const recovery = document.getElementById('landing-recovery-step');
            const register = document.getElementById('landing-register-step');
            
            if (step === 'close' || step === 'portal') {
                if (modal) {
                    modal.classList.add('hidden');
                    modal.classList.remove('flex');
                }
                return;
            }

            if (modal) {
                modal.classList.remove('hidden');
                modal.classList.add('flex');
            }

            if (login) login.classList.toggle('hidden', step !== 'login');
            if (recovery) recovery.classList.toggle('hidden', step !== 'recovery');
            if (register) register.classList.toggle('hidden', step !== 'register');

            if (step === 'register') {
                mostrarErrorRegistroLanding('');
                const form = register.querySelector('form');
                const resultEl = document.getElementById('landing-register-result');
                if (form) form.classList.remove('hidden');
                if (resultEl) {
                    resultEl.classList.add('hidden');
                    resultEl.innerHTML = '';
                }
                const nameInput = document.getElementById('landing-register-name');
                if (nameInput) nameInput.focus();
            } else if (step === 'login') {
                mostrarErrorLoginLanding('');
                const identifierInput = document.getElementById('landing-login-identifier');
                if (identifierInput) identifierInput.focus();
            } else if (step === 'recovery') {
                mostrarErrorRecoveryLanding('');
                mostrarEstadoRecoveryLanding('');
                const recoveryForm = document.getElementById('landing-recovery-form');
                const recoverySuccess = document.getElementById('landing-recovery-success');
                if (recoveryForm) recoveryForm.classList.remove('hidden');
                if (recoverySuccess) recoverySuccess.classList.add('hidden');
                const devLinkEl = document.getElementById('landing-dev-reset-link');
                if (devLinkEl) {
                    devLinkEl.classList.add('hidden');
                    devLinkEl.innerHTML = '';
                }
                const identifierInput = document.getElementById('landing-recovery-identifier');
                if (identifierInput) identifierInput.focus();
            }
        }
        window.mostrarLandingStep = mostrarLandingStep;

        function openSupportModal() {
            const modal = document.getElementById('support-modal');
            const feedback = document.getElementById('support-form-message');
            if (feedback) {
                feedback.textContent = '';
                feedback.className = 'mt-4 hidden rounded-2xl px-4 py-3 text-sm font-bold';
            }
            modal?.classList.remove('hidden');
            modal?.classList.add('flex');
            document.getElementById('support-name')?.focus();
        }
        window.openSupportModal = openSupportModal;

        function closeSupportModal() {
            const modal = document.getElementById('support-modal');
            modal?.classList.add('hidden');
            modal?.classList.remove('flex');
        }
        window.closeSupportModal = closeSupportModal;

        async function submitSupportTicket(event) {
            event.preventDefault();
            const form = event.currentTarget;
            const submit = document.getElementById('support-submit');
            const feedback = document.getElementById('support-form-message');
            if (!form || form.dataset.submitting === 'true') return;
            form.dataset.submitting = 'true';
            const payload = {
                name: document.getElementById('support-name')?.value.trim(),
                email: document.getElementById('support-email')?.value.trim(),
                whatsapp: document.getElementById('support-whatsapp')?.value.trim(),
                message: document.getElementById('support-message')?.value.trim()
            };
            try {
                submit.disabled = true;
                submit.textContent = 'Enviando...';
                const requestOptions = {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(payload)
                };
                let response = await fetch(`${API_URL}/support/tickets`, requestOptions);
                if (response.status === 502 && CONFIGURED_BACKEND_URL) {
                    response = await fetch(`${CONFIGURED_BACKEND_URL}/api/support/tickets`, requestOptions);
                }
                const data = await response.json().catch(() => ({}));
                feedback.textContent = data.message || data.error || 'No se pudo enviar la solicitud.';
                feedback.className = `mt-4 rounded-2xl px-4 py-3 text-sm font-bold text-white ${response.ok ? 'bg-emerald-700' : 'bg-rose-700'}`;
                if (response.ok) {
                    form.reset();
                    setTimeout(closeSupportModal, 30000);
                }
            } catch (error) {
                if (CONFIGURED_BACKEND_URL) {
                    try {
                        const response = await fetch(`${CONFIGURED_BACKEND_URL}/api/support/tickets`, {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify(payload)
                        });
                        const data = await response.json().catch(() => ({}));
                        feedback.textContent = data.message || data.error || 'No se pudo enviar la solicitud.';
                        feedback.className = `mt-4 rounded-2xl px-4 py-3 text-sm font-bold ${response.ok ? 'bg-emerald-700 text-white' : 'bg-rose-700 text-white'}`;
                        if (response.ok) {
                            form.reset();
                            setTimeout(closeSupportModal, 30000);
                        }
                        return;
                    } catch (fallbackError) {
                        console.error('Error conectando con soporte:', fallbackError);
                    }
                }
                feedback.textContent = 'No se pudo conectar con soporte.';
                feedback.className = 'mt-4 rounded-2xl bg-rose-700 px-4 py-3 text-sm font-bold text-white';
            } finally {
                form.dataset.submitting = 'false';
                submit.disabled = false;
                submit.textContent = 'Enviar solicitud';
            }
        }
        window.submitSupportTicket = submitSupportTicket;

        function toggleMobileMenu() {
            const mobileMenu = document.getElementById('mobile-menu');
            if (mobileMenu) {
                mobileMenu.classList.toggle('hidden');
            }
        }
        window.toggleMobileMenu = toggleMobileMenu;

        function mostrarErrorLoginLanding(msg) {
            const el = document.getElementById("landing-login-error");
            if (!el) return;
            el.innerText = msg;
            el.classList.toggle('hidden', !msg);
        }

        function mostrarErrorRegistroLanding(msg) {
            const el = document.getElementById("landing-register-error");
            if (!el) return;
            el.innerText = msg;
            el.classList.toggle('hidden', !msg);
        }

        function mostrarErrorRecoveryLanding(msg) {
            const el = document.getElementById("landing-recovery-error");
            if (!el) return;
            el.innerText = msg;
            el.classList.toggle('hidden', !msg);
        }

        function mostrarEstadoRecoveryLanding(msg, success = false) {
            const el = document.getElementById("landing-recovery-success");
            if (!el) return;
            el.innerText = msg;
            el.classList.toggle('hidden', !msg);
            if (msg) {
                el.className = `rounded-2xl border px-4 py-3 text-xs font-bold ${success ? 'bg-emerald-50 border-emerald-200 text-emerald-800 border-l-4 border-l-emerald-500' : 'bg-rose-50 border-rose-200 text-rose-800 border-l-4 border-l-rose-500'}`;
            }
        }

        async function verificarPasswordLanding(event) {
            if (event) event.preventDefault();
            const identifier = document.getElementById("landing-login-identifier").value.trim();
            const password = document.getElementById("landing-login-password").value;
            const submitBtn = document.getElementById('landing-login-submit');

            mostrarErrorLoginLanding('');
            if (!identifier || !password) {
                mostrarErrorLoginLanding("Ingresa tu correo, usuario o número de cuenta y contraseña.");
                return;
            }
            try {
                if (submitBtn) {
                    submitBtn.disabled = true;
                    submitBtn.classList.add('opacity-70', 'cursor-wait');
                    submitBtn.innerHTML = '<i class="fa-solid fa-spinner fa-spin mr-2"></i> Validando...';
                }
                
                const res = await fetch(`${API_URL}/auth/login`, {
                    method: 'POST',
                    credentials: 'include',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ identifier, password })
                });

                const data = await res.json().catch(() => ({}));
                if (res.ok) {
                    const tSlug = data.tenantSlug || data.user?.tenantSlug;
                    const aKey = data['ad' + 'min' + 'AccessKey'];
                    
                    if (data.devSessionToken) {
                        sessionStorage.setItem(`catalogo_dev_session_${tSlug}`, data.devSessionToken);
                    }
                    
                    if (data.mustChangePassword || data.mustChangeUsername) {
                        mostrarLandingStep('close');
                        abrirCambioCredencialesObligatorio({
                            tenant: tSlug,
                            accessKey: aKey,
                            changeUsername: data.mustChangeUsername,
                            changePassword: data.mustChangePassword
                        });
                        return;
                    }
                    
                    window.open(`/c/${tSlug}/p/${aKey}`, '_blank');
                    mostrarLandingStep('close');
                } else {
                    mostrarErrorLoginLanding(data.error || "Credenciales inválidas.");
                }
            } catch (err) {
                mostrarErrorLoginLanding("Error de conexión al servidor.");
            } finally {
                if (submitBtn) {
                    submitBtn.disabled = false;
                    submitBtn.classList.remove('opacity-70', 'cursor-wait');
                    submitBtn.innerHTML = '<i class="fa-solid fa-arrow-right-to-bracket"></i> Entrar al panel';
                }
            }
        }
        window.verificarPasswordLanding = verificarPasswordLanding;

        function slugifyClient(str) {
            return String(str || '')
                .normalize('NFD')
                .replace(/[\u0300-\u036f]/g, '')
                .toLowerCase()
                .replace(/[^a-z0-9]+/g, '-')
                .replace(/^-+|-+$/g, '');
        }

        async function registrarCuentaSaasLanding(e) {
