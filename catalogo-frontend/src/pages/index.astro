                    <p class="mt-2 text-xs font-semibold text-slate-500">Ingresa tus credenciales registradas para acceder a tu panel de administración.</p>
                </div>

                <form id="auth2-login-form" action="javascript:void(0)" onsubmit="event.preventDefault(); verificarPassword(event); return false;" class="space-y-4">
                    <div id="auth2-login-error" class="hidden rounded-2xl border border-rose-200 bg-rose-50 px-4 py-3 text-xs font-bold text-rose-700 border-l-4 border-l-rose-500"></div>

                    <div>
                        <label class="mb-2 block text-[10px] font-black uppercase tracking-wider text-slate-500">Correo, usuario o número de cuenta</label>
                        <div class="relative">
                            <i class="fa-solid fa-user absolute left-4 top-1/2 -translate-y-1/2 text-slate-400"></i>
                            <input type="text" id="auth2-identifier" placeholder="Tu correo, usuario o número de cuenta" required autocomplete="username"
                            class="w-full rounded-2xl border border-slate-200 bg-slate-50 py-3.5 pl-11 pr-4 text-sm font-bold text-slate-900 outline-none transition-all placeholder:text-slate-400 focus:border-purple-500 focus:bg-white focus:ring-4 focus:ring-purple-500/10">
                        </div>
                    </div>

                    <div>
                        <label class="mb-2 block text-[10px] font-black uppercase tracking-wider text-slate-500">Contraseña</label>
                        <div class="relative">
                            <i class="fa-solid fa-key absolute left-4 top-1/2 -translate-y-1/2 text-slate-400"></i>
                            <input type="password" id="auth2-password" placeholder="Ingresa tu contraseña" required autocomplete="current-password"
                            class="w-full rounded-2xl border border-slate-200 bg-slate-50 py-3.5 pl-11 pr-12 text-sm font-bold text-slate-900 outline-none transition-all placeholder:text-slate-400 focus:border-purple-500 focus:bg-white focus:ring-4 focus:ring-purple-500/10">
                            <button type="button" onclick="togglePasswordVisibility('auth2-password', this)" class="absolute right-3 top-1/2 flex h-9 w-9 -translate-y-1/2 items-center justify-center rounded-xl text-slate-400 transition hover:bg-slate-100 hover:text-slate-700" aria-label="Mostrar contraseña">
                                <i class="fa-solid fa-eye"></i>
                            </button>
                        </div>
                    </div>

                    <button id="auth2-login-submit" type="submit" class="flex w-full items-center justify-center gap-2 rounded-2xl bg-gradient-to-r from-violet-600 to-orange-500 hover:from-violet-500 hover:to-orange-400 active:scale-95 py-4 text-xs font-black uppercase tracking-wider text-white shadow-xl shadow-purple-500/10 transition-all">
                        <i class="fa-solid fa-arrow-right-to-bracket"></i>
                        Entrar al panel
                    </button>
                </form>

                <div class="flex flex-col gap-3 pt-2 text-center border-t border-slate-100">
                    <button type="button" onclick="mostrarAuthStep('recovery')" class="text-xs font-black uppercase text-slate-400 hover:text-purple-600 transition-colors">
                        Olvidé mi contraseña
                    </button>
                    <button type="button" onclick="mostrarRegistroSaas()" class="flex items-center justify-center gap-2 rounded-2xl border border-purple-200 bg-purple-50 px-4 py-3.5 text-xs font-black uppercase tracking-wider text-purple-700 shadow-sm transition hover:-translate-y-0.5 hover:bg-purple-100 hover:shadow-md">
