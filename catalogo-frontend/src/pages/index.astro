            <div id="support-form-message" class="mt-4 hidden rounded-2xl px-4 py-3 text-sm font-bold"></div>
            <div class="mt-5 grid gap-3">
                <input id="support-name" required maxlength="100" placeholder="Nombre" class="rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 text-sm font-bold outline-none focus:border-violet-500 focus:ring-4 focus:ring-violet-500/10">
                <input id="support-email" type="email" maxlength="160" placeholder="Correo (opcional)" class="rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 text-sm font-bold outline-none focus:border-violet-500 focus:ring-4 focus:ring-violet-500/10">
                <input id="support-whatsapp" required maxlength="30" placeholder="WhatsApp" class="rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 text-sm font-bold outline-none focus:border-violet-500 focus:ring-4 focus:ring-violet-500/10">
                <textarea id="support-message" required minlength="10" maxlength="2000" rows="4" placeholder="Mensaje" class="resize-none rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 text-sm font-bold outline-none focus:border-violet-500 focus:ring-4 focus:ring-violet-500/10"></textarea>
                <button id="support-submit" class="rounded-2xl bg-[#7C3AED] px-5 py-4 text-sm font-black text-white transition hover:bg-[#6D28D9]">Enviar solicitud</button>
            </div>
