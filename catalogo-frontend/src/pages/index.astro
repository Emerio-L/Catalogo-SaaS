        async function submitSupportTicket(event) {
            event.preventDefault();
            const form = event.currentTarget;
            const submit = document.getElementById('support-submit');
            const feedback = document.getElementById('support-form-message');
            if (!form || form.dataset.submitting === 'true') return;
            form.dataset.submitting = 'true';
            const payload = {
                name: document.getElementById('support-name')?.value.trim(),
                email: document.getElementById('support-email')?.value.trim(),
                whatsapp: document.getElementById('support-whatsapp')?.value.trim(),
                message: document.getElementById('support-message')?.value.trim()
            };
            try {
                submit.disabled = true;
                submit.textContent = 'Enviando...';
                const requestOptions = {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(payload)
                };
                let response = await fetch(`${API_URL}/support/tickets`, requestOptions);
                if (response.status === 502 && CONFIGURED_BACKEND_URL) {
                    response = await fetch(`${CONFIGURED_BACKEND_URL}/api/support/tickets`, requestOptions);
                }
                const data = await response.json().catch(() => ({}));
                feedback.textContent = data.message || data.error || 'No se pudo enviar la solicitud.';
                feedback.className = `mt-4 rounded-2xl px-4 py-3 text-sm font-bold text-white ${response.ok ? 'bg-emerald-700' : 'bg-rose-700'}`;
                if (response.ok) {
                    form.reset();
                    setTimeout(closeSupportModal, 30000);
                }
            } catch (error) {
                if (CONFIGURED_BACKEND_URL) {
                    try {
                        const response = await fetch(`${CONFIGURED_BACKEND_URL}/api/support/tickets`, {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify(payload)
                        });
                        const data = await response.json().catch(() => ({}));
                        feedback.textContent = data.message || data.error || 'No se pudo enviar la solicitud.';
                        feedback.className = `mt-4 rounded-2xl px-4 py-3 text-sm font-bold ${response.ok ? 'bg-emerald-700 text-white' : 'bg-rose-700 text-white'}`;
                        if (response.ok) {
                            form.reset();
                            setTimeout(closeSupportModal, 30000);
                        }
                        return;
                    } catch (fallbackError) {
                        console.error('Error conectando con soporte:', fallbackError);
                    }
                }
                feedback.textContent = 'No se pudo conectar con soporte.';
                feedback.className = 'mt-4 rounded-2xl bg-rose-700 px-4 py-3 text-sm font-bold text-white';
            } finally {
                form.dataset.submitting = 'false';
                submit.disabled = false;
                submit.textContent = 'Enviar solicitud';
            }
        }
        window.submitSupportTicket = submitSupportTicket;

