        function moverElementoCheckout(event, element) {
            if (window.innerWidth < 768) return;
            if (event.target?.closest?.('button, input, textarea, select, a')) return;
            if (!element) return;
            event.preventDefault();
            const rect = element.getBoundingClientRect();
            const startX = event.clientX;
            const startY = event.clientY;
            const currentX = Number(element.dataset.dragX || 0);
            const currentY = Number(element.dataset.dragY || 0);

            const onMove = (moveEvent) => {
                const nextX = currentX + moveEvent.clientX - startX;
                const nextY = currentY + moveEvent.clientY - startY;
                const maxLeft = 24 - rect.left + currentX;
                const maxRight = window.innerWidth - 24 - rect.right + currentX;
                const maxTop = 24 - rect.top + currentY;
                const maxBottom = window.innerHeight - 24 - rect.bottom + currentY;
                const clampedX = Math.min(maxRight, Math.max(maxLeft, nextX));
                const clampedY = Math.min(maxBottom, Math.max(maxTop, nextY));
                element.dataset.dragX = String(clampedX);
                element.dataset.dragY = String(clampedY);
                element.style.transform = `translate(${clampedX}px, ${clampedY}px)`;
            };

            const onUp = () => {
                window.removeEventListener('pointermove', onMove);
                window.removeEventListener('pointerup', onUp);
            };

            window.addEventListener('pointermove', onMove);
            window.addEventListener('pointerup', onUp, { once: true });
        }

        function iniciarDragCheckout(event) {
            moverElementoCheckout(event, document.getElementById('checkout-panel'));
        }
