    <script is:inline>
        /* ===========================
        CONFIGURACION Y VARIABLES
        =========================== */
        let MI_WHATSAPP = "50235387468";
        
        // Configuración dinámica del servidor de API.
        // PUBLIC_BACKEND_URL apunta al dominio publico del backend en produccion.
        const CONFIGURED_BACKEND_URL = String(window.__PUBLIC_BACKEND_URL__ || '').replace(/\/$/, '');
        const BACKEND_URL = CONFIGURED_BACKEND_URL || window.location.origin;
        const API_URL = '/api';
        const pathParts = window.location.pathname.split('/').filter(Boolean);
        const isLandingPage = window.location.pathname === '/';
        const tenantSlug = pathParts[0] === 'c' && pathParts[1] ? pathParts[1] : 'default';
        const isAdminRoute = pathParts[0] === 'c' && pathParts[2] === 'p' && Boolean(pathParts[3]);
        const isResetRoute = pathParts[0] === 'c' && pathParts[2] === 'reset-password';
        const adminAccessKey = isAdminRoute ? pathParts[3] : '';
        const resetToken = new URLSearchParams(window.location.search).get('token') || '';
        const TENANT_API_URL = `${API_URL}/${tenantSlug}`;
        const DEV_SESSION_KEY = `catalogo_dev_session_${tenantSlug}`;
        const ADMIN_IDLE_TIMEOUT_MS = 2 * 60 * 60 * 1000;
        const ADMIN_LAST_ACTIVITY_KEY = `catalogo_admin_last_activity_${tenantSlug}`;
        const nativeFetch = window.fetch.bind(window);
        window.fetch = (input, init = {}) => {
            const token = sessionStorage.getItem(DEV_SESSION_KEY);
            const url = typeof input === 'string' ? input : input?.url || '';
            const isTenantProtectedRequest = url.startsWith(TENANT_API_URL) && (url.includes('/admin') || url.includes('/auth/'));
            if (!isTenantProtectedRequest) {
                return nativeFetch(input, init);
            }
            const headers = new Headers(init.headers || {});
            if (token && !headers.has('Authorization')) headers.set('Authorization', `Bearer ${token}`);
            return nativeFetch(input, { ...init, headers }).then((response) => {
                const isLoginRequest = url.includes('/auth/login');
                const isLogoutRequest = url.includes('/auth/logout');
                if (response.status === 401 && isAdminRoute && !isLoginRequest && !isLogoutRequest) {
                    cerrarSesionPorInactividad('Tu sesión expiró por seguridad. Ingresa nuevamente.');
                }
                return response;
            });
        };

        let productos = [];
        let adminProductos = [];
        let adminPedidos = [];
        let pedidosSeleccionados = new Set();
        let categorias = [];
        let tabAdminActual = "inventario";
        let adminPaginaActual = 1;
        let adminProductosPorPagina = 10;
        let pedido = {};
        let filtroActual = "todos";
        let productoIdParaEliminar = null;
        let pedidoIdParaEliminar = null;
        let saasSupportSettings = {
            supportWhatsapp: '',
            supportMessage: 'Hola, necesito ayuda con mi catalogo.',
            emulatorUrl: '',
            emulatorEnabled: false,
            logoUrl: ''
        };
        const DEFAULT_TENANT_THEME = {
            mode: 'default',
            selectedColor: '#3B82F6',
            businessCategory: null,
            paletteName: 'Paleta default',
            colors: {
                primary: '#3B82F6',
                primaryHover: '#1D4ED8',
                secondary: '#38BDF8',
                background: '#0B1120',
                surface: '#1E293B',
                button: '#2563EB',
                text: '#F8FAFC',
                accent: '#06B6D4',
                success: '#22C55E',
                warning: '#F59E0B',
                error: '#EF4444'
            }
        };
        let configuracionNegocio = {
            nombreNegocio: 'Catálogo de Productos',
            catalogTitle: 'Catalogo de productos',
            descripcionNegocio: 'Selecciona tus productos y confirma tu pedido',
            logo: '',
            logoShape: 'rectangle',
            logoRotation: 0,
            mostrarBuscador: true,
            mostrarCategorias: true,
            mostrarDescripcion: false,
            vistaPredeterminada: 'grid',
            monedaVisible: 'GTQ',
            orderCartEnabled: true,
            orderWhatsappEnabled: false,
            addressRequirement: 'optional',
            commentRequirement: 'optional',
            account: null,
            theme: DEFAULT_TENANT_THEME
        };

        function formatAccountDate(value) {
            if (!value) return 'Sin fecha';
            return new Intl.DateTimeFormat('es-GT', { day: '2-digit', month: 'long', year: 'numeric' }).format(new Date(value));
        }

        function formatAccountMoney(value) {
            return new Intl.NumberFormat('es-GT', { style: 'currency', currency: 'GTQ' }).format(Number(value || 0));
        }

        function accountStatusClass(status) {
            if (status === 'active') return 'text-emerald-600';
            if (status === 'trial') return 'text-blue-600';
            if (status === 'pending_payment') return 'text-amber-600';
            if (status === 'suspended' || status === 'deleted') return 'text-rose-600';
            return 'text-primary-600';
        }

        function actualizarInformacionCuenta(account = configuracionNegocio.account) {
            const safeAccount = account || {};
            const status = safeAccount.status || '';
            const statusLabel = safeAccount.statusLabel || 'Sin estado';
            const planName = safeAccount.planName || safeAccount.plan?.name || 'Sin plan';
            const setText = (id, value) => {
                const el = document.getElementById(id);
                if (el) el.innerText = value;
            };

            setText('account-number', safeAccount.accountNumber || 'Sin asignar');
            setText('account-plan-name', planName);
            setText('account-period-end', formatAccountDate(safeAccount.currentPeriodEnd));
            setText('account-payment-due', formatAccountDate(safeAccount.paymentDueDate));
            setText('account-monthly-price', formatAccountMoney(safeAccount.monthlyPrice));
            const amountInput = document.getElementById('payment-receipt-amount');
            const monthInput = document.getElementById('payment-receipt-month');
            if (amountInput && !amountInput.value) amountInput.value = Number(safeAccount.monthlyPrice || 0).toFixed(2);
            if (monthInput && !monthInput.value) {
                const sourceDate = safeAccount.currentPeriodEnd ? new Date(safeAccount.currentPeriodEnd) : new Date();
                monthInput.value = `${sourceDate.getFullYear()}-${String(sourceDate.getMonth() + 1).padStart(2, '0')}`;
            }
            const statusEl = document.getElementById('account-status');
            if (statusEl) {
                statusEl.innerText = statusLabel;
                statusEl.className = `text-right ${accountStatusClass(status)}`;
            }

            const warning = document.getElementById('account-warning');
            const warningText = warning?.querySelector('span');
            if (!warning || !warningText) return;
            const showWarning = ['pending_payment', 'suspended', 'trial'].includes(status);
            warning.classList.toggle('hidden', !showWarning);
            warning.classList.toggle('flex', showWarning);
            if (status === 'trial') {
                warningText.innerText = safeAccount.trialEndDate
                    ? `Tu prueba gratis finaliza el ${formatAccountDate(safeAccount.trialEndDate)}.`
                    : 'Tu cuenta esta en prueba gratis.';
                if (typeof window.iniciarTrialCountdown === 'function') {
                    window.iniciarTrialCountdown(safeAccount.trialEndDate);
                }
            } else {
                if (status === 'pending_payment') {
                    warningText.innerText = safeAccount.paymentDueDate
                        ? `Fecha limite de pago: ${formatAccountDate(safeAccount.paymentDueDate)}.`
                        : 'Tu cuenta tiene pago pendiente.';
                } else if (status === 'suspended') {
                    warningText.innerText = 'Tu cuenta esta suspendida. Realiza el pago para reactivar el servicio.';
                }
                const banner = document.getElementById('trial-countdown-banner');
                if (banner) banner.classList.add('hidden');
                if (window.trialCountdownInterval) {
                    clearInterval(window.trialCountdownInterval);
                    window.trialCountdownInterval = null;
                }
            }
        }

