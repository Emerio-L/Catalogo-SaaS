        async function guardarLogoCatalogo() {
            const input = document.getElementById('perfil-logo-input');
            const file = input?.files?.[0];

            try {
                if (file) {
                    const fileError = validarImagenParaSubir(file);
                    if (fileError) {
                        showToast(fileError, 'error');
                        return;
                    }
                    const formData = new FormData();
                    formData.append('logo', file);
                    const res = await fetch(`${TENANT_API_URL}/admin/settings/logo`, {
                        method: 'POST',
                        credentials: 'include',
                        body: formData
                    });
                    const data = await res.json().catch(() => ({}));
                    if (!res.ok) {
                        showToast(data.error || "Error al guardar imagen", "error");
                        return;
                    }
                    configuracionNegocio.logo = data.logo || '';
                    if (input) input.value = '';
                }

                const shapeGuardado = await guardarLogoShapeCatalogo({ silent: true });
                if (!file && !shapeGuardado) return;

                actualizarLogoCatalogo(configuracionNegocio.logo, configuracionNegocio.logoShape);
                cerrarModalImagenCatalogo();
                showToast(file ? "Imagen del catálogo actualizada" : "Forma de la imagen actualizada", "success");
                await cargarConfiguracionPublica();
            } catch (err) {
                console.error('Error subiendo imagen del catálogo:', err);
                showToast('No se pudo conectar con el servidor para subir la imagen', 'error');
            }
        }

        function asignarImagenPerfil(file) {
            if (!file) return false;
            const fileError = validarImagenParaSubir(file);
            if (fileError) {
                showToast(fileError, "error");
                return false;
            }
            const input = document.getElementById('perfil-logo-input');
            const label = document.getElementById('perfil-logo-modal-label');
            const dataTransfer = new DataTransfer();
            dataTransfer.items.add(file);
            input.files = dataTransfer.files;
            if (label) label.innerText = file.name;

            const reader = new FileReader();
            reader.onload = function(e) {
                const preview = document.getElementById('perfil-logo-modal-preview');
                const placeholder = document.getElementById('perfil-logo-modal-placeholder');
                if (preview) {
                    preview.src = e.target.result;
                    preview.classList.remove('hidden');
                }
                if (placeholder) placeholder.classList.add('hidden');
            };
            reader.readAsDataURL(file);
            return true;
        }

