        function openResetCredentialsModal() {
            document.getElementById('reset-creds-usuario').value = '';
            document.getElementById('reset-creds-email').value = '';
            document.getElementById('reset-creds-password').value = '';
            document.getElementById('reset-creds-error').classList.add('hidden');
            document.getElementById('reset-creds-success').classList.add('hidden');
            document.getElementById('reset-creds-modal').classList.remove('hidden');
            document.getElementById('reset-creds-modal').classList.add('flex');
        }
        window.openResetCredentialsModal = openResetCredentialsModal;

        function closeResetCredentialsModal() {
            document.getElementById('reset-creds-modal').classList.add('hidden');
            document.getElementById('reset-creds-modal').classList.remove('flex');
        }
        window.closeResetCredentialsModal = closeResetCredentialsModal;

        async function submitResetCredentials() {
            const newUsuario = document.getElementById('reset-creds-usuario').value.trim();
            const newEmail   = document.getElementById('reset-creds-email').value.trim();
            const newPassword= document.getElementById('reset-creds-password').value;
            const errEl = document.getElementById('reset-creds-error');
            const okEl  = document.getElementById('reset-creds-success');
            errEl.classList.add('hidden');
            okEl.classList.add('hidden');

            if (!newUsuario && !newEmail && !newPassword) {
                errEl.innerText = 'Completa al menos un campo para actualizar.';
                errEl.classList.remove('hidden');
                return;
            }
            const btn = document.getElementById('reset-creds-submit');
            btn.disabled = true;
            btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin mr-1"></i> Actualizando...';

            const payload = {};
            if (newUsuario) payload.newUsuario = newUsuario;
            if (newEmail)   payload.newEmail   = newEmail;
            if (newPassword) payload.newPassword = newPassword;

            const res = await superFetch(`/tenants/${selectedTenantId}/reset-credentials`, {
                method: 'POST',
                body: JSON.stringify(payload)
            });
            const data = await res.json().catch(() => ({}));
            btn.disabled = false;
            btn.innerHTML = '<i class="fa-solid fa-key mr-1"></i> Resetear credenciales';

            if (!res.ok) {
                errEl.innerText = data.error || 'Error al resetear credenciales';
                errEl.classList.remove('hidden');
                return;
            }
            okEl.innerText = '✅ ' + (data.message || 'Credenciales actualizadas. El cliente deberá cambiar su contraseña al ingresar.');
            okEl.classList.remove('hidden');
            document.getElementById('reset-creds-usuario').value = '';
            document.getElementById('reset-creds-email').value = '';
            document.getElementById('reset-creds-password').value = '';
            showSuperToast('Credenciales reseteadas con éxito.', 'success');
        }
        window.submitResetCredentials = submitResetCredentials;

