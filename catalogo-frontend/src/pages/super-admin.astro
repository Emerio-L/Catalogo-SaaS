        async function loadSaasSettings() {
            const res = await superFetch('/settings');
            if (!res.ok) return;
            superSettings = await res.json();
            
            // General settings
            document.getElementById('config-platform-name').value = superSettings.platformName || 'sedelynk';
            document.getElementById('config-currency').value = superSettings.currency || 'GTQ';
            document.getElementById('config-support-email').value = superSettings.supportEmail || 'soporte@sedelynk.com';
            document.getElementById('config-support-url').value = superSettings.supportUrl || 'https://soporte.sedelynk.com';
            document.getElementById('config-timezone').value = superSettings.timezone || 'America/Guatemala';
            document.getElementById('config-favicon-url').value = superSettings.faviconUrl || '';
            document.getElementById('config-support-whatsapp').value = superSettings.supportWhatsapp || '';
            document.getElementById('config-support-message').value = superSettings.supportMessage || '';

            // Landing settings
            document.getElementById('config-landing-title').value = superSettings.landingTitle || 'Vende cualquier producto en línea por';
            document.getElementById('config-landing-subtitle').value = superSettings.landingSubtitle || 'carrito y WhatsApp';
            document.getElementById('config-landing-hero-text').value = superSettings.landingHeroText || '';
            document.getElementById('config-saas-monthly-price').value = superSettings.monthlyPrice !== undefined ? superSettings.monthlyPrice : 50;
            document.getElementById('config-saas-trial-days').value = superSettings.freeTrialDays !== undefined ? superSettings.freeTrialDays : 7;
            document.getElementById('config-saas-logo-alt').value = superSettings.logoAltText || 'SEDELYNK';
            
            const primaryColor = superSettings.primaryColor || '#7C3AED';
            const secondaryColor = superSettings.secondaryColor || '#D946EF';
            const accentColor = superSettings.accentColor || '#FF6B1A';
            
            document.getElementById('config-saas-primary-color').value = primaryColor;
            document.getElementById('config-saas-primary-color-text').innerText = primaryColor.toUpperCase();
            
            document.getElementById('config-saas-secondary-color').value = secondaryColor;
            document.getElementById('config-saas-secondary-color-text').innerText = secondaryColor.toUpperCase();
            
            document.getElementById('config-saas-accent-color').value = accentColor;
            document.getElementById('config-saas-accent-color-text').innerText = accentColor.toUpperCase();
            
            document.getElementById('config-saas-show-price').checked = superSettings.showPrice !== false;

            // Notifications settings
            document.getElementById('notify-emails').checked = superSettings.notificationEmails !== false;
            document.getElementById('notify-reminders').checked = superSettings.notificationPaymentReminders !== false;
            document.getElementById('notify-expirations').checked = superSettings.notificationUpcomingExpirations !== false;
            document.getElementById('notify-welcome').checked = superSettings.notificationWelcomeMessages !== false;

            // Load FAQ
            try {
                faqList = JSON.parse(superSettings.landingFaqs || '[]');
            } catch (e) {
                faqList = [];
            }
            renderFaqs();

            actualizarLogoSaasUI();
        }

        function normalizarAssetUrl(url = '') {
            if (!url) return '';
            return String(url).startsWith('/') ? `${BACKEND_URL}${url}` : String(url);
        }

        function actualizarLogoSaasUI() {
            const logo = normalizarAssetUrl(superSettings?.logoUrl || '');
            const img = document.getElementById('super-sidebar-logo');
            if (img) {
                img.src = logo;
                img.classList.toggle('hidden', !logo);
                img.nextElementSibling?.classList.toggle('hidden', Boolean(logo));
            }
            const brandText = document.getElementById('super-sidebar-brand-name');
            if (brandText && superSettings?.platformName) {
                brandText.innerText = superSettings.platformName;
            }
        }

        function setConfigSubTab(tabName) {
            currentConfigSubTab = tabName;
            document.querySelectorAll('[data-config-tab]').forEach(btn => {
                const isActive = btn.getAttribute('data-config-tab') === tabName;
                btn.classList.toggle('config-sub-tab-active', isActive);
            });
            document.querySelectorAll('.config-panel').forEach(panel => {
                panel.classList.toggle('hidden', panel.id !== `config-panel-${tabName}`);
            });
            if (tabName === 'users') {
                loadSuperAdminUsers();
            }
        }

        function renderFaqs() {
            const container = document.getElementById('faq-list-container');
            if (!container) return;
            if (faqList.length === 0) {
                container.innerHTML = '<p class="text-xs text-slate-500 italic">No hay preguntas frecuentes agregadas.</p>';
                return;
            }
            container.innerHTML = faqList.map((faq, idx) => `
                <div class="faq-item flex flex-col gap-2 rounded-xl border border-white/5 bg-white/5 p-3 relative">
                    <button type="button" onclick="removeFaqItem(${idx})" class="absolute top-2 right-2 text-rose-400 hover:text-rose-300 text-xs">
                        <i class="fa-solid fa-trash-can"></i>
                    </button>
                    <div class="pr-6">
                        <label class="block mb-1">
                            <span class="text-[10px] font-black uppercase text-slate-400">Pregunta</span>
                            <input type="text" oninput="updateFaqItem(${idx}, 'q', this.value)" value="${escapeHtml(faq.q || '')}" class="super-input py-1 text-xs" placeholder="¿Cómo funciona...?">
                        </label>
                        <label class="block">
                            <span class="text-[10px] font-black uppercase text-slate-400">Respuesta</span>
                            <textarea oninput="updateFaqItem(${idx}, 'a', this.value)" class="super-input py-1 text-xs min-h-12" placeholder="Explicación...">${escapeHtml(faq.a || '')}</textarea>
                        </label>
                    </div>
                </div>
            `).join('');
        }

        function escapeHtml(str) {
            return str.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;').replace(/'/g, '&#039;');
        }

        function addFaqItem() {
            faqList.push({ q: '', a: '' });
            renderFaqs();
        }

        function removeFaqItem(idx) {
            faqList.splice(idx, 1);
            renderFaqs();
        }

        function updateFaqItem(idx, field, value) {
            if (faqList[idx]) {
                faqList[idx][field] = value;
            }
        }

        async function patchSettings(payload) {
            const res = await superFetch('/settings', {
                method: 'PATCH',
                body: JSON.stringify(payload)
            });
            if (res.ok) {
                superSettings = await res.json();
                await loadSaasSettings();
                return true;
            } else {
                const data = await res.json().catch(() => ({}));
                alert(data.error || 'Error al guardar configuración');
                return false;
            }
        }

