            const payload = {
                platformName: document.getElementById('config-platform-name').value.trim(),
                currency: document.getElementById('config-currency').value.trim(),
                supportEmail: document.getElementById('config-support-email').value.trim(),
                supportUrl: document.getElementById('config-support-url').value.trim(),
                timezone: document.getElementById('config-timezone').value.trim(),
