            if (document.getElementById('tenant-search-input')) document.getElementById('tenant-search-input').value = '';
            if (document.getElementById('tenant-status-filter')) document.getElementById('tenant-status-filter').value = '';
            if (document.getElementById('tenant-plan-filter')) document.getElementById('tenant-plan-filter').value = '';
            if (document.getElementById('tenant-created-start')) document.getElementById('tenant-created-start').value = '';
            if (document.getElementById('tenant-created-end')) document.getElementById('tenant-created-end').value = '';
            if (document.getElementById('tenant-payment-start')) document.getElementById('tenant-payment-start').value = '';
            if (document.getElementById('tenant-payment-end')) document.getElementById('tenant-payment-end').value = '';
