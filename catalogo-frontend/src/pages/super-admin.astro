            body.innerHTML = superAdminUsers.map(user => {
                const isSelf = currentSuperUser && String(currentSuperUser._id || currentSuperUser.id) === String(user._id || user.id);
                return `
                    <tr class="text-slate-300 text-xs">
                        <td class="px-3 py-3 font-bold text-white">${user.nombre}</td>
                        <td class="px-3 py-3">${user.usuario}</td>
                        <td class="px-3 py-3">${user.email}</td>
                        <td class="px-3 py-3 text-right">
                            ${isSelf 
                                ? '<span class="text-slate-500 font-bold italic">Tú</span>' 
                                : `<button onclick="deleteSuperAdminUser('${user._id || user.id}')" class="text-rose-400 hover:text-rose-300 transition" title="Eliminar"><i class="fa-solid fa-trash-can"></i></button>`
                            }
                        </td>
                    </tr>
                `;
            }).join('');
        }

        async function createSuperAdminUser(event) {
            event.preventDefault();
            const err = document.getElementById('new-user-error');
            const succ = document.getElementById('new-user-success');
            err.classList.add('hidden');
            succ.classList.add('hidden');

            const payload = {
                nombre: document.getElementById('new-user-nombre').value.trim(),
                usuario: document.getElementById('new-user-usuario').value.trim(),
                email: document.getElementById('new-user-email').value.trim(),
                password: document.getElementById('new-user-password').value
            };

            const res = await superFetch('/users', {
                method: 'POST',
                body: JSON.stringify(payload)
            });
            const data = await res.json().catch(() => ({}));
            if (!res.ok) {
                err.innerText = data.error || 'Error al crear usuario';
                err.classList.remove('hidden');
                return;
            }
            succ.innerText = 'Usuario creado con éxito';
            succ.classList.remove('hidden');
            event.target.reset();
            await loadSuperAdminUsers();
        }

        async function deleteSuperAdminUser(id) {
            if (!confirm('¿Está seguro de eliminar a este super administrador?')) return;
            const res = await superFetch(`/users/${id}`, { method: 'DELETE' });
            if (res.ok) {
                await loadSuperAdminUsers();
            } else {
                const data = await res.json().catch(() => ({}));
                alert(data.error || 'Error al eliminar usuario');
            }
        }

        async function changeSuperAdminPassword(event) {
            event.preventDefault();
            const err = document.getElementById('change-pass-error');
            const succ = document.getElementById('change-pass-success');
            err.classList.add('hidden');
            succ.classList.add('hidden');

            const currentPassword = document.getElementById('change-pass-current').value;
            const newPassword = document.getElementById('change-pass-new').value;
            const confirmPassword = document.getElementById('change-pass-confirm').value;

            if (newPassword !== confirmPassword) {
                err.innerText = 'La nueva contraseña y su confirmación no coinciden.';
                err.classList.remove('hidden');
                return;
            }

            if (newPassword.length < 8) {
                err.innerText = 'La nueva contraseña debe tener al menos 8 caracteres.';
                err.classList.remove('hidden');
                return;
            }

            if (!/[A-Z]/.test(newPassword)) {
                err.innerText = 'La nueva contraseña debe incluir al menos una letra mayúscula.';
                err.classList.remove('hidden');
                return;
            }

            if (!/[0-9]/.test(newPassword)) {
                err.innerText = 'La nueva contraseña debe incluir al menos un número.';
                err.classList.remove('hidden');
                return;
            }

            const res = await superFetch('/auth/password', {
                method: 'PUT',
                body: JSON.stringify({ currentPassword, newPassword })
            });
            const data = await res.json().catch(() => ({}));
            if (!res.ok) {
                err.innerText = data.error || 'Error al cambiar la contraseña';
                err.classList.remove('hidden');
                return;
            }

            succ.innerText = 'Contraseña cambiada con éxito. Cerrando sesión...';
            succ.classList.remove('hidden');
            event.target.reset();
            
            setTimeout(async () => {
                await superLogout();
            }, 2500);
        }

        // Setup color picker visual updates
        document.addEventListener('DOMContentLoaded', () => {
            const pColor = document.getElementById('config-saas-primary-color');
            const sColor = document.getElementById('config-saas-secondary-color');
            const aColor = document.getElementById('config-saas-accent-color');
            
            if (pColor) {
                pColor.addEventListener('input', (e) => {
                    const text = document.getElementById('config-saas-primary-color-text');
                    if (text) text.innerText = e.target.value.toUpperCase();
                });
            }
            if (sColor) {
                sColor.addEventListener('input', (e) => {
                    const text = document.getElementById('config-saas-secondary-color-text');
                    if (text) text.innerText = e.target.value.toUpperCase();
                });
            }
            if (aColor) {
                aColor.addEventListener('input', (e) => {
                    const text = document.getElementById('config-saas-accent-color-text');
                    if (text) text.innerText = e.target.value.toUpperCase();
                });
            }
        });

        async function loadSuperData() {
            document.getElementById('super-current-date').innerText = new Intl.DateTimeFormat('es-GT', { day: '2-digit', month: 'long', year: 'numeric' }).format(new Date());
            await Promise.all([loadDashboard(), loadTenants(), loadPayments(), loadPlans(), loadSaasSettings()]);
        }

        async function initSuperAdmin() {
            document.getElementById('super-current-date').innerText = new Intl.DateTimeFormat('es-GT', { day: '2-digit', month: 'long', year: 'numeric' }).format(new Date());
            const res = await superFetch('/auth/me');
            if (!res.ok) return showSuperLogin();
            const data = await res.json();
            currentSuperUser = data.user;
            showSuperApp(data.user);
            await loadSuperData();
        }

        initSuperAdmin();
    </script>
</Layout>
