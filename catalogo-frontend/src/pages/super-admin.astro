        async function saveSaasLandingSettings(event) {
            event.preventDefault();
            const payload = {
                landingTitle: document.getElementById('config-landing-title').value.trim(),
                landingSubtitle: document.getElementById('config-landing-subtitle').value.trim(),
                landingHeroText: document.getElementById('config-landing-hero-text').value.trim(),
                monthlyPrice: Number(document.getElementById('config-saas-monthly-price').value || 0),
                freeTrialDays: Number(document.getElementById('config-saas-trial-days').value || 0),
                logoAltText: document.getElementById('config-saas-logo-alt').value.trim(),
                primaryColor: document.getElementById('config-saas-primary-color').value,
                secondaryColor: document.getElementById('config-saas-secondary-color').value,
                accentColor: document.getElementById('config-saas-accent-color').value,
                showPrice: document.getElementById('config-saas-show-price').checked,
                landingFaqs: JSON.stringify(faqList)
            };

            const res = await superFetch('/settings', {
                method: 'PATCH',
                body: JSON.stringify(payload)
            });
            if (!res.ok) {
                const data = await res.json().catch(() => ({}));
                alert(data.error || 'Error al guardar la configuración de landing');
                return;
            }
            superSettings = await res.json();

            const logoFile = document.getElementById('config-saas-logo-input')?.files?.[0];
            if (logoFile) {
                const formData = new FormData();
                formData.append('logo', logoFile);
                const logoRes = await superFetch('/settings/logo', { method: 'POST', body: formData });
                if (logoRes.ok) superSettings = await logoRes.json();
            }

            const logoInput = document.getElementById('config-saas-logo-input');
            if (logoInput) logoInput.value = '';

            await loadSaasSettings();
            alert('Configuración de Landing Page guardada con éxito');
        }

        async function saveSaasNotificationsSettings(event) {
