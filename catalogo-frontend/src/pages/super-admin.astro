---
import Layout from '../layouts/Layout.astro';

const publicBackendUrl = import.meta.env.PUBLIC_BACKEND_URL || '';
---

<Layout title="Super Admin SaaS">
    <script define:vars={{ publicBackendUrl }}>
        window.__PUBLIC_BACKEND_URL__ = publicBackendUrl;
    </script>

    <main class="min-h-screen bg-[#020816] text-white">
        <div id="super-login" class="flex min-h-screen items-center justify-center px-5">
            <form onsubmit="superLogin(event)" class="w-full max-w-md rounded-[1.75rem] border border-white/10 bg-[#0a1428] p-7 shadow-2xl shadow-black/30">
                <div class="mb-7 flex items-center gap-3">
                    <span class="flex h-12 w-12 items-center justify-center rounded-2xl bg-violet-600 text-xl shadow-lg shadow-violet-950/40">
                        <i class="fa-solid fa-bag-shopping"></i>
                    </span>
                    <div>
                        <h1 class="text-xl font-black">Mi SaaS</h1>
                        <p class="text-sm font-semibold text-slate-400">Panel Super Administrador</p>
                    </div>
                </div>
                <div class="space-y-4">
                    <label class="block">
                        <span class="mb-2 block text-xs font-black uppercase tracking-wider text-slate-400">Usuario o email</span>
                        <input id="super-identifier" class="w-full rounded-2xl border border-white/10 bg-white/5 px-4 py-3 text-sm font-bold outline-none transition focus:border-violet-400 focus:ring-4 focus:ring-violet-500/10" autocomplete="username">
                    </label>
                    <label class="block">
                        <span class="mb-2 block text-xs font-black uppercase tracking-wider text-slate-400">Contraseña</span>
                        <input id="super-password" type="password" class="w-full rounded-2xl border border-white/10 bg-white/5 px-4 py-3 text-sm font-bold outline-none transition focus:border-violet-400 focus:ring-4 focus:ring-violet-500/10" autocomplete="current-password">
                    </label>
                    <p id="super-login-error" class="hidden rounded-2xl border border-rose-500/20 bg-rose-500/10 px-4 py-3 text-sm font-bold text-rose-200"></p>
                    <button class="w-full rounded-2xl bg-violet-600 px-5 py-3 text-sm font-black uppercase tracking-wider text-white shadow-lg shadow-violet-950/40 transition hover:bg-violet-500" type="submit">
                        Entrar al panel
                    </button>
                </div>
            </form>
        </div>
        <div id="super-app" class="hidden min-h-screen lg:flex">
            <aside class="fixed inset-y-0 left-0 z-40 hidden w-64 border-r border-white/8 bg-[#081225] lg:flex lg:flex-col">
                <div class="flex h-full flex-col p-5">
                    <div class="mb-8 flex items-center gap-3">
                        <span class="flex h-12 w-12 items-center justify-center overflow-hidden rounded-2xl bg-[#0b1428] text-xl border border-white/10 shadow-lg">
                            <img id="super-sidebar-logo" src="" alt="Logo SaaS" class="hidden h-full w-full object-contain p-1">
                            <i id="super-sidebar-logo-fallback" class="fa-solid fa-bag-shopping text-violet-500"></i>
                        </span>
                        <div>
                            <p id="super-sidebar-brand-name" class="text-base font-black uppercase tracking-tight">Mi SaaS</p>
                            <p class="text-[10px] font-bold text-slate-400 uppercase tracking-wider">Super User</p>
                        </div>
                    </div>
                    <nav class="space-y-2">
                        <button onclick="setSuperTab('dashboard')" data-super-tab="dashboard" class="super-nav super-nav-active"><i class="fa-solid fa-house"></i><span>Dashboard</span></button>
                        <button onclick="setSuperTab('clientes')" data-super-tab="clientes" class="super-nav"><i class="fa-solid fa-users"></i><span>Clientes</span></button>
                        <button onclick="setSuperTab('pagos')" data-super-tab="pagos" class="super-nav"><i class="fa-solid fa-wallet"></i><span>Pagos</span></button>
                        <button onclick="setSuperTab('planes')" data-super-tab="planes" class="super-nav"><i class="fa-solid fa-calendar-check"></i><span>Planes</span></button>
                        <button onclick="setSuperTab('trash')" data-super-tab="trash" class="super-nav"><i class="fa-solid fa-trash-can"></i><span>Trash</span></button>
                        <button onclick="setSuperTab('configuracion')" data-super-tab="configuracion" class="super-nav"><i class="fa-solid fa-gears"></i><span>Configuración</span></button>
                    </nav>
                    <div class="mt-auto border-t border-white/8 pt-5">
                        <div class="flex items-center gap-3">
                            <span id="super-user-avatar" class="flex h-11 w-11 items-center justify-center rounded-full bg-violet-600 text-sm font-black">S</span>
                            <div class="min-w-0 flex-1">
                                <p id="super-user-name" class="truncate text-sm font-black">Super Admin</p>
                                <p class="text-xs font-semibold text-slate-400">Administrador</p>
                            </div>
                            <button onclick="superLogout()" class="flex h-9 w-9 items-center justify-center rounded-xl text-slate-300 transition hover:bg-white/8 hover:text-white" title="Salir"><i class="fa-solid fa-right-from-bracket"></i></button>
                        </div>
                    </div>
                </div>
            </aside>
 
            <section class="min-h-screen flex-1 px-4 py-5 lg:ml-64 lg:px-9 lg:py-8">
                <div class="mb-7 flex flex-col gap-4 md:flex-row md:items-center md:justify-between">
                    <div>
                        <h2 class="text-3xl font-black tracking-tight md:text-4xl">¡Hola, <span id="super-greeting-name">Admin</span>!</h2>
                        <p class="mt-2 text-sm font-semibold text-slate-400">Resumen general de tu plataforma</p>
                    </div>
                    <div class="inline-flex items-center gap-3 rounded-2xl border border-white/10 bg-white/5 px-4 py-3 text-sm font-black text-slate-200">
                        <i class="fa-regular fa-calendar"></i>
                        <span id="super-current-date"></span>
                    </div>
                </div>
 
                <div class="mb-5 flex gap-2 overflow-x-auto pb-1 lg:hidden">
                    <button onclick="setSuperTab('dashboard')" data-super-mobile-tab="dashboard" class="super-mobile-tab super-mobile-active">Dashboard</button>
                    <button onclick="setSuperTab('clientes')" data-super-mobile-tab="clientes" class="super-mobile-tab">Clientes</button>
                    <button onclick="setSuperTab('pagos')" data-super-mobile-tab="pagos" class="super-mobile-tab">Pagos</button>
                    <button onclick="setSuperTab('planes')" data-super-mobile-tab="planes" class="super-mobile-tab">Planes</button>
                    <button onclick="setSuperTab('trash')" data-super-mobile-tab="trash" class="super-mobile-tab">Trash</button>
                    <button onclick="setSuperTab('configuracion')" data-super-mobile-tab="configuracion" class="super-mobile-tab">Configuración</button>
                </div>

                <section id="super-section-dashboard" class="space-y-5">
                    <div id="super-metrics" class="grid grid-cols-1 gap-5 md:grid-cols-2 lg:grid-cols-4 xl:grid-cols-5"></div>
                </section>

                <section id="super-section-clientes" class="hidden space-y-5">
                    <div class="super-panel">
                        <div class="mb-6 space-y-4">
                            <div class="flex flex-col gap-3 md:flex-row md:items-center md:justify-between">
                                <div>
                                    <h3 class="text-lg font-black text-white">Clientes / Suscriptores</h3>
                                    <p class="text-sm font-semibold text-slate-400">Administra y filtra todos los negocios registrados en la plataforma.</p>
                                </div>
                                <div class="flex flex-wrap gap-2">
                                    <button onclick="exportTenantsCSV()" class="rounded-xl bg-violet-600/20 hover:bg-violet-600/30 text-violet-300 border border-violet-500/30 px-4 py-2.5 text-xs font-black transition flex items-center gap-2">
                                        <i class="fa-solid fa-file-csv text-sm"></i> Exportar CSV
                                    </button>
                                </div>
                            </div>
                            
                            <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-4">
                                <div class="relative">
                                    <span class="absolute inset-y-0 left-3 flex items-center text-slate-500">
                                        <i class="fa-solid fa-magnifying-glass"></i>
                                    </span>
                                    <input id="tenant-search-input" oninput="filterTenants()" type="text" class="super-input pl-9 text-xs" placeholder="Buscar negocio, propietario, email, whatsapp...">
                                </div>
                                <div>
                                    <select id="tenant-status-filter" onchange="filterTenants()" class="super-input text-xs">
                                        <option value="">Todos los estados</option>
                                        <option value="trial">En prueba gratis</option>
                                        <option value="active">Activos</option>
                                        <option value="pending_payment">Pago pendiente</option>
                                        <option value="suspended">Suspendidos</option>
                                    </select>
                                </div>
                                <div>
                                    <select id="tenant-plan-filter" onchange="filterTenants()" class="super-input text-xs">
                                        <option value="">Todos los planes</option>
                                    </select>
                                </div>
                                <div>
                                    <button onclick="resetTenantsFilters()" class="w-full rounded-xl bg-white/5 border border-white/10 hover:bg-white/8 text-slate-300 py-2.5 text-xs font-black transition">
                                        Limpiar filtros
                                    </button>
                                </div>
                            </div>

                            <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-4 border-t border-white/5 pt-3">
                                <div>
                                    <label class="block">
                                        <span class="mb-1 block text-[10px] font-bold text-slate-500 uppercase tracking-wider">Fecha Creación Desde</span>
                                        <input id="tenant-created-start" type="date" onchange="filterTenants()" class="super-input text-xs py-1.5">
                                    </label>
                                </div>
                                <div>
                                    <label class="block">
                                        <span class="mb-1 block text-[10px] font-bold text-slate-500 uppercase tracking-wider">Fecha Creación Hasta</span>
                                        <input id="tenant-created-end" type="date" onchange="filterTenants()" class="super-input text-xs py-1.5">
                                    </label>
                                </div>
                                <div>
                                    <label class="block">
                                        <span class="mb-1 block text-[10px] font-bold text-slate-500 uppercase tracking-wider">Corte / Vence Desde</span>
                                        <input id="tenant-payment-start" type="date" onchange="filterTenants()" class="super-input text-xs py-1.5">
                                    </label>
                                </div>
                                <div>
                                    <label class="block">
                                        <span class="mb-1 block text-[10px] font-bold text-slate-500 uppercase tracking-wider">Corte / Vence Hasta</span>
                                        <input id="tenant-payment-end" type="date" onchange="filterTenants()" class="super-input text-xs py-1.5">
                                    </label>
                                </div>
                            </div>
                        </div>

                        <div class="overflow-x-auto rounded-xl border border-white/8 bg-[#0b1428]">
                            <table class="w-full min-w-[900px] text-left text-sm border-collapse">
                                <thead class="text-xs uppercase tracking-wider text-slate-500 bg-[#081225]">
                                    <tr>
                                        <th class="px-4 py-3">Negocio</th>
                                        <th class="px-4 py-3">Propietario</th>
                                        <th class="px-4 py-3">Contacto</th>
                                        <th class="px-4 py-3">Plan</th>
                                        <th class="px-4 py-3">Estado</th>
                                        <th class="px-4 py-3">Próximo Pago</th>
                                        <th class="px-4 py-3 text-right sticky right-0 bg-[#081225] z-10 shadow-[-4px_0_8px_rgba(0,0,0,0.3)]">Acciones</th>
                                    </tr>
                                </thead>
                                <tbody id="super-tenants-body" class="divide-y divide-white/8"></tbody>
                            </table>
                        </div>
                    </div>
                </section>

                <section id="super-section-trash" class="hidden space-y-5">
                    <div class="super-panel">
                        <div class="mb-4">
                            <h3 class="text-lg font-black">Trash de cuentas eliminadas</h3>
                            <p class="text-sm font-semibold text-slate-400">Las cuentas eliminadas se purgan definitivamente despues de 30 dias.</p>
                        </div>
                        <div id="super-trash-list" class="space-y-3"></div>
                    </div>
                </section>

                <section id="super-section-pagos" class="hidden space-y-5">
                    <div class="super-panel">
                        <div class="mb-4 flex flex-col gap-3 md:flex-row md:items-center md:justify-between">
                            <div>
                                <h3 class="text-lg font-black">Pagos</h3>
                                <p class="text-sm font-semibold text-slate-400">Los comprobantes viven dentro de cada pago.</p>
                            </div>
                            <select id="payment-status-filter" onchange="loadPayments()" class="super-input md:w-52">
                                <option value="">Todos</option>
                                <option value="pendiente">Pendientes</option>
                                <option value="aprobado">Aprobados</option>
                                <option value="rechazado">Rechazados</option>
                            </select>
                        </div>
                        <div id="super-payments-list" class="space-y-3"></div>
                    </div>
                </section>

                <section id="super-section-planes" class="hidden space-y-5">
                    <div class="grid gap-5 xl:grid-cols-[420px_minmax(0,1fr)]">
                        <form onsubmit="createPlan(event)" class="super-panel space-y-4">
                            <div>
                                <h3 class="text-lg font-black">Nuevo plan</h3>
                                <p class="text-sm font-semibold text-slate-400">El precio queda guardado en base de datos.</p>
                            </div>
                            <input id="plan-name" class="super-input" placeholder="Nombre del plan" required>
                            <input id="plan-price" type="number" min="0" step="0.01" class="super-input" placeholder="Precio mensual" required>
                            <div class="grid grid-cols-2 gap-3">
                                <input id="plan-trial-days" type="number" min="0" step="1" class="super-input" placeholder="Días prueba" required>
                                <input id="plan-grace-days" type="number" min="0" step="1" class="super-input" placeholder="Días gracia" required>
                            </div>
                            <input id="plan-product-limit" type="number" min="0" step="1" class="super-input" placeholder="Límite de productos (vacío para ilimitado)">
                            <textarea id="plan-features" class="super-input min-h-24" placeholder="Funciones incluidas, una por línea"></textarea>
                            <button class="rounded-2xl bg-violet-600 px-5 py-3 text-sm font-black uppercase tracking-wider shadow-lg shadow-violet-950/40 transition hover:bg-violet-500">Crear plan</button>
                        </form>
                        <div class="super-panel">
                            <div class="mb-4">
                                <h3 class="text-lg font-black">Planes</h3>
                                <p class="text-sm font-semibold text-slate-400">Activa, desactiva y ajusta precios desde la API.</p>
                            </div>
                            <div id="super-plans-list" class="grid gap-3 md:grid-cols-2"></div>
                        </div>
                    </div>
                </section>

                <section id="super-section-configuracion" class="hidden space-y-5">
                    <div class="grid gap-5 lg:grid-cols-[240px_1fr]">
                        <div class="super-panel flex flex-row flex-wrap gap-2 lg:flex-col lg:items-stretch h-fit">
                            <button onclick="setConfigSubTab('general')" data-config-tab="general" class="config-sub-tab config-sub-tab-active">
                                <i class="fa-solid fa-globe mr-2"></i>General
                            </button>
                            <button onclick="setConfigSubTab('landing')" data-config-tab="landing" class="config-sub-tab">
                                <i class="fa-solid fa-pager mr-2"></i>Landing Page
                            </button>
                            <button onclick="setConfigSubTab('users')" data-config-tab="users" class="config-sub-tab">
                                <i class="fa-solid fa-users-gear mr-2"></i>Usuarios
                            </button>
                            <button onclick="setConfigSubTab('security')" data-config-tab="security" class="config-sub-tab">
                                <i class="fa-solid fa-shield-halved mr-2"></i>Seguridad
                            </button>
                            <button onclick="setConfigSubTab('notifications')" data-config-tab="notifications" class="config-sub-tab">
                                <i class="fa-solid fa-bell mr-2"></i>Notificaciones
                            </button>
                        </div>

                        <div class="space-y-5">
                            <div id="config-panel-general" class="config-panel space-y-5">
                                <form onsubmit="saveSaasGeneralSettings(event)" class="super-panel space-y-4">
                                    <div>
                                        <h3 class="text-lg font-black">Configuración General</h3>
                                        <p class="text-sm font-semibold text-slate-400">Parámetros globales de funcionamiento de la plataforma.</p>
                                    </div>
                                    <div class="grid gap-4 md:grid-cols-2">
                                        <label class="block">
                                            <span class="mb-2 block text-xs font-black uppercase tracking-wider text-slate-500">Nombre de la Plataforma</span>
                                            <input id="config-platform-name" class="super-input" placeholder="sedelynk">
                                        </label>
                                        <label class="block">
                                            <span class="mb-2 block text-xs font-black uppercase tracking-wider text-slate-500">Moneda</span>
                                            <input id="config-currency" class="super-input" placeholder="GTQ">
                                        </label>
                                    </div>
                                    <div class="grid gap-4 md:grid-cols-2">
                                        <label class="block">
                                            <span class="mb-2 block text-xs font-black uppercase tracking-wider text-slate-500">Email de Soporte</span>
                                            <input id="config-support-email" type="email" class="super-input" placeholder="soporte@sedelynk.com">
                                        </label>
                                        <label class="block">
                                            <span class="mb-2 block text-xs font-black uppercase tracking-wider text-slate-500">URL de Soporte</span>
                                            <input id="config-support-url" type="url" class="super-input" placeholder="https://soporte.sedelynk.com">
                                        </label>
                                    </div>
                                    <div class="grid gap-4 md:grid-cols-2">
                                        <label class="block">
                                            <span class="mb-2 block text-xs font-black uppercase tracking-wider text-slate-500">Zona Horaria</span>
                                            <input id="config-timezone" class="super-input" placeholder="America/Guatemala">
                                        </label>
                                        <label class="block">
                                            <span class="mb-2 block text-xs font-black uppercase tracking-wider text-slate-500">Favicon URL</span>
                                            <input id="config-favicon-url" type="url" class="super-input" placeholder="https://ejemplo.com/favicon.ico">
                                        </label>
                                    </div>
                                    <div class="grid gap-4 md:grid-cols-2">
                                        <label class="block">
                                            <span class="mb-2 block text-xs font-black uppercase tracking-wider text-slate-500">WhatsApp de soporte</span>
                                            <input id="config-support-whatsapp" class="super-input" placeholder="502XXXXXXXX">
                                        </label>
                                        <label class="block">
                                            <span class="mb-2 block text-xs font-black uppercase tracking-wider text-slate-500">Mensaje de WhatsApp</span>
                                            <textarea id="config-support-message" class="super-input min-h-20" placeholder="Mensaje inicial para WhatsApp"></textarea>
                                        </label>
                                    </div>
                                    <button class="rounded-2xl bg-violet-600 px-5 py-3 text-sm font-black uppercase tracking-wider shadow-lg shadow-violet-950/40 transition hover:bg-violet-500" type="submit">Guardar General</button>
                                </form>
                            </div>

                            <div id="config-panel-landing" class="config-panel hidden space-y-5">
                                <form onsubmit="saveSaasLandingSettings(event)" class="super-panel space-y-4">
                                    <div>
                                        <h3 class="text-lg font-black">Personalización de Landing Page</h3>
                                        <p class="text-sm font-semibold text-slate-400">Edita la apariencia, costos y textos principales de tu landing page.</p>
                                    </div>
                                    <div class="grid gap-4 md:grid-cols-2">
                                        <label class="block">
                                            <span class="mb-2 block text-xs font-black uppercase tracking-wider text-slate-500">Título Principal Landing (Parte 1)</span>
                                            <input id="config-landing-title" class="super-input" placeholder="Vende cualquier producto en línea por">
                                        </label>
                                        <label class="block">
                                            <span class="mb-2 block text-xs font-black uppercase tracking-wider text-slate-500">Subtítulo Resaltado Landing (Parte 2)</span>
                                            <input id="config-landing-subtitle" class="super-input" placeholder="carrito y WhatsApp">
                                        </label>
                                    </div>
                                    <label class="block">
                                        <span class="mb-2 block text-xs font-black uppercase tracking-wider text-slate-500">Texto Descriptivo Hero</span>
                                        <textarea id="config-landing-hero-text" class="super-input min-h-20" placeholder="Crea tu tienda en línea..."></textarea>
                                    </label>
                                    
                                    <div class="grid gap-4 md:grid-cols-2">
                                        <label class="block">
                                            <span class="mb-2 block text-xs font-black uppercase tracking-wider text-slate-500">Precio Mensual (Q)</span>
                                            <input id="config-saas-monthly-price" type="number" min="0" class="super-input" placeholder="50">
                                        </label>
                                        <label class="block">
                                            <span class="mb-2 block text-xs font-black uppercase tracking-wider text-slate-500">Días de Prueba Gratis</span>
                                            <input id="config-saas-trial-days" type="number" min="0" class="super-input" placeholder="7">
                                        </label>
                                    </div>

                                    <div class="grid gap-4 md:grid-cols-2">
                                        <label class="block">
                                            <span class="mb-2 block text-xs font-black uppercase tracking-wider text-slate-500">Logotipo (Imagen)</span>
                                            <input id="config-saas-logo-input" type="file" accept="image/*" class="super-input">
                                        </label>
                                        <label class="block">
                                            <span class="mb-2 block text-xs font-black uppercase tracking-wider text-slate-500">Texto Alternativo / Marca</span>
                                            <input id="config-saas-logo-alt" type="text" class="super-input" placeholder="SEDELYNK">
                                        </label>
                                    </div>

                                    <div class="grid gap-4 grid-cols-3">
                                        <label class="block">
                                            <span class="mb-2 block text-[10px] font-black uppercase tracking-wider text-slate-500">Color Primario</span>
                                            <div class="flex items-center gap-2">
                                                <input id="config-saas-primary-color" type="color" class="h-10 w-10 cursor-pointer rounded-lg border-0 bg-transparent" value="#7C3AED">
                                                <span id="config-saas-primary-color-text" class="text-xs font-bold font-mono">#7C3AED</span>
                                            </div>
                                        </label>
                                        <label class="block">
                                            <span class="mb-2 block text-[10px] font-black uppercase tracking-wider text-slate-500">Color Secundario</span>
                                            <div class="flex items-center gap-2">
                                                <input id="config-saas-secondary-color" type="color" class="h-10 w-10 cursor-pointer rounded-lg border-0 bg-transparent" value="#D946EF">
                                                <span id="config-saas-secondary-color-text" class="text-xs font-bold font-mono">#D946EF</span>
                                            </div>
                                        </label>
                                        <label class="block">
                                            <span class="mb-2 block text-[10px] font-black uppercase tracking-wider text-slate-500">Color Acento</span>
                                            <div class="flex items-center gap-2">
                                                <input id="config-saas-accent-color" type="color" class="h-10 w-10 cursor-pointer rounded-lg border-0 bg-transparent" value="#FF6B1A">
                                                <span id="config-saas-accent-color-text" class="text-xs font-bold font-mono">#FF6B1A</span>
                                            </div>
                                        </label>
                                    </div>

                                    <label class="inline-flex cursor-pointer items-center gap-2 text-xs font-black text-slate-300">
                                        <input id="config-saas-show-price" type="checkbox" class="h-4 w-4 accent-violet-500" checked>
                                        Mostrar precio y secciones de costo en la Landing Page
                                    </label>

                                    <div class="border-t border-white/8 pt-4">
                                        <h4 class="mb-3 text-sm font-black text-slate-300">Preguntas Frecuentes (FAQs)</h4>
                                        <div id="faq-list-container" class="space-y-3"></div>
                                        <button type="button" onclick="addFaqItem()" class="mt-3 rounded-xl bg-white/8 px-4 py-2 text-xs font-black hover:bg-white/12 text-white">
