                        <td class="px-4 py-4 text-right sticky right-0 bg-[#0b1428] z-10 shadow-[-4px_0_8px_rgba(0,0,0,0.3)]">
                            <div class="flex flex-wrap justify-end gap-1">
                                <button onclick="openTenantDrawer('${tenant.id}')" class="rounded-xl bg-white/8 px-2.5 py-1.5 text-xs font-black transition hover:bg-white/12 text-white" title="Ver detalle"><i class="fa-regular fa-eye"></i> Ver</button>
                                <button onclick="openTenantPaymentModal('${tenant.id}')" class="rounded-xl bg-blue-600 px-2.5 py-1.5 text-xs font-black transition hover:bg-blue-500 text-white" title="Confirmar pago"><i class="fa-solid fa-receipt"></i> Pago</button>
                                ${tenant.status === 'active'
                                    ? `<button onclick="updateTenantStatus('${tenant.id}', 'suspended')" class="rounded-xl bg-rose-600/20 text-rose-300 border border-rose-500/20 px-2.5 py-1.5 text-xs font-black transition hover:bg-rose-600 hover:text-white" title="Suspender cuenta"><i class="fa-solid fa-ban"></i> Suspender</button>`
                                    : `<button onclick="updateTenantStatus('${tenant.id}', 'active')" class="rounded-xl bg-emerald-600 px-2.5 py-1.5 text-xs font-black transition hover:bg-emerald-500 text-white" title="Activar cuenta"><i class="fa-solid fa-check"></i> Activar</button>`
                                }
                                ${tenant.status !== 'deleted'
                                    ? `<button onclick="openTenantCancelModal('${tenant.id}')" class="rounded-xl bg-white/5 border border-white/10 px-2.5 py-1.5 text-xs font-black text-rose-400 transition hover:bg-rose-600 hover:text-white" title="Cancelar cuenta"><i class="fa-regular fa-trash-can"></i> Cancelar</button>`
                                    : `<button onclick="updateTenantStatus('${tenant.id}', 'active')" class="rounded-xl bg-blue-600 px-2.5 py-1.5 text-xs font-black transition hover:bg-blue-500 text-white" title="Restaurar cuenta"><i class="fa-solid fa-rotate-left"></i> Restaurar</button>`
                                }
                                <button onclick="openTenantPlanModal('${tenant.id}')" class="rounded-xl bg-violet-600 px-2.5 py-1.5 text-xs font-black transition hover:bg-violet-500 text-white" title="Cambiar plan"><i class="fa-solid fa-gear"></i> Plan</button>
                            </div>
                        </td>
                    </tr>
                `;
            }).join('');
        }

        function exportTenantsCSV() {
            if (filteredTenantsList.length === 0) {
                alert('No hay clientes para exportar.');
                return;
            }
            const headers = ['Negocio', 'Propietario', 'Slug', 'Email', 'WhatsApp', 'Plan', 'Estado', 'Precio Mensual', 'Fecha Creacion', 'Fecha Corte'];
            const rows = filteredTenantsList.map(t => [
                t.businessName || '',
                t.ownerName || '',
                t.slug || '',
                t.email || '',
                t.whatsapp || '',
                t.planName || '',
                t.statusLabel || t.status,
                t.monthlyPrice || 0,
                t.createdAt ? new Date(t.createdAt).toISOString().split('T')[0] : '',
                t.status === 'trial' 
                    ? (t.trialEndDate ? new Date(t.trialEndDate).toISOString().split('T')[0] : '')
                    : (t.currentPeriodEnd ? new Date(t.currentPeriodEnd).toISOString().split('T')[0] : '')
            ]);

            const csvContent = "data:text/csv;charset=utf-8,\uFEFF" 
                + [headers.join(','), ...rows.map(e => e.map(val => `"${String(val).replace(/"/g, '""')}"`).join(','))].join('\n');
            
            const encodedUri = encodeURI(csvContent);
            const link = document.createElement("a");
            link.setAttribute("href", encodedUri);
            link.setAttribute("download", `clientes_saas_${new Date().toISOString().split('T')[0]}.csv`);
            document.body.appendChild(link);
            link.click();
            document.body.removeChild(link);
        }

        async function refreshTenantViews() {
            await Promise.all([loadDashboard(), loadTenants(), loadPayments()]);
            if (selectedTenantId) {
                loadTenantDrawerDetail(selectedTenantId);
            }
        }

        async function updateTenantStatus(id, status) {
            await superFetch(`/tenants/${id}/status`, {
                method: 'PATCH',
                body: JSON.stringify({
                    status,
                    reason: status === 'suspended' ? 'Suspension manual super admin' : 'Activacion manual super admin'
                })
            });
            await refreshTenantViews();
        }

        function tenantById(id) {
            return superTenants.find(tenant => String(tenant.id) === String(id));
        }

        function openTenantActionModal({ id, type, title, subtitle, submitLabel, needsPlan = false, needsReason = false }) {
            const modal = document.getElementById('tenant-action-modal');
            document.getElementById('tenant-action-id').value = id;
            document.getElementById('tenant-action-type').value = type;
            document.getElementById('tenant-action-title').innerText = title;
            document.getElementById('tenant-action-subtitle').innerText = subtitle || '';
            document.getElementById('tenant-action-submit').innerText = submitLabel || 'Aplicar';
            document.getElementById('tenant-action-plan-wrapper').classList.toggle('hidden', !needsPlan);
            document.getElementById('tenant-action-reason-wrapper').classList.toggle('hidden', !needsReason);
            document.getElementById('tenant-action-payment-wrapper').classList.toggle('hidden', type !== 'payment');
            document.getElementById('tenant-action-reason').value = '';
            if (type === 'payment') renderTenantPaymentDefaults(id);
            if (needsPlan) renderTenantPlanOptions(id);
            modal.classList.remove('hidden');
            modal.classList.add('flex');
        }

        function closeTenantActionModal() {
            const modal = document.getElementById('tenant-action-modal');
            modal.classList.add('hidden');
            modal.classList.remove('flex');
        }

        function renderTenantPlanOptions(id) {
            const select = document.getElementById('tenant-action-plan');
            const tenant = tenantById(id);
            select.innerHTML = superPlans.length
                ? superPlans.map(plan => `<option value="${plan._id}" ${tenant?.plan?.id === plan._id ? 'selected' : ''}>${plan.name} - ${fmtMoney(plan.monthlyPrice)}</option>`).join('')
                : '<option value="">No hay planes creados</option>';
            document.getElementById('tenant-action-price').value = tenant?.monthlyPrice || '';
        }

        function openTenantPlanModal(id) {
            openTenantActionModal({
                id,
                type: 'plan',
                title: 'Cambiar plan',
                subtitle: tenantById(id)?.businessName || '',
                submitLabel: 'Guardar plan',
                needsPlan: true
            });
        }

        function openTenantCancelModal(id) {
            openTenantActionModal({
                id,
                type: 'cancel',
                title: 'Cancelar cuenta',
                subtitle: tenantById(id)?.businessName || '',
                submitLabel: 'Cancelar cuenta',
                needsReason: true
            });
        }

        function openTenantPaymentModal(id) {
            openTenantActionModal({
                id,
                type: 'payment',
                title: 'Confirmar pago',
                subtitle: tenantById(id)?.businessName || '',
                submitLabel: 'Confirmar pago'
            });
        }

        function renderTenantPaymentDefaults(id) {
            const tenant = tenantById(id);
            const now = new Date();
            const month = `${now.getFullYear()}-${String(now.getMonth() + 1).padStart(2, '0')}`;
            document.getElementById('tenant-action-payment-amount').value = tenant?.monthlyPrice || '';
            document.getElementById('tenant-action-payment-month').value = month;
            document.getElementById('tenant-action-payment-method').value = 'Efectivo';
        }

        async function submitTenantAction(event) {
            event.preventDefault();
            const id = document.getElementById('tenant-action-id').value;
            const type = document.getElementById('tenant-action-type').value;
            if (type === 'plan') {
                const planId = document.getElementById('tenant-action-plan').value;
                const monthlyPrice = Number(document.getElementById('tenant-action-price').value || 0);
                if (!planId) return;
                await superFetch(`/tenants/${id}/plan`, {
                    method: 'PATCH',
                    body: JSON.stringify({
                        planId,
                        ...(Number.isFinite(monthlyPrice) && monthlyPrice >= 0 ? { monthlyPrice } : {})
                    })
                });
            }
            if (type === 'cancel') {
                const reason = document.getElementById('tenant-action-reason').value.trim();
                await superFetch(`/tenants/${id}`, {
                    method: 'DELETE',
                    body: JSON.stringify({ reason })
                });
            }
            if (type === 'payment') {
                const amount = Number(document.getElementById('tenant-action-payment-amount').value || 0);
                const paymentMonth = document.getElementById('tenant-action-payment-month').value.trim();
                const paymentMethod = document.getElementById('tenant-action-payment-method').value.trim() || 'Efectivo';
                await superFetch(`/tenants/${id}/payments/confirm`, {
                    method: 'POST',
                    body: JSON.stringify({ amount, paymentMonth, paymentMethod })
                });
            }
            closeTenantActionModal();
            await refreshTenantViews();
        }

        function openTenantDrawer(id) {
            selectedTenantId = id;
            loadTenantDrawerDetail(id);
            
            const backdrop = document.getElementById('super-drawer-backdrop');
            const drawer = document.getElementById('super-tenant-drawer');
            
            backdrop.classList.remove('hidden');
            backdrop.offsetHeight;
            backdrop.classList.add('opacity-100');
            drawer.classList.remove('translate-x-full');
        }

        function closeTenantDrawer() {
            const backdrop = document.getElementById('super-drawer-backdrop');
            const drawer = document.getElementById('super-tenant-drawer');
            
            backdrop.classList.remove('opacity-100');
            drawer.classList.add('translate-x-full');
            
            setTimeout(() => {
                backdrop.classList.add('hidden');
            }, 300);
        }

        async function loadTenantDrawerDetail(id) {
            const res = await superFetch(`/tenants/${id}`);
            if (!res.ok) return;
            const data = await res.json();
            const tenant = data.tenant;
            
            document.getElementById('drawer-business-name').innerText = tenant.businessName;
            document.getElementById('drawer-owner-info').innerHTML = `
                <div class="font-bold text-slate-200">${tenant.ownerName || 'Sin propietario'}</div>
                <div class="text-xs text-slate-400 mt-0.5">${tenant.email || 'Sin email'} · ${tenant.whatsapp || 'Sin WhatsApp'}</div>
            `;
            document.getElementById('drawer-status-badge').innerHTML = statusBadge(tenant.status, tenant.statusLabel);
            
            const stats = [
                { label: 'Plan actual', value: tenant.planName },
                { label: 'Mensualidad', value: fmtMoney(tenant.monthlyPrice) },
                { label: 'Fecha de corte', value: fmtDate(tenant.currentPeriodEnd) },
                { label: 'Límite de pago', value: fmtDate(tenant.paymentDueDate) },
                { label: 'Días prueba rest.', value: tenant.trialDaysRemaining ?? 'Sin prueba' },
                { label: 'Inicio prueba', value: fmtDate(tenant.trialStartDate) },
                { label: 'Fin prueba', value: fmtDate(tenant.trialEndDate) },
                { label: 'Último pago', value: tenant.lastPayment ? fmtDate(tenant.lastPayment.paidAt || tenant.lastPayment.approvedAt) : 'Sin pagos' }
            ];
            
            document.getElementById('drawer-stats-grid').innerHTML = stats.map(s => `
                <div class="rounded-xl border border-white/5 bg-white/5 p-3">
                    <p class="text-[10px] font-black uppercase tracking-wider text-slate-500">${s.label}</p>
                    <p class="mt-1 text-xs font-black text-white truncate" title="${s.value}">${s.value}</p>
