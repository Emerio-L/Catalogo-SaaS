        function filterTenants() {
            const searchQuery = (document.getElementById('tenant-search-input')?.value || '').toLowerCase().trim();
            const statusFilter = document.getElementById('tenant-status-filter')?.value || '';
            const planFilter = document.getElementById('tenant-plan-filter')?.value || '';
            const createdStart = document.getElementById('tenant-created-start')?.value || '';
            const createdEnd = document.getElementById('tenant-created-end')?.value || '';
            const paymentStart = document.getElementById('tenant-payment-start')?.value || '';
            const paymentEnd = document.getElementById('tenant-payment-end')?.value || '';

            filteredTenantsList = superTenants.filter(tenant => {
                if (searchQuery) {
                    const matchName = String(tenant.businessName || '').toLowerCase().includes(searchQuery);
                    const matchSlug = String(tenant.slug || '').toLowerCase().includes(searchQuery);
                    const matchEmail = String(tenant.email || '').toLowerCase().includes(searchQuery);
                    const matchWhatsapp = String(tenant.whatsapp || '').toLowerCase().includes(searchQuery);
                    const matchOwner = String(tenant.ownerName || '').toLowerCase().includes(searchQuery);
                    if (!matchName && !matchSlug && !matchEmail && !matchWhatsapp && !matchOwner) {
                        return false;
                    }
                }

                if (statusFilter && tenant.status !== statusFilter) {
                    return false;
                }

                if (planFilter) {
                    const planId = tenant.plan?.id || tenant.planId;
                    if (String(planId) !== String(planFilter)) {
                        return false;
                    }
                }

                if (createdStart) {
                    const dateVal = new Date(tenant.createdAt);
                    const startVal = new Date(createdStart);
                    dateVal.setHours(0,0,0,0);
                    startVal.setHours(0,0,0,0);
                    if (dateVal < startVal) return false;
                }
                if (createdEnd) {
                    const dateVal = new Date(tenant.createdAt);
                    const endVal = new Date(createdEnd);
                    dateVal.setHours(0,0,0,0);
                    endVal.setHours(0,0,0,0);
                    if (dateVal > endVal) return false;
                }

                const paymentDateStr = tenant.status === 'trial' ? tenant.trialEndDate : tenant.currentPeriodEnd;
                if (paymentStart && paymentDateStr) {
                    const dateVal = new Date(paymentDateStr);
                    const startVal = new Date(paymentStart);
                    dateVal.setHours(0,0,0,0);
                    startVal.setHours(0,0,0,0);
                    if (dateVal < startVal) return false;
                }
                if (paymentEnd && paymentDateStr) {
                    const dateVal = new Date(paymentDateStr);
                    const endVal = new Date(paymentEnd);
                    dateVal.setHours(0,0,0,0);
                    endVal.setHours(0,0,0,0);
                    if (dateVal > endVal) return false;
                }

                return true;
            });

            renderTenants();
            renderMetrics();
        }

