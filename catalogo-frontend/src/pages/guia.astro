        function highlightElement(selector) {
            // Map legacy and dynamic selectors to static hotspots
            if (selector === 'button[onclick*="ResumenPreparacion"]') selector = '#pedidos-agrupar-pdf';
            if (selector === 'button[onclick*="TodosPDFPedidos"]') selector = '#pedidos-download';
            if (selector === 'button[onclick*="ConfirmLimpiarPedidos"]') selector = '#pedidos-clean';
            if (selector === '#setting-mostrar-categories') selector = '#setting-mostrar-categorias';

            currentTargetSelector = selector;
            recalculateHighlight();
        }

        function recalculateHighlight() {
            if (!currentTargetSelector) {
                glowOverlay.style.opacity = "0";
                glowOverlay.style.display = "none";
                return;
            }

            let target = null;
            try {
                target = deviceFrame.querySelector(currentTargetSelector);
            } catch (e) {
                console.error("Invalid selector:", currentTargetSelector);
            }

            if (target) {
                glowOverlay.style.display = "block";

                const rect = target.getBoundingClientRect();
                const containerRect = deviceFrame.getBoundingClientRect();

                // Calculate relative position within the device frame
                const top = rect.top - containerRect.top;
                const left = rect.left - containerRect.left;
                const width = rect.width;
                const height = rect.height;

                const highlightPadding = 12;
                glowOverlay.style.top = `${top - highlightPadding}px`;
                glowOverlay.style.left = `${left - highlightPadding}px`;
                glowOverlay.style.width = `${width + highlightPadding * 2}px`;
                glowOverlay.style.height = `${height + highlightPadding * 2}px`;
                glowOverlay.style.opacity = "1";
            } else {
                glowOverlay.style.opacity = "0";
                glowOverlay.style.display = "none";
            }
        }

        function updateStepUI() {
            const currentStep = tourSteps[currentStepIndex];

            stepBadge.innerText = `Paso ${currentStep.step} / ${tourSteps.length}`;
            sectionBadge.innerText = currentStep.section.replace("admin_", "").toUpperCase();
            scriptText.innerText = currentStep.script;
            selectorDisplay.innerText = currentStep.selector;

            switchMockupView(currentStep.section);
            highlightElement(currentStep.selector);

            // Re-run alignment calculations multiple times as the image loads and settles
            let count = 0;
            const interval = setInterval(() => {
                recalculateHighlight();
                count++;
                if (count > 15) clearInterval(interval); // 750ms total
            }, 50);

            stepProgress = 0;
            progressFill.style.width = "0%";
        }

        function startTimer() {
            if (playInterval) clearInterval(playInterval);
            
            playInterval = setInterval(() => {
                if (!isPlaying) return;

                stepProgress += (PROGRESS_INTERVAL / STEP_DURATION) * 100;
                progressFill.style.width = `${Math.min(stepProgress, 100)}%`;

                if (stepProgress >= 100) {
                    if (currentStepIndex < tourSteps.length - 1) {
                        currentStepIndex++;
                        updateStepUI();
                    } else {
                        if (autoplayToggle.checked) {
                            currentStepIndex = 0;
                            updateStepUI();
                        } else {
                            pauseTour();
                        }
                    }
                }
            }, PROGRESS_INTERVAL);
        }

        function playTour() {
            isPlaying = true;
            playIcon.className = "fa-solid fa-pause";
            btnPlay.classList.add("from-pink-600", "to-violet-500", "pulse-glow");
            
            document.querySelectorAll(".voice-bar").forEach(b => b.classList.add("active"));
            startTimer();
        }

        function pauseTour() {
            isPlaying = false;
            playIcon.className = "fa-solid fa-play";
            btnPlay.classList.remove("from-pink-600", "to-violet-500", "pulse-glow");
            
            document.querySelectorAll(".voice-bar").forEach(b => b.classList.remove("active"));
            
            if (playInterval) {
                clearInterval(playInterval);
                playInterval = null;
            }
        }

        btnPlay.addEventListener("click", () => {
            if (isPlaying) {
                pauseTour();
            } else {
                playTour();
            }
        });

        btnPrev.addEventListener("click", () => {
            if (currentStepIndex > 0) {
                currentStepIndex--;
                updateStepUI();
                if (isPlaying) startTimer();
            }
        });

        btnNext.addEventListener("click", () => {
            if (currentStepIndex < tourSteps.length - 1) {
                currentStepIndex++;
                updateStepUI();
                if (isPlaying) startTimer();
            }
        });

        btnReset.addEventListener("click", () => {
            currentStepIndex = 0;
            updateStepUI();
            if (isPlaying) {
                startTimer();
            } else {
                progressFill.style.width = "0%";
            }
        });

        // Listeners for resizing and scrolling to keep the focus box positioned correctly
        window.addEventListener("resize", recalculateHighlight);
        const mockupScroll = document.getElementById("mockup-content-scroll");
        if (mockupScroll) {
            mockupScroll.addEventListener("scroll", recalculateHighlight);
        }

        // Initial setup on page load
        updateStepUI();
    </script>

    <!-- Custom CSS styles -->
    <style is:inline>
        /* Waveform voice animation delay */
        .voice-bar {
            transition: height 0.1s ease-in-out;
        }
        .voice-bar.active {
            animation: pulse-height 0.8s ease-in-out infinite alternate;
        }
        .voice-bar:nth-child(2) { animation-delay: 0.1s; }
        .voice-bar:nth-child(3) { animation-delay: 0.2s; }
        .voice-bar:nth-child(4) { animation-delay: 0.3s; }
        .voice-bar:nth-child(5) { animation-delay: 0.4s; }
        .voice-bar:nth-child(6) { animation-delay: 0.25s; }
        .voice-bar:nth-child(7) { animation-delay: 0.15s; }
        .voice-bar:nth-child(8) { animation-delay: 0.35s; }
        .voice-bar:nth-child(9) { animation-delay: 0.45s; }
        .voice-bar:nth-child(10) { animation-delay: 0.05s; }

        @keyframes pulse-height {
            from { height: 4px; }
            to { height: 28px; }
        }

        .pulse-glow {
            box-shadow: 0 0 15px rgba(124, 58, 237, 0.6);
            animation: neon-glow 1.5s infinite alternate;
        }

        @keyframes neon-glow {
            from { box-shadow: 0 0 8px rgba(124, 58, 237, 0.4); }
            to { box-shadow: 0 0 20px rgba(236, 72, 153, 0.8); }
        }
    </style>
</Layout>
