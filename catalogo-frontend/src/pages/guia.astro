                img.src = "/assets/tour/register.png";
                browserUrl.innerText = "http://127.0.0.1:4322/#register";
            } else {
                // Admin views
                if (section === "admin_inventory") {
                    if (stepNum >= 9 && stepNum <= 11) {
                        img.src = "/assets/tour/category_modal.png";
                    } else if (stepNum >= 13 && stepNum <= 21) {
                        img.src = "/assets/tour/product_modal.png";
