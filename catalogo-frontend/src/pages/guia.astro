---
import Layout from '../layouts/Layout.astro';
---

<Layout
    title="Guía de Uso e Interactividad - Sedelynk"
    description="Tour interactivo con avatar virtual para pruebas locales."
    noindex={true}
>
    <!-- MAIN CONTAINER -->
    <div class="w-full min-h-screen bg-slate-950 text-slate-100 flex flex-col font-sans overflow-hidden">
        <!-- HEADER -->
        <header class="border-b border-slate-900 bg-slate-950/80 backdrop-blur-md px-6 py-4 flex items-center justify-between z-10 shrink-0">
            <div class="flex items-center gap-3">
                <span class="flex h-9 w-9 items-center justify-center rounded-xl bg-gradient-to-r from-violet-600 to-pink-500 text-white shadow-md">
                    <i class="fa-solid fa-graduation-cap"></i>
                </span>
                <div>
                    <h1 class="text-md font-heading font-black tracking-tight uppercase">Soporte y Guía de Uso</h1>
                    <p class="text-[9px] text-slate-400 font-extrabold uppercase tracking-wider">Guia de uso</p>
                </div>
            </div>
            
            <div class="flex items-center gap-3">
                <span class="inline-flex items-center gap-2 bg-slate-900 px-3.5 py-1.5 rounded-full text-[10px] font-black text-slate-400">
                    <i class="fa-solid fa-circle-check text-emerald-500 animate-pulse"></i> MODO INTERACTIVO
                </span>
                <a href="/" class="text-xs font-black uppercase text-slate-400 hover:text-slate-200 transition-colors">
                    <i class="fa-solid fa-arrow-left mr-1.5"></i> Salir
                </a>
            </div>
        </header>

        <!-- CONTENT PANEL GRID -->
        <div class="flex-grow flex flex-col md:flex-row overflow-hidden relative">
            
            <!-- LEFT PANEL: AVATAR PRESENTER -->
            <section class="w-full md:w-[420px] border-r border-slate-900 bg-slate-950 flex flex-col z-20 shrink-0 overflow-y-auto">
                <!-- Avatar Visual Box -->
                <div class="order-2 p-6 flex flex-col items-center justify-center border-b border-slate-900 bg-slate-900/10 shrink-0">
                    <div class="relative w-44 h-44 rounded-full bg-slate-900/80 border border-violet-500/20 flex items-center justify-center overflow-hidden shadow-2xl group">
                        <!-- Hologram Lines & Glow -->
                        <div class="absolute inset-0 bg-gradient-to-t from-violet-600/10 via-transparent to-pink-500/5 pointer-events-none"></div>
                        <div class="absolute w-full h-[2px] bg-violet-500/30 blur-[2px] animate-pulse top-1/2 left-0"></div>
                        
                        <!-- Simulated Digital Avatar Icon -->
                        <div id="avatar-container" class="relative z-10 flex flex-col items-center">
                            <svg class="w-28 h-28 text-violet-400 transition-transform duration-300 transform group-hover:scale-105" viewBox="0 0 200 200" fill="none" xmlns="http://www.w3.org/2000/svg">
                                <circle cx="100" cy="80" r="45" stroke="currentColor" stroke-width="4" fill="rgba(139, 92, 246, 0.15)"/>
                                <path d="M40 160C40 126.863 66.8629 100 100 100C133.137 100 160 126.863 160 160" stroke="currentColor" stroke-width="4" stroke-linecap="round" fill="rgba(139, 92, 246, 0.1)"/>
                                <circle cx="85" cy="75" r="5" fill="currentColor" class="avatar-eye"/>
                                <circle cx="115" cy="75" r="5" fill="currentColor" class="avatar-eye"/>
                                <path d="M90 95C95 98 105 98 110 95" stroke="currentColor" stroke-width="3" stroke-linecap="round" fill="none"/>
                            </svg>
                            <div class="absolute bottom-1 right-8 h-4.5 w-4.5 rounded-full bg-emerald-500 border-2 border-slate-950"></div>
                        </div>
                    </div>
                    
                    <!-- Voice Waveform Animation -->
                    <div class="mt-4 flex items-center justify-center gap-1 w-full h-8 px-8">
                        <div class="w-1 bg-violet-500 rounded-full voice-bar h-3"></div>
                        <div class="w-1 bg-violet-400 rounded-full voice-bar h-6"></div>
                        <div class="w-1 bg-pink-500 rounded-full voice-bar h-4"></div>
                        <div class="w-1 bg-pink-400 rounded-full voice-bar h-7"></div>
                        <div class="w-1 bg-purple-500 rounded-full voice-bar h-5"></div>
                        <div class="w-1 bg-violet-500 rounded-full voice-bar h-2"></div>
                        <div class="w-1 bg-pink-500 rounded-full voice-bar h-6"></div>
                        <div class="w-1 bg-violet-400 rounded-full voice-bar h-8"></div>
                        <div class="w-1 bg-purple-500 rounded-full voice-bar h-4"></div>
                        <div class="w-1 bg-pink-400 rounded-full voice-bar h-7"></div>
                        <div class="w-1 bg-violet-500 rounded-full voice-bar h-2"></div>
                    </div>
                </div>

                <!-- Active Step Script Details -->
                <div class="order-1 flex-grow p-6 flex flex-col justify-between">
                    <div>
                        <!-- Active Step Header info -->
                        <div class="flex items-center justify-between mb-4">
                            <span id="step-badge" class="bg-violet-950 text-violet-300 border border-violet-800/50 rounded-full px-3 py-1 text-[10px] font-black uppercase tracking-wider">
                                Paso 1 / 46
                            </span>
                            <span id="section-badge" class="bg-slate-900 text-slate-400 rounded-full px-3 py-1 text-[9px] font-black uppercase tracking-wider">
                                LANDING PAGE
                            </span>
                        </div>

                        <!-- Current Script Speech Box -->
                        <div class="bg-slate-900/60 border border-slate-800/50 rounded-3xl p-5 mb-5 min-h-[120px] flex flex-col justify-between relative overflow-hidden text-left">
                            <div class="absolute top-2 left-2 text-[20px] text-violet-500/20 font-black"><i class="fa-solid fa-quote-left"></i></div>
                            <p id="script-text" class="text-sm font-extrabold text-slate-200 leading-relaxed pl-3 pt-2 relative z-10">
                                Presiona reproducir para iniciar el tour explicativo de la plataforma.
                            </p>
                            <!-- Progress Bar for the active Step -->
                            <div class="mt-4 w-full bg-slate-950 rounded-full h-1 overflow-hidden">
                                <div id="step-progress-fill" class="bg-gradient-to-r from-violet-600 to-pink-500 h-full w-[0%]" style="transition: width 0.1s linear;"></div>
                            </div>
                        </div>

                        <!-- CSS Selector details (for debug/testing) -->
                        <div class="bg-slate-950 border border-slate-900 rounded-2xl p-4 text-left">
                            <p class="text-[9px] font-black text-slate-500 uppercase tracking-wider mb-1.5"><i class="fa-solid fa-magnifying-glass-chart mr-1"></i> Selector CSS Activo</p>
                            <code id="selector-display" class="block text-xs font-bold text-violet-400 font-mono break-all bg-slate-900/60 p-2 rounded-xl border border-slate-900">
                                header button[onclick*="register"]
                            </code>
                        </div>
                    </div>

                    <!-- Player Interface Controls -->
                    <div class="order-first mb-6 pb-6 border-b border-slate-900 space-y-4">
                        <!-- Controls Row -->
                        <div class="flex items-center justify-center gap-3">
                            <button id="btn-prev" class="h-10 w-10 flex items-center justify-center rounded-xl bg-slate-900 hover:bg-slate-800 text-slate-300 transition hover:text-white active:scale-95" title="Anterior">
                                <i class="fa-solid fa-backward-step"></i>
                            </button>
                            <button id="btn-play" class="h-14 w-14 flex items-center justify-center rounded-2xl bg-gradient-to-r from-violet-600 to-pink-500 text-white text-lg font-black transition-all shadow-lg shadow-violet-600/20 hover:scale-105 active:scale-95" title="Reproducir">
                                <i class="fa-solid fa-play" id="play-icon"></i>
                            </button>
                            <button id="btn-next" class="h-10 w-10 flex items-center justify-center rounded-xl bg-slate-900 hover:bg-slate-800 text-slate-300 transition hover:text-white active:scale-95" title="Siguiente">
                                <i class="fa-solid fa-forward-step"></i>
                            </button>
                            <button id="btn-reset" class="h-10 w-10 flex items-center justify-center rounded-xl bg-slate-900 hover:bg-slate-800 text-slate-400 transition hover:text-white active:scale-95" title="Reiniciar">
                                <i class="fa-solid fa-rotate-left"></i>
                            </button>
                        </div>

                        <!-- Auto-Advance Switch -->
                        <div class="flex items-center justify-between px-3 py-2 bg-slate-900/30 rounded-xl border border-slate-900 text-xs">
                            <span class="font-extrabold text-slate-400 uppercase tracking-wide flex items-center gap-1.5">
                                <i class="fa-solid fa-forward text-slate-500"></i> Autoplay Continuo
                            </span>
                            <label class="relative inline-flex items-center cursor-pointer">
                                <input type="checkbox" id="autoplay-toggle" checked class="sr-only">
                                <div class="w-9 h-5 bg-slate-800 rounded-full border border-slate-700 toggle-bg"></div>
                                <div class="absolute left-0.5 top-0.5 bg-slate-400 w-4 h-4 rounded-full shadow-md toggle-dot transition-transform"></div>
                            </label>
                        </div>
                    </div>
                </div>
            </section>

            <!-- RIGHT PANEL: HIGH-FIDELITY INTERFACE SIMULATOR -->
            <section class="flex-1 bg-slate-900 p-2 md:p-3 flex items-center justify-center overflow-hidden relative">
                <!-- Grid background -->
                <div class="absolute inset-0 pointer-events-none opacity-5 bg-[radial-gradient(#7c3aed_1.5px,transparent_1.5px)] bg-[size:24px_24px]"></div>

                <!-- WEB DEVICE FRAME -->
                <div id="browser-device-frame" class="w-full max-w-none h-full bg-[#070b19] border border-slate-800 rounded-[1.5rem] shadow-2xl flex flex-col overflow-hidden relative z-10">
                    <!-- Browser Address bar -->
                    <div class="bg-[#0b1026] border-b border-slate-900 px-6 py-3 flex items-center gap-3 shrink-0 select-none">
                        <div class="flex gap-1.5 shrink-0">
                            <span class="w-3 h-3 rounded-full bg-rose-500/80"></span>
                            <span class="w-3 h-3 rounded-full bg-amber-500/80"></span>
                            <span class="w-3 h-3 rounded-full bg-emerald-500/80"></span>
                        </div>
                        <div class="flex gap-2 text-xs text-slate-500 shrink-0">
                            <i class="fa-solid fa-arrow-left"></i>
                            <i class="fa-solid fa-arrow-right"></i>
                            <i class="fa-solid fa-rotate-right"></i>
                        </div>
                        <div class="flex-grow bg-[#131b3c] border border-slate-800 rounded-xl px-4 py-1 flex items-center gap-2">
                            <i class="fa-solid fa-lock text-[10px] text-emerald-500"></i>
                            <span id="browser-url" class="text-slate-400 text-xs font-semibold font-mono">http://127.0.0.1:4322/</span>
                        </div>
                    </div>

                    <!-- MOCKUP CONTENT CONTAINER (SCREENSHOTS FLOW WITH PERCENTAGE HOTSPOTS) -->
                    <div id="mockup-content-scroll" class="flex-grow bg-[#070b19] relative overflow-hidden select-none h-full w-full">
                        <!-- Real Screenshot Image -->
                        <img id="mockup-screenshot-img" src="/assets/tour/landing.png" class="w-full h-full object-fill pointer-events-none" />
                        
                        <!-- HOTSPOTS FOR SPOTLIGHT ENFOQUE (Absolute positions matching visual elements in screenshots) -->
                        
                        <!-- Landing Hotspots -->
                        <!-- Botón COMENZAR GRATIS en el header (medido: x≈1370/1536=89.2%, y≈76/747=10.2%, w≈165/1536=10.7%, h≈42/747=5.6%) -->
                        <div id="landing-register-trigger" class="absolute pointer-events-none" style="top: 9%; left: 83.5%; width: 13.5%; height: 6%;"></div>
                        
                        <!-- Register Hotspots (medidos en register.png 1536x1468px) -->
                        <!-- Campo Nombre del negocio: y≈420/1468=28.6%, x≈510/1536=33.2%, w≈516/1536=33.6% -->
                        <div id="landing-register-modal" class="absolute pointer-events-none" style="top: 3%; left: 33%; width: 34%; height: 81%;"></div>
                        <div id="landing-register-name" class="absolute pointer-events-none" style="top: 27%; left: 33%; width: 34%; height: 4.5%;"></div>
                        <!-- Campo WhatsApp: y≈570/1468=38.8% -->
                        <div id="landing-register-whatsapp" class="absolute pointer-events-none" style="top: 38%; left: 33%; width: 34%; height: 4.5%;"></div>
                        <!-- Campo Usuario: y≈720/1468=49%, x≈510 w≈248 -->
                        <div id="landing-register-user" class="absolute pointer-events-none" style="top: 48%; left: 33%; width: 16.5%; height: 4.5%;"></div>
                        <!-- Campo Email: x≈762/1536=49.6%, w≈264 -->
                        <div id="landing-register-email" class="absolute pointer-events-none" style="top: 48%; left: 49.5%; width: 16.5%; height: 4.5%;"></div>
                        <!-- Campo Contraseña: y≈870/1468=59.3% -->
                        <div id="landing-register-password" class="absolute pointer-events-none" style="top: 58.5%; left: 33%; width: 34%; height: 4.5%;"></div>
                        <!-- Botón Guardar y crear catálogo: y≈1120/1468=76.3% -->
                        <div id="landing-register-submit" class="absolute pointer-events-none" style="top: 75%; left: 33%; width: 34%; height: 5.5%;"></div>
                        
                        <!-- Sidebar Hotspots — medidos en inventory.png (sidebar ~290px de 1536) -->
                        <!-- Inventario: y≈167/747=22.4% -->
                        <div id="admin-tab-inventario" class="absolute pointer-events-none" style="top: 20.5%; left: 1%; width: 18%; height: 6%;"></div>
                        <!-- Historial de pedidos: y≈225/747=30.1% -->
                        <div id="admin-tab-pedidos" class="absolute pointer-events-none" style="top: 28.5%; left: 1%; width: 18%; height: 6%;"></div>
                        <!-- Perfil: y≈283/747=37.9% -->
                        <div id="admin-tab-perfil" class="absolute pointer-events-none" style="top: 36.5%; left: 1%; width: 18%; height: 6%;"></div>
                        <!-- Ajustes: y≈342/747=45.8% -->
                        <div id="admin-tab-config" class="absolute pointer-events-none" style="top: 43.5%; left: 1%; width: 18%; height: 6%;"></div>
                        
                        <!-- Inventory Hotspots — medidos en inventory.png -->
                        <!-- CREAR CATEGORÍA: x≈1420/1536=92.4%, y≈540/747=72.3%, w≈116/1536=7.5%, h≈45/747=6% -->
                        <div id="btn-crear-categoria-trigger" class="absolute pointer-events-none" style="top: 55%; left: 85.5%; width: 11.5%; height: 6.5%;"></div>
                        <!-- + AGREGAR PRODUCTO: x≈1228/1536=79.9%, y≈540/747=72.3%, w≈155/1536=10.1% -->
                        <div id="btn-agregar-producto-trigger" class="absolute pointer-events-none" style="top: 55%; left: 72%; width: 13.5%; height: 6.5%;"></div>
                        <!-- Acciones en la lista de productos (fila producto debajo del header de tabla) -->
                        <div class="btn-edit-product-mock absolute pointer-events-none" style="top: 90%; left: 90%; width: 3%; height: 4%;"></div>
                        <div class="btn-toggle-status-mock absolute pointer-events-none" style="top: 90%; left: 78%; width: 10%; height: 4%;"></div>
                        <div class="btn-delete-product-mock absolute pointer-events-none" style="top: 90%; left: 93%; width: 3%; height: 4%;"></div>
                        
                        <!-- Category Modal Hotspots — medidos en category_modal.png -->
                        <!-- Campo nombre categoría: y≈440/747=58.9%, x≈565/1536=36.8%, w≈406/1536=26.4% -->
                        <div id="admin-categoria-nombre-input" class="absolute pointer-events-none" style="top: 57%; left: 36.5%; width: 27%; height: 5%;"></div>
                        <!-- Botón GUARDAR modal categoría: y≈525/747=70.3%, x≈820/1536=53.4%, w≈82/1536=5.3% -->
                        <div id="admin-categoria-submit" class="absolute pointer-events-none" style="top: 68.5%; left: 53%; width: 8%; height: 5%;"></div>
                        
                        <!-- Product Modal Hotspots — medidos en product_modal.png (modal visible arriba) -->
                        <!-- Nombre producto: y≈140/747=18.7%, x≈610/1536=39.7%, w≈450/1536=29.3% -->
                        <div id="admin-product-modal" class="absolute pointer-events-none" style="top: 5%; left: 35%; width: 30%; height: 90%;"></div>
                        <div id="admin-nombre" class="absolute pointer-events-none" style="top: 17%; left: 39.5%; width: 29.5%; height: 4.5%;"></div>
                        <!-- Categoría select: y≈200/747=26.8% -->
                        <div id="admin-categoria" class="absolute pointer-events-none" style="top: 25.5%; left: 39.5%; width: 29.5%; height: 4.5%;"></div>
                        <!-- Unidad: y≈260/747=34.8%, w≈210/1536=13.7% -->
                        <div id="admin-unidad" class="absolute pointer-events-none" style="top: 33.5%; left: 39.5%; width: 13.5%; height: 4.5%;"></div>
                        <!-- Precio: x≈825/1536=53.7%, w≈235/1536=15.3% -->
                        <div id="admin-precio" class="absolute pointer-events-none" style="top: 33.5%; left: 53.5%; width: 15.5%; height: 4.5%;"></div>
                        <!-- Orden/Stock: y≈322/747=43.1% -->
                        <div id="admin-orden" class="absolute pointer-events-none" style="top: 41.5%; left: 39.5%; width: 29.5%; height: 4.5%;"></div>
                        <!-- Descripción: y≈384/747=51.4%, h≈78/747=10.4% -->
                        <div id="admin-descripcion" class="absolute pointer-events-none" style="top: 50%; left: 39.5%; width: 29.5%; height: 8%;"></div>
                        <!-- Foto botón: y≈475/747=63.6% -->
                        <div id="admin-foto-btn" class="absolute pointer-events-none" style="top: 62%; left: 39.5%; width: 29.5%; height: 5%;"></div>
                        <!-- Estado Activo toggle: y≈535/747=71.6% -->
                        <div id="admin-activo" class="absolute pointer-events-none" style="top: 70%; left: 39.5%; width: 29.5%; height: 4.5%;"></div>
                        <!-- Botón GUARDAR PRODUCTO: y≈594/747=79.5% -->
                        <div id="admin-form-submit" class="absolute pointer-events-none" style="top: 78%; left: 39.5%; width: 29.5%; height: 5%;"></div>
                        
                        <!-- Pedidos Hotspots — medidos en pedidos.png -->
                        <!-- Buscador: y≈348/747=46.6%, x≈746/1536=48.6%, w≈780/1536=50.8% -->
                        <div id="pedidos-buscar" class="absolute pointer-events-none" style="top: 44.5%; left: 19%; width: 76%; height: 6%;"></div>
                        <!-- SELECCIONADOS (modo agrupación): y≈441/747=59%, x≈910/1536=59.2% -->
                        <div id="pedidos-agrupar-modo" class="absolute pointer-events-none" style="top: 57%; left: 58.5%; width: 8%; height: 5.5%;"></div>
                        <!-- AGRUPAR PEDIDOS EN PDF: x≈1010/1536=65.7%, w≈168/1536=10.9% -->
                        <div id="pedidos-agrupar-pdf" class="absolute pointer-events-none" style="top: 57%; left: 65%; width: 12%; height: 5.5%;"></div>
                        <!-- DESCARGAR TODOS LOS RECIBOS: x≈1185/1536=77.1%, w≈165/1536=10.7% -->
                        <div id="pedidos-download" class="absolute pointer-events-none" style="top: 57%; left: 76.5%; width: 12%; height: 5.5%;"></div>
                        <!-- LIMPIAR HISTORIAL: x≈1355/1536=88.2%, w≈134/1536=8.7% -->
                        <div id="pedidos-clean" class="absolute pointer-events-none" style="top: 57%; left: 87.5%; width: 10%; height: 5.5%;"></div>
                        
                        <!-- Perfil Hotspots — medidos en perfil.png -->
                        <!-- Campo WhatsApp input: y≈555/747=74.3%, x≈357/1536=23.2%, w≈760/1536=49.5% -->
                        <div id="perfil-whatsapp-input" class="absolute pointer-events-none" style="top: 72%; left: 23%; width: 50%; height: 6%;"></div>
                        <!-- EDITAR logo: y≈490/747=65.6%, x≈1435/1536=93.4%, w≈95/1536=6.2% -->
                        <div id="btn-perfil-logo-edit" class="absolute pointer-events-none" style="top: 63%; left: 90%; width: 6%; height: 5%;"></div>
                        <!-- EDITAR nombre: y≈596/747=79.8% -->
                        <div id="btn-perfil-name-edit" class="absolute pointer-events-none" style="top: 76%; left: 90%; width: 6%; height: 5%;"></div>
                        <!-- EDITAR título catálogo: y≈665/747=89% -->
                        <div id="btn-perfil-title-edit" class="absolute pointer-events-none" style="top: 88.5%; left: 90%; width: 6%; height: 5%;"></div>
                        <!-- Estado suscripción (perfil_bottom.png): fila 'Estado - En prueba gratis': top≈65%, left≈20% -->
                        <div id="account-status" class="absolute pointer-events-none" style="top: 48%; left: 20.5%; width: 37%; height: 50%;"></div>
                        <!-- Cambiar contraseña (perfil_bottom.png): card derecho, top≈50% -->
                        <div id="btn-perfil-password-toggle" class="absolute pointer-events-none" style="top: 57%; left: 61.5%; width: 36%; height: 11%;"></div>
                        
                        <!-- Ajustes Hotspots — medidos en ajustes.png -->
                        <!-- Tab COLOR ACTUAL: y≈80/747=10.7%, x≈360/1536=23.4%, w≈122/1536=7.9% -->
                        <div id="palette-tab-current" class="absolute pointer-events-none" style="top: 62.5%; left: 22%; width: 10%; height: 6%;"></div>
                        <!-- Checkbox Mostrar buscador: y≈578/747=77.4%, x≈860/1536=56%, checkbox x≈868px/1536=56.5%, w=32px -->
                        <div id="setting-mostrar-buscador" class="absolute pointer-events-none" style="top: 57%; left: 55%; width: 40%; height: 5.5%;"></div>
                        <!-- Checkbox Mostrar categorías: y≈656/747=87.8% -->
                        <div id="setting-mostrar-categorias" class="absolute pointer-events-none" style="top: 63%; left: 55%; width: 40%; height: 5.5%;"></div>
                        <!-- Ajustes BOTTOM (ajustes_bottom.png) - Sección 'Confirmación de pedidos' (columna derecha) -->
                        <!-- Checkbox Enviar por carrito: top≈27.5%, left≈62% -->
                        <div id="setting-order-options" class="absolute pointer-events-none" style="top: 24%; left: 61%; width: 36%; height: 22%;"></div>
                        <div id="setting-order-cart-enabled" class="absolute pointer-events-none" style="top: 26%; left: 62%; width: 36%; height: 6%;"></div>
                        <!-- Checkbox Enviar por WhatsApp: top≈38% -->
                        <div id="setting-order-whatsapp-enabled" class="absolute pointer-events-none" style="top: 38%; left: 62%; width: 36%; height: 6%;"></div>
                        <!-- DIRECCIÓN DEL CLIENTE dropdown 'Opcional': top≈52% -->
                        <div id="setting-customer-fields" class="absolute pointer-events-none" style="top: 47%; left: 61%; width: 36%; height: 22%;"></div>
                        <div id="setting-address-requirement" class="absolute pointer-events-none" style="top: 51%; left: 62%; width: 36%; height: 6%;"></div>
                        <!-- COMENTARIO DEL CLIENTE dropdown 'Opcional': top≈61% -->
                        <div id="setting-comment-requirement" class="absolute pointer-events-none" style="top: 61%; left: 62%; width: 36%; height: 6%;"></div>
                        <!-- MONEDA VISIBLE 'Quetzal guatemalteco (GTQ)': en sección abajo, top≈90% -->
                        <div id="setting-moneda-visible" class="absolute pointer-events-none" style="top: 88%; left: 22.5%; width: 55%; height: 6%;"></div>
                        <div id="sidebar-support" class="absolute pointer-events-none" style="top: 52%; left: 1%; width: 17%; height: 31%;"></div>
                    </div>

                    <!-- NESTED SPOTLIGHT RING OVERLAY -->
                    <div id="selector-glow-overlay" class="pointer-events-none border-[3px] border-pink-500 rounded-2xl shadow-[0_0_25px_rgba(236,72,153,0.7),_inset_0_0_15px_rgba(236,72,153,0.4)] opacity-0 z-[9999] transition-all duration-300 ease-out absolute" style="display: none;">
                        <span class="absolute -top-7 left-0 bg-pink-500 text-white font-black text-[9px] uppercase px-2 py-0.5 rounded shadow-md tracking-wider animate-bounce flex items-center gap-1">
                            <i class="fa-solid fa-circle-play"></i> Enfoque
                        </span>
                    </div>
                </div>
            </section>
        </div>
    </div>

    <!-- ON-PAGE SCRIPTS FOR TOUR AND MOCKUP INTERACTION LOGIC -->
    <script is:inline>
        // Tour Steps Data matching the analyzed DOM Selectors in logical sequential order
        const legacyTourSteps = [
